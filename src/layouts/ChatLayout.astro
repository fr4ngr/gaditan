        <script>
            import { AudioRecorderManager } from '../scripts/audio-recorder';
            
            document.addEventListener('DOMContentLoaded', () => {
                const recordBtn = document.getElementById('record-audio-btn');
                const deleteAudioBtn = document.getElementById('delete-audio-btn');
                const statusTxt = document.getElementById('record-audio-status');
                const indicator = document.getElementById('recording-indicator');
                const previewContainer = document.getElementById('audio-preview-container');
                const previewAudio = document.getElementById('audio-preview');
                
                let audioManager = new AudioRecorderManager(
                    () => {
                        // onStart
                        if (recordBtn) {
                            recordBtn.innerText = '⏹️';
                            recordBtn.style.background = '#ef4444';
                        }
                        if (statusTxt) statusTxt.style.display = 'none';
                        if (indicator) indicator.style.display = 'block';
                        if (deleteAudioBtn) deleteAudioBtn.style.display = 'none';
                        if (previewContainer) previewContainer.style.display = 'none';
                    },
                    (audioBlob, audioUrl) => {
                        // onStop
                        (window as any).currentAudioBlob = audioBlob;
                        if (recordBtn) {
                            recordBtn.innerText = '🎙️';
                            recordBtn.style.background = 'var(--primary-color)';
                            recordBtn.style.display = 'none'; // Ocultar mientras haya audio
                        }
                        if (indicator) indicator.style.display = 'none';
                        if (statusTxt) statusTxt.style.display = 'none';
                        
                        if (previewContainer) previewContainer.style.display = 'block';
                        if (previewAudio) (previewAudio as HTMLAudioElement).src = audioUrl;
                        if (deleteAudioBtn) deleteAudioBtn.style.display = 'block';
                    },
                    (err) => {
                        alert("No se pudo acceder al micrófono.");
                        if (indicator) indicator.style.display = 'none';
                        if (statusTxt) statusTxt.style.display = 'block';
                        if (recordBtn) {
                            recordBtn.innerText = '🎙️';
                            recordBtn.style.background = 'var(--primary-color)';
                        }
                    }
                );
                
                if (recordBtn) {
                    recordBtn.addEventListener('click', () => {
                        if (audioManager.isRecording()) {
                            audioManager.stopRecording();
                        } else {
                            audioManager.startRecording();
                        }
                    });
                }
                
                if (deleteAudioBtn) {
                    deleteAudioBtn.addEventListener('click', () => {
                        (window as any).currentAudioBlob = null;
                        if (previewAudio) (previewAudio as HTMLAudioElement).src = '';
                        if (previewContainer) previewContainer.style.display = 'none';
                        if (deleteAudioBtn) deleteAudioBtn.style.display = 'none';
                        
                        if (recordBtn) {
                            recordBtn.style.display = 'flex';
                        }
                        if (statusTxt) {
                            statusTxt.style.display = 'block';
                            statusTxt.innerText = 'Grabar nota de voz';
                        }
                    });
                }
            });
        </script>
    </body>
</html>
