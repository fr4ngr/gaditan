---
// src/layouts/ChatLayout.astro
import '../styles/chat.css';
import '../styles/components.css';
interface Props {
	title: string;
    description?: string;
}

const { title, description } = Astro.props;
import themeData from '../data/theme.json';

import Header from '../components/layout/Header.astro';
import NewPostModal from '../components/modals/NewPostModal.astro';
import ProfileTab from '../components/tabs/ProfileTab.astro';
import MuroTab from '../components/tabs/MuroTab.astro';
import LoginModal from '../components/modals/LoginModal.astro';
import OnboardingModal from '../components/modals/OnboardingModal.astro';
import { LegalWelcomeModal } from '../components/onboarding/LegalWelcomeModal';
import CommunityTab from '../components/tabs/CommunityTab.astro';
import DMsTab from '../components/tabs/DMsTab.astro';
import MapWidget from '../components/widgets/MapWidget.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={Astro.props.description || "Asistente Inteligente de Cádiz"} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="manifest" href="/manifest.json" />
        <meta name="theme-color" content="#3b82f6" />
        <link rel="apple-touch-icon" href="/logo.png" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<slot name="head" />
		
        <!-- GLOBAL THEME INJECTION -->
        <style is:inline set:html={`
            :root {
                --ds-primary: ${themeData.primary} !important;
                --primary-color: ${themeData.primary} !important;
                --bubble-user-bg: ${themeData.primary} !important;
            }
            .card, .card-wrapper > div > div {
                border-radius: ${themeData.radius} !important;
            }
        `}></style>
		
		<!-- Leaflet CSS & JS -->
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
		
		<!-- Leaflet Routing Machine CSS & JS -->
		<link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
		<script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

        <!-- Lottie Web Player -->
        <NewPostModal />
        <LegalWelcomeModal client:only="preact" />

        <script>
            window.switchTab = function(tab) {
                const tabChat = document.getElementById('tab-chat');
                const tabMuro = document.getElementById('tab-muro');
                const tabDms = document.getElementById('tab-dms');
                const tabComunidad = document.getElementById('tab-comunidad');
                const tabMapa = document.getElementById('tab-mapa');
                
                const navChat = document.getElementById('nav-tab-chat');
                const navMuro = document.getElementById('nav-tab-muro');
                const navDms = document.getElementById('nav-tab-dms');
                const navComunidad = document.getElementById('nav-tab-comunidad');

                // Hide all
                tabChat.style.display = 'none';
                tabMuro.style.display = 'none';
                const tabPerfil = document.getElementById('tab-perfil');
                if (tabPerfil) tabPerfil.style.display = 'none';
                if (tabDms) tabDms.style.display = 'none';
                if (tabComunidad) tabComunidad.style.display = 'none';
                if (tabMapa) tabMapa.style.display = 'none';
                
                navChat.classList.remove('active');
                navMuro.classList.remove('active');
                if (navDms) navDms.classList.remove('active');
                if (navComunidad) navComunidad.classList.remove('active');
                const navMapaTab = document.getElementById('nav-tab-mapa');
                if (navMapaTab) navMapaTab.classList.remove('active');
                
                navChat.style.color = 'var(--text-secondary)';
                navMuro.style.color = 'var(--text-secondary)';
                if (navDms) navDms.style.color = 'var(--text-secondary)';
                if (navComunidad) navComunidad.style.color = 'var(--text-secondary)';
                const bottomNav = document.getElementById('bottom-nav');
                const mainInput = document.getElementById('main-input');

                if (bottomNav) {
                    bottomNav.style.transition = 'transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s ease, bottom 0.3s ease, top 0.3s ease';
                }
                if (mainInput) {
                    mainInput.style.transition = 'transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s ease, bottom 0.3s ease';
                }

                if (tab === 'chat') {
                    tabChat.style.display = 'flex';
                    navChat.classList.add('active');
                    navChat.style.color = 'var(--primary-color)';
                    
                    if (bottomNav) {
                        bottomNav.style.bottom = 'auto';
                        bottomNav.style.top = '16px';
                        bottomNav.style.transform = 'translateX(-50%) scale(0.9)';
                        bottomNav.style.opacity = '0.9';
                    }
                    if (mainInput) {
                        mainInput.style.bottom = 'max(16px, env(safe-area-inset-bottom))';
                        mainInput.style.transform = 'translateX(-50%) translateY(0)';
                        mainInput.style.opacity = '1';
                        mainInput.style.pointerEvents = 'auto';
                    }
                } else {
                    if (bottomNav) {
                        bottomNav.style.bottom = 'max(16px, env(safe-area-inset-bottom))';
                        bottomNav.style.top = 'auto';
                        bottomNav.style.transform = 'translateX(-50%) scale(1)';
                        bottomNav.style.opacity = '1';
                    }
                    if (mainInput) {
                        mainInput.style.transform = 'translateX(-50%) translateY(150%)';
                        mainInput.style.opacity = '0';
                        mainInput.style.pointerEvents = 'none';
                    }

                    if (tab === 'muro') {
                        tabMuro.style.display = 'flex';
                        navMuro.classList.add('active');
                        navMuro.style.color = 'var(--primary-color)';
                        window.loadFeed();
                    } else if (tab === 'dms') {
                        if (tabDms) tabDms.style.display = 'flex';
                        if (navDms) navDms.classList.add('active');
                        if (navDms) navDms.style.color = 'var(--primary-color)';
                        if (window.loadDMsInbox) window.loadDMsInbox();
                    } else if (tab === 'mapa') {
                        if (tabMapa) tabMapa.style.display = 'flex';
                        const navMapa = document.getElementById('nav-tab-mapa');
                        if (navMapa) {
                            navMapa.classList.add('active');
                            navMapa.style.color = 'var(--primary-color)';
                        }
                        if (!document.getElementById('fullscreen-leaflet-main') && window.openFullscreenMap) {
                            window.openFullscreenMap(null, null, 'main');
                        }
                    } else if (tab === 'comunidad') {
                        if (tabComunidad) tabComunidad.style.display = 'flex';
                        if (navComunidad) navComunidad.classList.add('active');
                        if (navComunidad) navComunidad.style.color = 'var(--primary-color)';
                        if (window.loadCommunity) window.loadCommunity();
                    } else if (tab === 'perfil') {
                        if (tabPerfil) tabPerfil.style.display = 'flex';
                    }
                }
            };


            window.openNewPostModal = async function() {
                try {
                    const res = await fetch('/api/auth/me');
                    const data = await res.json();
                    if (!data.user) {
                        window.openLoginModal();
                        return;
                    }
                    document.getElementById('new-post-content').value = '';
                    document.getElementById('new-post-image').value = '';
                    window.currentAudioBlob = null;
                    const statusTxt = document.getElementById('record-audio-status');
                    const deleteAudioBtn = document.getElementById('delete-audio-btn');
                    const recordBtn = document.getElementById('record-audio-btn');
                    const indicator = document.getElementById('recording-indicator');
                    const previewContainer = document.getElementById('audio-preview-container');
                    const previewAudio = document.getElementById('audio-preview');
                    
                    if (statusTxt) {
                        statusTxt.style.display = 'block';
                        statusTxt.innerText = 'Grabar nota de voz';
                    }
                    if (deleteAudioBtn) deleteAudioBtn.style.display = 'none';
                    if (indicator) indicator.style.display = 'none';
                    if (previewContainer) previewContainer.style.display = 'none';
                    if (previewAudio) previewAudio.src = '';
                    if (recordBtn) {
                        recordBtn.style.display = 'flex';
                        recordBtn.innerText = '🎙️';
                        recordBtn.style.background = 'var(--primary-color)';
                    }
                    document.getElementById('new-post-modal').style.display = 'flex';
                } catch (e) {
                    console.error("Auth check failed", e);
                }
            };

            window.submitNewPost = async function() {
                const content = document.getElementById('new-post-content').value;
                const fileInput = document.getElementById('new-post-image');
                const file = fileInput.files?.[0];
                const audioBlob = window.currentAudioBlob;
                const btn = document.getElementById('submit-post-btn');

                if (!content && !file && !audioBlob) {
                    alert("Añade un texto, una foto o un audio.");
                    return;
                }

                btn.innerText = "Localizando...";
                btn.disabled = true;

                try {
                    const getPosition = () => new Promise((resolve) => {
                        if (!navigator.geolocation) return resolve(null);
                        navigator.geolocation.getCurrentPosition(
                            pos => resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude }),
                            err => resolve(null),
                            { timeout: 5000, enableHighAccuracy: true }
                        );
                    });
                    
                    const coords = await getPosition();
                    
                    btn.innerText = "Subiendo...";

                    const formData = new FormData();
                    if (content) formData.append('content', content);
                    if (file) formData.append('image', file);
                    if (audioBlob) formData.append('audio', audioBlob, 'audio.webm');
                    if (coords) {
                        formData.append('lat', coords.lat);
                        formData.append('lon', coords.lon);
                    }

                    const res = await fetch('/api/posts/create', {
                        method: 'POST',
                        body: formData
                    });

                    if (res.ok) {
                        document.getElementById('new-post-modal').style.display = 'none';
                        window.loadFeed();
                        btn.innerText = "Publicar";
                        btn.disabled = false;
                        // Forzar a recargar el mapa
                        if (window.renderMapMarkers) window.renderMapMarkers();
                    } else {
                        const err = await res.json();
                        alert("Error al publicar: " + (err.error || "Desconocido"));
                    }
                } catch (e) {
                    console.error("Upload error", e);
                    alert("Error de red al publicar.");
                } finally {
                    btn.innerText = "Publicar";
                    btn.disabled = false;
                }
            };

            window.loadFeed = async function() {
                const container = document.getElementById('feed-container');
                try {
                    container.innerHTML = '<div style="text-align: center; color: var(--text-secondary); margin-top: 20px;">Cargando publicaciones...</div>';
                    const res = await fetch('/api/posts/list');
                    const data = await res.json();
                    
                    if (!data.posts || data.posts.length === 0) {
                        container.innerHTML = '<div style="text-align: center; color: var(--text-secondary); margin-top: 20px;">Aún no hay publicaciones. ¡Sé el primero!</div>';
                        return;
                    }

                    container.innerHTML = '';
                    data.posts.forEach(post => {
                        const date = new Date(post.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
                        
                        const div = document.createElement('div');
                        div.style.cssText = "background: var(--header-bg); border: 1px solid var(--header-border); border-radius: 16px; padding: 16px; display: flex; flex-direction: column; gap: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);";

                        const headerDiv = document.createElement('div');
                        headerDiv.style.cssText = "display: flex; align-items: center; gap: 12px;";

                        const img = document.createElement('img');
                        img.src = post.user_avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(post.user_name || '?');
                        img.style.cssText = "width: 36px; height: 36px; border-radius: 50%; object-fit: cover; cursor: pointer;";
                        img.alt = "Avatar";
                        img.onclick = () => window.openPublicProfile(post.user_id);

                        const nameContainer = document.createElement('div');
                        nameContainer.style.cursor = 'pointer';
                        nameContainer.onclick = () => window.openPublicProfile(post.user_id);
                        
                        const nameDiv = document.createElement('div');
                        nameDiv.style.cssText = "font-weight: 600; color: var(--text-primary); font-size: 15px;";
                        nameDiv.textContent = post.user_name || 'Usuario';
                        const dateDiv = document.createElement('div');
                        dateDiv.style.cssText = "font-size: 12px; color: var(--text-secondary);";
                        dateDiv.textContent = date;

                        nameContainer.appendChild(nameDiv);
                        nameContainer.appendChild(dateDiv);
                        headerDiv.appendChild(img);
                        headerDiv.appendChild(nameContainer);

                        // Add DM Button if not my own post
                        if (post.user_id && dataMe && dataMe.user && post.user_id !== dataMe.user.id) {
                            const dmBtn = document.createElement('button');
                            dmBtn.innerHTML = '✉️ Mensaje';
                            dmBtn.style.cssText = "margin-left: auto; background: var(--chat-bg); border: 1px solid var(--border-color); color: var(--primary-color); border-radius: 12px; padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer;";
                            dmBtn.onclick = () => window.openDMChat(post.user_id, post.user_name, post.user_avatar);
                            headerDiv.appendChild(dmBtn);
                        }

                        div.appendChild(headerDiv);

                        if (post.content) {
                            const contentDiv = document.createElement('div');
                            contentDiv.style.cssText = "color: var(--text-primary); font-size: 15px; line-height: 1.4; white-space: pre-wrap;";
                            contentDiv.textContent = post.content;
                            div.appendChild(contentDiv);
                        }

                        if (post.image_url) {
                            const postImg = document.createElement('img');
                            postImg.src = post.image_url;
                            postImg.style.cssText = "width: 100%; border-radius: 12px; max-height: 300px; object-fit: cover; margin-top: 4px;";
                            postImg.alt = "Post image";
                            postImg.loading = "lazy";
                            div.appendChild(postImg);
                        }

                        // Add interaction actions (Like, Comment, Save, Share)
                        const actionsDiv = document.createElement('div');
                        actionsDiv.style.cssText = "display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 12px; margin-top: 4px;";

                        const actionBtnStyle = "background: none; border: none; display: flex; align-items: center; gap: 6px; color: var(--text-secondary); cursor: pointer; font-size: 13px; font-weight: 500; padding: 4px 8px; border-radius: 8px; transition: background 0.2s;";
                        
                        const applyHover = function() { this.style.background = 'var(--chat-bg)'; };
                        const applyLeave = function() { this.style.background = 'none'; };

                        // Like
                        const likeBtn = document.createElement('button');
                        likeBtn.style.cssText = actionBtnStyle;
                        likeBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg> <span style="display:none;" class="cnt">0</span>`;
                        likeBtn.onmouseover = applyHover;
                        likeBtn.onmouseout = applyLeave;
                        likeBtn.onclick = function() {
                            const svg = this.querySelector('svg');
                            const cnt = this.querySelector('.cnt');
                            if (svg.getAttribute('fill') === 'none') {
                                svg.setAttribute('fill', 'var(--primary-color)');
                                svg.setAttribute('stroke', 'var(--primary-color)');
                                this.style.color = 'var(--primary-color)';
                                cnt.style.display = 'inline';
                                cnt.innerText = (parseInt(cnt.innerText) + 1).toString();
                            } else {
                                svg.setAttribute('fill', 'none');
                                svg.setAttribute('stroke', 'currentColor');
                                this.style.color = 'var(--text-secondary)';
                                cnt.innerText = (parseInt(cnt.innerText) - 1).toString();
                                if (cnt.innerText === '0') cnt.style.display = 'none';
                            }
                        };
                        
                        // Comment
                        const commentBtn = document.createElement('button');
                        commentBtn.style.cssText = actionBtnStyle;
                        commentBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`;
                        commentBtn.onmouseover = applyHover;
                        commentBtn.onmouseout = applyLeave;
                        commentBtn.onclick = () => alert("Comentarios (Próximamente)");

                        // Share
                        const shareBtn = document.createElement('button');
                        shareBtn.style.cssText = actionBtnStyle;
                        shareBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>`;
                        shareBtn.onmouseover = applyHover;
                        shareBtn.onmouseout = applyLeave;
                        shareBtn.onclick = async () => {
                            if (navigator.share) {
                                try { await navigator.share({ title: 'Gaditan', text: post.content || 'Mira esto en Gaditan', url: window.location.href }); } catch(err) {}
                            } else {
                                alert("Compartir (Próximamente)");
                            }
                        };

                        // Save
                        const saveBtn = document.createElement('button');
                        saveBtn.style.cssText = actionBtnStyle;
                        saveBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>`;
                        saveBtn.onmouseover = applyHover;
                        saveBtn.onmouseout = applyLeave;
                        saveBtn.onclick = function() {
                            const svg = this.querySelector('svg');
                            if (svg.getAttribute('fill') === 'none') {
                                svg.setAttribute('fill', 'var(--primary-color)');
                                svg.setAttribute('stroke', 'var(--primary-color)');
                                this.style.color = 'var(--primary-color)';
                            } else {
                                svg.setAttribute('fill', 'none');
                                svg.setAttribute('stroke', 'currentColor');
                                this.style.color = 'var(--text-secondary)';
                            }
                        };

                        const leftActions = document.createElement('div');
                        leftActions.style.display = 'flex';
                        leftActions.style.gap = '8px';
                        leftActions.appendChild(likeBtn);
                        leftActions.appendChild(commentBtn);
                        leftActions.appendChild(shareBtn);

                        actionsDiv.appendChild(leftActions);
                        actionsDiv.appendChild(saveBtn);
                        
                        div.appendChild(actionsDiv);

                        container.appendChild(div);
                    });
                } catch (e) {
                    container.innerHTML = '<div style="text-align: center; color: #ef4444; margin-top: 20px;">Error al cargar el perfil.</div>';
                }
            };
        </script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js"></script>
        
        <style>
            /* Permitir scroll nativo horizontal para el swiper */
            .leaflet-container {
                touch-action: pan-x pan-y !important;
            }
            /* Estilo para recortar foto en círculo (Cropper) */
            .cropper-view-box,
            .cropper-face {
                border-radius: 50%;
            }
            /* Ajuste extra de opacidad de lo que se va a cortar */
            .cropper-modal {
                opacity: 0.8;
                background-color: #000;
            }
        </style>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
	</head>
	<body>
        <div class="app-container" style="display: flex; flex-direction: column; height: 100dvh; max-width: 100%;">
            <!-- CABECERA ÚNICA Y ESTÁTICA -->
            <Header />

            <!-- TABS WRAPPER -->
            <div id="tabs-wrapper" style="flex: 1; width: 100%; min-height: 0; display: flex; flex-direction: column; position: relative;">
                
                <!-- TAB CHAT -->
                <div id="tab-chat" style="flex: 1; width: 100%; min-height: 0; display: flex; flex-direction: column; position: relative;">
                    <!-- CONTENEDOR DESLIZABLE (SWIPER) -->
                    <div class="swiper-container" id="main-swiper" style="flex: 1; width: 100%; min-height: 0;">
                <div class="swiper-wrapper">
                    
                    <!-- PANEL 0: GUARDADOS -->
                    <div class="swipe-panel" id="panel-guardados">
                        <main class="messages-area" id="saved-messages-container" style="padding: 20px; width: 100%; max-width: 480px; margin: 0 auto; height: 100%; overflow-y: auto; background: #0f172a; position: relative;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px;">
                                <button class="back-swipe-btn" style="color: #60a5fa;" onclick="window.switchPanel('chat')" aria-label="Volver">⬅ Volver al Chat</button>
                                <h2 style="margin:0; font-size:16px; color: #f8fafc; letter-spacing: 0.5px;">⭐ Guardados</h2>
                            </div>
                            <p style="color: #94a3b8; text-align:center; margin-top:40px; font-weight: 300;">No tienes mensajes guardados aún.</p>
                        </main>
                    </div>

                    <!-- PANEL 1: CHAT PRINCIPAL -->
                    <div class="swipe-panel" id="panel-chat">
                        <main class="messages-area" id="messages-container" style="width: 100%; max-width: 480px; margin: 0 auto; height: 100%; overflow-y: auto; background: var(--chat-bg); padding-bottom: 160px;">
                            <slot />
                        </main>
                    </div>

                    <!-- PANEL 2: PANTALLA COMPLETA (WIDGETS) -->
                    <MapWidget />

                </div>
            </div>
            
            <!-- ÁREA DE INPUT ESTÁTICA Y FLOTANTE -->
            <div class="input-area" id="main-input" style="width: 100%; max-width: 480px; margin: 0 auto; padding-bottom: 0.5rem;">
                <div class="chat-input-wrapper">
                    <textarea id="chat-input" class="chat-input" placeholder="Pregunta lo que necesites..." rows="1"></textarea>
                    <button id="send-btn" class="send-button" aria-label="Enviar mensaje">
                        <div id="lottie-send" style="width: 100%; height: 100%; transform: scale(1.65);"></div>
                    </button>
                </div>
            </div>
            </div> <!-- END TAB CHAT -->

            <!-- TAB MURO -->
            <MuroTab />

            <!-- TAB PERFIL (Antiguo Muro) -->
            <ProfileTab />
            
            <!-- BOTTOM NAVIGATION -->
            <!-- TAB COMUNIDAD -->
            <CommunityTab />

            <!-- TAB DMs (Mensajes Directos) -->
            <DMsTab />
        <!-- MODAL DE PERFIL PUBLICO -->
        <!-- MODAL DE PERFIL PUBLICO -->
        <div id="public-profile-modal" style="display: none; position: absolute; inset: 0; z-index: 50; background: var(--bg-color); flex-direction: column; overflow: hidden;">
            <div style="background: var(--bg-color); width: 100%; max-width: 480px; height: 100%; margin: 0 auto; display: flex; flex-direction: column; position: relative; overflow: hidden;">
                
                <!-- Botón de Cerrar (Flotante) -->
                <button onclick="document.getElementById('public-profile-modal').style.display='none'" style="position: absolute; top: 16px; left: 16px; width: 36px; height: 36px; background: rgba(0,0,0,0.5); border-radius: 50%; border: none; color: white; font-size: 20px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 20; backdrop-filter: blur(4px);">←</button>

                <div style="width: 100%; height: 100%; overflow-y: auto; display: flex; flex-direction: column;">
                    <!-- Banner / Portada (Degradado por defecto) -->
