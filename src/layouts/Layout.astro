    <title>Taxi Cádiz | Teléfonos, Reservas y Precios</title>
    <meta name="description" content="Guía turística y directorio independiente de Taxis en Cádiz. Encuentra teléfonos, tarifas estimadas a aeropuertos y paradas principales.">
    
    <!-- Open Graph -->
    <meta property="og:title" content="Taxi Cádiz | Guía Local y Traslados">
    <meta property="og:description" content="Directorio rápido para pedir tu taxi en Cádiz. Teléfonos directos, precios a aeropuertos y puerto de cruceros.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cadiz.taxi/">
    
    <!-- Lucide Icons -->
    <script>
      import { createIcons, icons } from 'lucide';
      const patchedCreateIcons = (args) => createIcons(args || { icons });
      window.lucide = { createIcons: patchedCreateIcons, icons };
      patchedCreateIcons();
    </script>
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <!-- Schema.org Data for SEO -->
