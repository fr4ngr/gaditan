<script>
document.addEventListener('DOMContentLoaded', function() {
    
    // Función para cerrar una tarjeta
    function closeCard(card) {
        var content = card.querySelector('.dest-actions-content');
        var toggle  = card.querySelector('.dest-action-toggle');
        
        card.classList.remove('expanded');
        if (toggle) toggle.classList.remove('open');
        if (content) {
            content.classList.remove('open');
            // CSS Grid se encarga del resto
        }
    }

    // Lógica para acordeones nativos (<details>)
    document.addEventListener('click', function(e) {
        // Cerrar si se clica fuera de cualquier tarjeta
        if (!e.target.closest('.mini-dest-card')) {
            document.querySelectorAll('details.native-accordion[open]').forEach(function(card) {
                card.removeAttribute('open');
            });
            // (Mantenemos por compatibilidad con antiguas si quedan)
            document.querySelectorAll('.mini-dest-card.expanded').forEach(function(card) {
                closeCard(card);
            });
        }
    });

    // Cuando se abre un acordeón nativo, cerrar los demás
    document.querySelectorAll('details.native-accordion').forEach(function(details) {
        details.addEventListener('toggle', function(e) {
            if (details.open) {
                document.querySelectorAll('details.native-accordion[open]').forEach(function(other) {
                    if (other !== details) other.removeAttribute('open');
                });
                if (window.lucide) window.lucide.createIcons({ icons: window.lucide.icons });
            }
        });
    });

    // Lógica principal de cada tarjeta antigua (no nativa)
    document.querySelectorAll('div.mini-dest-card').forEach(function(card) {
        card.addEventListener('click', function(e) {
            if (e.target.closest('a') || e.target.closest('.dest-actions-content')) return;
            var content = card.querySelector('.dest-actions-content');
            var toggle  = card.querySelector('.dest-action-toggle');
            var isOpen = content && content.classList.contains('open');

            if (isOpen) {
                closeCard(card);
            } else {
                document.querySelectorAll('div.mini-dest-card.expanded').forEach(function(otherCard) {
                    if (otherCard !== card) closeCard(otherCard);
                });
                card.classList.add('expanded');
                if (toggle) toggle.classList.add('open');
                if (content) content.classList.add('open');
            }
            if (window.lucide) window.lucide.createIcons({ icons: window.lucide.icons });
        });
    });
});
</script>
<!-- Glow Up Observer -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('glow-active');
              } else {
                  entry.target.classList.remove('glow-active');
              }
          });
      }, {
          root: null,
          rootMargin: '-64% 0px -34% 0px',
          threshold: 0
      });

      // Observar las estáticas iniciales
      document.querySelectorAll('.cadizcab-card-hover, .pildora-hover').forEach(card => {
          observer.observe(card);
      });

      // Observar las creadas dinámicamente en el mapa
      const mutationObserver = new MutationObserver((mutations) => {
          mutations.forEach(mutation => {
              mutation.addedNodes.forEach(node => {
                  if (node.nodeType === 1) { 
                      if (node.classList && (node.classList.contains('cadizcab-card-hover') || node.classList.contains('pildora-hover'))) {
                          observer.observe(node);
                      }
                      const childCards = node.querySelectorAll ? node.querySelectorAll('.cadizcab-card-hover, .pildora-hover') : [];
                      childCards.forEach(card => observer.observe(card));
                  }
              });
          });
      });
      mutationObserver.observe(document.body, { childList: true, subtree: true });
  });
</script>
