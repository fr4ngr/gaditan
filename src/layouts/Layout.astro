---
import '../styles/styles.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Taxi Cádiz | Teléfonos, Reservas y Precios</title>
    <meta name="description" content="Guía turística y directorio independiente de Taxis en Cádiz. Encuentra teléfonos, tarifas estimadas a aeropuertos y paradas principales.">
    
    <!-- Open Graph -->
    <meta property="og:title" content="Taxi Cádiz | Guía Local y Traslados">
    <meta property="og:description" content="Directorio rápido e independiente para pedir un taxi en Cádiz. Teléfonos, tarifas estimadas a aeropuertos, VTCs y transporte público.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cadiz.taxi/">
    
    <!-- Lucide Icons -->
    <script>
      import { createIcons, icons } from 'lucide';
      const patchedCreateIcons = (args) => createIcons(args || { icons });
      window.lucide = { createIcons: patchedCreateIcons, icons };
      patchedCreateIcons();
    </script>
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <!-- Schema.org Data for SEO (CollectionPage/Directory) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Cádiz Taxi - Guía Independiente de Movilidad",
      "description": "Directorio informativo sobre taxis oficiales, VTCs y transporte público en Cádiz. Encuentra teléfonos, paradas y tarifas estimadas.",
      "url": "https://cadiz.taxi/",
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Radiotaxi Cádiz"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "cadiz.cab (VTC)"
          }
        ]
      }
    }

    </script>
    
    <!-- Tipografía Premium: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
</head>
<body>
    <slot />
    <!-- Script genérico (carga diferida de módulos específicos) -->
    <script src="js/mapData.js?v=20260606d" defer></script>
    <script src="js/components.js?v=20260610k" defer></script>
    <script src="js/mapManager.js?v=20260610c" defer></script>
    <script type="module" src="js/main.js?v=20260609d"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    
    // Función para cerrar una tarjeta
    function closeCard(card) {
        var content = card.querySelector('.dest-actions-content');
        var toggle  = card.querySelector('.dest-action-toggle');
        
        card.classList.remove('expanded');
        if (toggle) toggle.classList.remove('open');
        if (content) {
            content.classList.remove('open');
            // CSS Grid se encarga del resto
        }
    }

    // Lógica para acordeones nativos (<details>)
    document.addEventListener('click', function(e) {
        // Cerrar si se clica fuera de cualquier tarjeta
        if (!e.target.closest('.mini-dest-card')) {
            document.querySelectorAll('details.native-accordion[open]').forEach(function(card) {
                card.removeAttribute('open');
            });
            // (Mantenemos por compatibilidad con antiguas si quedan)
            document.querySelectorAll('.mini-dest-card.expanded').forEach(function(card) {
                closeCard(card);
            });
        }
    });

    // Cuando se abre un acordeón nativo, cerrar los demás
    document.querySelectorAll('details.native-accordion').forEach(function(details) {
        details.addEventListener('toggle', function(e) {
            if (details.open) {
                document.querySelectorAll('details.native-accordion[open]').forEach(function(other) {
                    if (other !== details) other.removeAttribute('open');
                });
                if (window.lucide) window.lucide.createIcons({ icons: window.lucide.icons });
            }
        });
    });

    // Lógica principal de cada tarjeta antigua (no nativa)
    document.querySelectorAll('div.mini-dest-card').forEach(function(card) {
        card.addEventListener('click', function(e) {
            if (e.target.closest('a') || e.target.closest('.dest-actions-content')) return;
            var content = card.querySelector('.dest-actions-content');
            var toggle  = card.querySelector('.dest-action-toggle');
            var isOpen = content && content.classList.contains('open');

            if (isOpen) {
                closeCard(card);
            } else {
                document.querySelectorAll('div.mini-dest-card.expanded').forEach(function(otherCard) {
                    if (otherCard !== card) closeCard(otherCard);
                });
                card.classList.add('expanded');
                if (toggle) toggle.classList.add('open');
                if (content) content.classList.add('open');
            }
            if (window.lucide) window.lucide.createIcons({ icons: window.lucide.icons });
        });
    });
});
</script>
<!-- Glow Up Observer -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
      // Observer para cadizcab (Aparezco y listo)
      const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('glow-active');
                  observer.unobserve(entry.target);
              }
          });
      }, {
          root: null,
          rootMargin: '0px 0px 0px 0px',
          threshold: 0.1
      });

      // Observer para píldoras de paradas (Efecto foco al pasar por el centro)
      const focusObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('glow-active');
              } else {
                  entry.target.classList.remove('glow-active');
              }
          });
      }, {
          root: null,
          rootMargin: '-48% 0px -48% 0px',
          threshold: 0
      });

      // Observar las estáticas iniciales
      document.querySelectorAll('.cadizcab-card-hover').forEach(card => observer.observe(card));
      document.querySelectorAll('.pildora-hover').forEach(card => focusObserver.observe(card));

      // Observar las creadas dinámicamente en el mapa
      const mutationObserver = new MutationObserver((mutations) => {
          mutations.forEach(mutation => {
              mutation.addedNodes.forEach(node => {
                  if (node.nodeType === 1) { 
                      if (node.classList) {
                          if (node.classList.contains('cadizcab-card-hover')) {
                              setTimeout(() => observer.observe(node), 800);
                          } else if (node.classList.contains('pildora-hover')) {
                              setTimeout(() => focusObserver.observe(node), 800);
                          }
                      }
                      const childCadiz = node.querySelectorAll ? node.querySelectorAll('.cadizcab-card-hover') : [];
                      childCadiz.forEach(child => setTimeout(() => observer.observe(child), 800));
                      
                      const childPildoras = node.querySelectorAll ? node.querySelectorAll('.pildora-hover') : [];
                      childPildoras.forEach(child => setTimeout(() => focusObserver.observe(child), 800));
                  }
              });
          });
      });
      mutationObserver.observe(document.body, { childList: true, subtree: true });

      // Rotación de texto en sticky bar
      const phrases = [
          "VTC: Viaja con precio cerrado",
          "¿Sin taxis? Pide un VTC ahora",
          "Mejor en vehiculos VTC premium"
      ];
      let currentPhrase = 0;
      const textEl = document.getElementById('sponsor-rotating-text');
      if(textEl) {
          setInterval(() => {
              textEl.style.opacity = '0';
              setTimeout(() => {
                  currentPhrase = (currentPhrase + 1) % phrases.length;
                  textEl.textContent = phrases[currentPhrase];
                  textEl.style.opacity = '1';
              }, 400);
          }, 4000);
      }
  });
</script>
    <!-- Mobile Sticky Bottom Bar -->
    <div class="mobile-sticky-bar" id="mobileStickyBar">
        <a href="https://cadiz.cab" target="_blank" class="sticky-sponsor-bar">
            <div class="sponsor-text-col" style="flex-direction: row; align-items: center; gap: 0.4rem;">
                <i data-lucide="info" style="color: #facc15; width: 20px; height: 20px; flex-shrink: 0;"></i>
                <span class="sponsor-main" id="sponsor-rotating-text" style="transition: opacity 0.4s ease-in-out;">VTC: Viaja con precio cerrado</span>
            </div>
            <div class="sponsor-btn" data-translate="sponsor-sticky-btn">cadiz.cab</div>
        </a>
    </div>
</body>
</html>
