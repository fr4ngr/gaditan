---
// src/components/Ventajas.astro
---
<section class="ventajas-section" style="padding: 1.5rem 0; overflow-x: auto; background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 2rem;">
    <div class="container">
        <div class="trust-badges" style="display: flex; gap: 1rem; margin-top: 0; padding-bottom: 0.5rem; justify-content: flex-start; white-space: nowrap;">
            <button type="button" class="glass-badge" onclick="alert('Todos los taxis cuentan con licencia municipal oficial del Ayuntamiento de Cádiz, garantizando tu seguridad y tarifas reguladas.')"><i data-lucide="shield-check" size="16"></i> <span data-translate="badge-official">Autorizados</span> <i data-lucide="info" size="16"></i></button>
            <span class="glass-badge"><i data-lucide="clock" size="16"></i> <span data-translate="badge-24h">24 Horas</span></span>
            <span class="glass-badge"><i data-lucide="credit-card" size="16"></i> <span data-translate="badge-card">Tarjeta</span></span>
            <span class="glass-badge"><i data-lucide="receipt" size="16"></i> <span data-translate="badge-receipt">Factura</span></span>
            <span class="glass-badge"><i data-lucide="accessibility" size="16"></i> <span data-translate="badge-adapted">Adaptados</span></span>
            <button type="button" class="glass-badge" onclick="alert('La inmensa mayoría de taxistas aceptan Bizum, consulta antes de subirte.')"><svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-right:-2px;"><line x1="5" y1="19" x2="19" y2="5" /><line x1="5" y1="11" x2="11" y2="5" /><line x1="13" y1="19" x2="19" y2="13" /><circle cx="4" cy="4" r="1" fill="currentColor" stroke="none" /><circle cx="20" cy="20" r="1" fill="currentColor" stroke="none" /></svg> <span>Bizum</span> <i data-lucide="info" size="16"></i></button>
        </div>
    </div>
</section>
