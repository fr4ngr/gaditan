---
// src/components/Ventajas.astro
---
<section class="ventajas-section" style="padding: 1.5rem 0; overflow: hidden; background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 2rem;">
    <div class="ticker-wrapper" style="width: 100%; display: flex; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none;">
        <!-- Ticker content -->
        <div class="trust-features" style="display: flex; gap: 2rem; padding: 0 1.5rem; white-space: nowrap; align-items: center;">
            <div class="feature-item" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">
                <i data-lucide="shield-check" style="color: var(--brand-cyan);" size="18"></i> <span>Taxis Autorizados</span>
            </div>
            <div class="feature-item" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">
                <i data-lucide="clock" style="color: var(--brand-cyan);" size="18"></i> <span>Servicio 24 Horas</span>
            </div>
            <div class="feature-item" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">
                <i data-lucide="credit-card" style="color: var(--brand-cyan);" size="18"></i> <span>Pago con Tarjeta / Bizum</span>
            </div>
            <div class="feature-item" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">
                <i data-lucide="baby" style="color: var(--brand-cyan);" size="18"></i> <span>Carritos Infantiles Gratis</span>
            </div>
            <div class="feature-item" style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.95rem; font-weight: 500;">
                <i data-lucide="accessibility" style="color: var(--brand-cyan);" size="18"></i> <span>Vehículos Adaptados</span>
            </div>
        </div>
    </div>
    <style>
        .ticker-wrapper::-webkit-scrollbar { display: none; }
        .feature-item span { color: white; }
    </style>
</section>
