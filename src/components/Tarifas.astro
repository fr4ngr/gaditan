        <script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
        <script>
            const initFareToggles = () => {
                const wrappers = document.querySelectorAll('.theme-toggle-wrapper');
                wrappers.forEach(wrapper => {
                    const pills = wrapper.querySelectorAll('.tarifa-pill');
                    pills.forEach(pill => {
                        pill.addEventListener('click', (e) => {
                            // Update active state of pills
                            pills.forEach(p => p.classList.remove('active'));
                            pill.classList.add('active');

                            const target = pill.getAttribute('data-target'); // 'day' or 'night'
                            const pillTitle = pill.getAttribute('data-title');
                            const pillSubtitle = pill.getAttribute('data-subtitle');
                            
                            const grid = wrapper.nextElementSibling;
                            
                            // Si hay saltos de linea, avanzamos hasta el div real
                            let actualGrid = grid;
                            while(actualGrid && actualGrid.nodeType !== 1) {
                                actualGrid = actualGrid.nextSibling;
                            }
                            if (!actualGrid || !actualGrid.classList.contains('tarifas-grid')) return;
                            
                            const card = actualGrid.querySelector('.dynamic-fare-card');
                            if (!card) return;
                            
                            const lottieContainer = card.querySelector('.lottie-container');
                            if (lottieContainer) {
                                // El contenedor permanece transparente con sombra estática para usar el fondo del Lottie

                                // Controlar la animación del Lottie único
                                const lottiePlayer = lottieContainer.querySelector('.lottie-default');
                                if (lottiePlayer) {
                                    const playLottie = (player) => {
                                        try {
                                            const anim = player.getLottie();
                                            if (!anim) return false;

                                            anim.setLoop(false);
                                            anim.setDirection(1);

                                            if (pillTitle === 'Día') {
                                                anim.setDirection(-1);
                                                anim.play();
                                            } else if (pillTitle === 'Noche') {
                                                const current = anim.currentFrame;
                                                anim.playSegments([current, 50], true);
                                            } else if (pillTitle === 'Fin de semana' || pillTitle === 'Festivos') {
                                                anim.setLoop(true);
                                                anim.playSegments([0, 100], true);
                                            }
                                            return true;
                                        } catch (e) {
                                            console.error('Error playing lottie:', e);
                                            return false;
                                        }
                                    };

                                    if (!playLottie(lottiePlayer)) {
                                        lottiePlayer.addEventListener('ready', () => {
                                            playLottie(lottiePlayer);
                                        });
                                    }
                                }
                            }

                            // Animar textos
                            const dynElements = card.querySelectorAll('.dyn-title, .dyn-subtitle, .dyn-price');
                            const infoBtn = card.querySelector('.festivos-info-btn');
                            dynElements.forEach(el => {
                                if (el.classList.contains('dyn-price')) {
                                    const targetValueStr = el.getAttribute('data-' + target);
                                    if (!targetValueStr) return;
                                    const targetValue = parseFloat(targetValueStr.replace(',', '.'));
                                    const startValue = parseFloat(el.innerHTML.replace(',', '.'));
                                    if (isNaN(targetValue) || isNaN(startValue)) {
                                        el.innerHTML = targetValueStr;
                                        return;
                                    }
                                    const duration = 300;
                                    const start = performance.now();
                                    const step = (timestamp) => {
                                        const progress = Math.min((timestamp - start) / duration, 1);
                                        const easeProgress = progress * (2 - progress); // easeOutQuad
                                        const current = startValue + (targetValue - startValue) * easeProgress;
                                        el.innerHTML = current.toFixed(2).replace('.', ',');
                                        if (progress < 1) {
                                            requestAnimationFrame(step);
                                        } else {
                                            el.innerHTML = targetValueStr;
                                        }
                                    };
                                    requestAnimationFrame(step);
                                } else {
                                    el.style.opacity = '0';
                                    setTimeout(() => {
                                        if (el.classList.contains('dyn-title') && pillTitle !== null) {
                                            el.innerHTML = pillTitle;
                                        } else if (el.classList.contains('dyn-subtitle') && pillSubtitle !== null) {
                                            el.innerHTML = pillSubtitle;
                                            el.style.display = pillSubtitle ? 'block' : 'none';
                                        } else if (!el.classList.contains('dyn-price')) {
                                            el.innerHTML = el.getAttribute('data-' + target);
                                        }
                                        el.style.opacity = '1';
                                    }, 150);
                                }
                            });
                            
                            if (infoBtn) {
                                infoBtn.style.opacity = '0';
                                setTimeout(() => {
                                    infoBtn.style.display = (pillTitle === 'Festivos') ? 'flex' : 'none';
                                    infoBtn.style.opacity = '1';
                                }, 150);
                            }
                        });
                    });
                });
            };

            const initScopeToggles = () => {
                const scopePills = document.querySelectorAll('.scope-pill');
                const urbanSec = document.getElementById('urban-section');
                const interurbanSec = document.getElementById('interurban-section');

                scopePills.forEach(pill => {
                    pill.addEventListener('click', () => {
                        scopePills.forEach(p => p.classList.remove('active'));
                        pill.classList.add('active');

                        const scope = pill.getAttribute('data-scope');
                        if (scope === 'urban') {
                            if (urbanSec && interurbanSec) {
                                interurbanSec.classList.remove('active-section');
                                setTimeout(() => {
                                    interurbanSec.style.display = 'none';
                                    urbanSec.style.display = 'block';
                                    setTimeout(() => urbanSec.classList.add('active-section'), 20);
                                }, 300);
                            }
                        } else if (scope === 'interurban') {
                            if (urbanSec && interurbanSec) {
                                urbanSec.classList.remove('active-section');
                                setTimeout(() => {
                                    urbanSec.style.display = 'none';
                                    interurbanSec.style.display = 'block';
                                    setTimeout(() => interurbanSec.classList.add('active-section'), 20);
                                }, 300);
                            }
                        }
                    });
                });
            };

