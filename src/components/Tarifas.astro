              /* From Uiverse.io by JustCode14 */ 
/* Theme Switch */
/* The switch - the box around the slider */
.switch {
  font-size: 17px;
  position: relative;
  display: inline-block;
  width: 4em;
  height: 2.2em;
  border-radius: 30px;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
}

/* Hide default HTML checkbox */
.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

/* The slider */
.slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #2a2a2a;
  transition: 0.4s;
  border-radius: 30px;
  overflow: hidden;
}

.slider:before {
  position: absolute;
  content: "";
  height: 1.2em;
  width: 1.2em;
  border-radius: 20px;
  left: 0.5em;
  bottom: 0.5em;
  transition: 0.4s;
  transition-timing-function: cubic-bezier(0.81, -0.04, 0.38, 1.5);
  box-shadow: inset 8px -4px 0px 0px #fff;
}

.switch input:checked + .slider {
  background-color: var(--brand-cyan);
}

.switch input:checked + .slider:before {
  transform: translateX(1.8em);
  box-shadow: inset 15px -4px 0px 15px #ffcf48;
}

.star {
  background-color: #fff;
  border-radius: 50%;
  position: absolute;
  width: 5px;
  transition: all 0.4s;
  height: 5px;
}

.star_1 {
  left: 2.5em;
  top: 0.5em;
}

.star_2 {
  left: 2.2em;
  top: 1.2em;
}

.star_3 {
  left: 3em;
  top: 0.9em;
}

.switch input:checked ~ .slider .star {
  opacity: 0;
}

.cloud {
  width: 3.5em;
  position: absolute;
  bottom: -1.4em;
  left: -1.1em;
  opacity: 0;
  transition: all 0.4s;
}

.switch input:checked ~ .slider .cloud {
  opacity: 1;
}
              @keyframes fadeInCard {
                from { opacity: 0; transform: translateY(5px); }
                to { opacity: 1; transform: translateY(0); }
              }
</style>

        <script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
        <script>
            const initFareToggles = () => {
                const toggles = document.querySelectorAll('.uiverse-toggle');
                toggles.forEach(toggle => {
                    toggle.addEventListener('change', (e) => {
                        const isDay = toggle.checked;
                        const target = isDay ? 'day' : 'night';
                        
                        const wrapper = toggle.closest('.theme-toggle-wrapper');
                        const grid = wrapper ? wrapper.nextElementSibling : null;
                        
                        // Si hay saltos de linea, avanzamos hasta el div real
                        let actualGrid = grid;
                        while(actualGrid && actualGrid.nodeType !== 1) {
                            actualGrid = actualGrid.nextSibling;
                        }
                        if (!actualGrid || !actualGrid.classList.contains('tarifas-grid')) return;
                        
                        const labelDay = wrapper.querySelector('.label-day');
                        const labelNight = wrapper.querySelector('.label-night');
                        if (isDay) {
                            if (labelDay) labelDay.style.display = 'inline';
                            if (labelNight) labelNight.style.display = 'none';
                        } else {
                            if (labelDay) labelDay.style.display = 'none';
                            if (labelNight) labelNight.style.display = 'inline';
                        }
                        
                        const card = actualGrid.querySelector('.dynamic-fare-card');
                        if (!card) return;
                        
                        const lottiePlayer = card.querySelector('lottie-player');
                        if (lottiePlayer) {
                            if (target === 'night') {
                                lottiePlayer.setDirection(1);
                                lottiePlayer.play();
                            } else {
                                lottiePlayer.setDirection(-1);
                                lottiePlayer.play();
                            }
                        }

                        // Animar textos
                        const dynElements = card.querySelectorAll('.dyn-title, .dyn-subtitle, .dyn-price');
                        dynElements.forEach(el => {
                            el.style.opacity = '0';
                            setTimeout(() => {
                                el.textContent = el.getAttribute('data-' + target);
                                el.style.opacity = '1';
                            }, 150);
                        });
                    });
                });
            };

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initFareToggles);
            } else {
                initFareToggles();
            }
        </script>