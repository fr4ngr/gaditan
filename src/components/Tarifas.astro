        <script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
        <script>
            const initFareToggles = () => {
                const wrappers = document.querySelectorAll('.theme-toggle-wrapper');
                wrappers.forEach(wrapper => {
                    const pills = wrapper.querySelectorAll('.tarifa-pill');
                    pills.forEach(pill => {
                        pill.addEventListener('click', (e) => {
                            // Update active state of pills
                            pills.forEach(p => p.classList.remove('active'));
                            pill.classList.add('active');

                            const target = pill.getAttribute('data-target'); // 'day' or 'night'
                            const pillTitle = pill.getAttribute('data-title');
                            const pillSubtitle = pill.getAttribute('data-subtitle');
                            
                            const grid = wrapper.nextElementSibling;
                            
                            // Si hay saltos de linea, avanzamos hasta el div real
                            let actualGrid = grid;
                            while(actualGrid && actualGrid.nodeType !== 1) {
                                actualGrid = actualGrid.nextSibling;
                            }
                            if (!actualGrid || !actualGrid.classList.contains('tarifas-grid')) return;
                            
                            const card = actualGrid.querySelector('.dynamic-fare-card');
                            if (!card) return;
                            
                            const lottieContainer = card.querySelector('.lottie-container');
                            if (lottieContainer) {
                                // El contenedor permanece transparente con sombra estática para usar el fondo del Lottie

                                // Controlar la animación del Lottie único
                                const lottiePlayer = lottieContainer.querySelector('.lottie-default');
                                if (lottiePlayer) {
                                    const playLottie = (player) => {
                                        try {
                                            const anim = player.getLottie();
                                            if (!anim) return false;

                                            anim.setLoop(false);
                                            anim.setDirection(1);

                                            if (pillTitle === 'Día') {
                                                anim.setDirection(-1);
                                                anim.play();
                                            } else if (pillTitle === 'Noche') {
                                                const current = anim.currentFrame;
                                                anim.playSegments([current, 50], true);
                                            } else if (pillTitle === 'Fin de semana' || pillTitle === 'Festivos') {
                                                anim.setLoop(true);
                                                anim.playSegments([0, 100], true);
                                            }
                                            return true;
                                        } catch (e) {
                                            console.error('Error playing lottie:', e);
                                            return false;
                                        }
                                    };

                                    if (!playLottie(lottiePlayer)) {
                                        lottiePlayer.addEventListener('ready', () => {
                                            playLottie(lottiePlayer);
                                        });
                                    }
                                }
                            }

                            // Animar textos
                            const dynElements = card.querySelectorAll('.dyn-title, .dyn-subtitle, .dyn-price');
                            const infoBtn = card.querySelector('.festivos-info-btn');
                            dynElements.forEach(el => {
                                el.style.opacity = '0';
                                setTimeout(() => {
                                    if (el.classList.contains('dyn-title') && pillTitle !== null) {
                                        el.innerHTML = pillTitle;
                                    } else if (el.classList.contains('dyn-subtitle') && pillSubtitle !== null) {
                                        el.innerHTML = pillSubtitle;
                                        el.style.display = pillSubtitle ? 'block' : 'none';
                                    } else {
                                        el.innerHTML = el.getAttribute('data-' + target);
                                    }
                                    el.style.opacity = '1';
                                }, 150);
                            });
                            
                            if (infoBtn) {
                                infoBtn.style.opacity = '0';
                                setTimeout(() => {
                                    infoBtn.style.display = (pillTitle === 'Festivos') ? 'flex' : 'none';
                                    infoBtn.style.opacity = '1';
                                }, 150);
                            }
                        });
                    });
                });
            };

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initFareToggles);
            } else {
                initFareToggles();
            }
            
            // Modal Festivos Logic
            const festivosCadiz = [
                { date: '2026-01-01', name: 'Año Nuevo' },
                { date: '2026-01-06', name: 'Reyes Magos' },
                { date: '2026-02-16', name: 'Lunes de Coros (Carnaval)' },
                { date: '2026-02-28', name: 'Día de Andalucía' },
                { date: '2026-04-02', name: 'Jueves Santo' },
                { date: '2026-04-03', name: 'Viernes Santo' },
                { date: '2026-05-01', name: 'Fiesta del Trabajo' },
                { date: '2026-08-15', name: 'Asunción de la Virgen' },
                { date: '2026-10-07', name: 'Virgen del Rosario' },
                { date: '2026-10-12', name: 'Fiesta Nacional' },
                { date: '2026-11-02', name: 'Todos los Santos' },
                { date: '2026-12-07', name: 'Día de la Constitución' },
                { date: '2026-12-08', name: 'Inmaculada Concepción' },
                { date: '2026-12-25', name: 'Navidad' },
                { date: '2027-01-01', name: 'Año Nuevo' },
                { date: '2027-01-06', name: 'Reyes Magos' },
                { date: '2027-02-08', name: 'Lunes Carnaval' },
                { date: '2027-03-01', name: 'Día de Andalucía' },
                { date: '2027-03-25', name: 'Jueves Santo' },
                { date: '2027-03-26', name: 'Viernes Santo' },
                { date: '2027-05-01', name: 'Fiesta del Trabajo' },
                { date: '2027-08-16', name: 'Asunción de la Virgen' },
                { date: '2027-10-07', name: 'Virgen del Rosario' },
                { date: '2027-10-12', name: 'Fiesta Nacional' },
                { date: '2027-11-01', name: 'Todos los Santos' },
                { date: '2027-12-06', name: 'Día de la Constitución' },
                { date: '2027-12-08', name: 'Inmaculada Concepción' },
                { date: '2027-12-25', name: 'Navidad' }
            ];

            window.openFestivosModal = function() {
                const modal = document.getElementById('festivos-modal');
                const list = document.getElementById('festivos-list');
                list.innerHTML = '';
                
                const todayStr = new Date().toISOString().split('T')[0];
                const upcoming = festivosCadiz.filter(f => f.date >= todayStr);
                
                if (upcoming.length === 0) {
                    list.innerHTML = '<li style="color: rgba(15, 23, 42, 0.6); font-size: 0.95rem; text-align: center; padding: 1rem 0;">No hay más festivos este año.</li>';
                } else {
                    upcoming.forEach(f => {
                        const parts = f.date.split('-');
                        const formattedDate = `${parts[2]}/${parts[1]}/${parts[0]}`;
                        list.innerHTML += `
                            <li style="display: flex; align-items: center; gap: 1rem; border-bottom: 1px solid rgba(15, 23, 42, 0.08); padding-bottom: 1rem; margin-bottom: 1rem;">
                                <span style="color: var(--brand-cyan); font-weight: 800; font-size: 0.9rem; background: rgba(6, 182, 212, 0.15); padding: 0.4rem 0.8rem; border-radius: 99px; flex-shrink: 0;">${formattedDate}</span>
                                <span title="${f.name}" style="font-weight: 500; color: #0f172a; font-size: 1.05rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0;">${f.name}</span>
                            </li>
                        `;
                    });
                }
                
                modal.style.display = 'flex';
                void modal.offsetWidth; // force reflow
                modal.style.opacity = '1';
                modal.querySelector('.card').style.transform = 'scale(1)';
                document.body.style.overflow = 'hidden';
            };

            window.closeFestivosModal = function() {
                const modal = document.getElementById('festivos-modal');
                modal.style.opacity = '0';
                modal.querySelector('.card').style.transform = 'scale(0.95)';
                setTimeout(() => {
                    modal.style.display = 'none';
                    document.body.style.overflow = '';
                }, 300);
            };

            // Modal Suplementos Info Logic
            window.openSupplementInfoModal = function(title, text) {
                const modal = document.getElementById('supplement-info-modal');
                document.getElementById('supp-modal-title').innerText = title;
                document.getElementById('supp-modal-text').innerHTML = text;
                
                modal.style.display = 'flex';
                void modal.offsetWidth; // force reflow
                modal.style.opacity = '1';
                modal.querySelector('.card').style.transform = 'scale(1)';
                document.body.style.overflow = 'hidden';
            };

            window.closeSupplementInfoModal = function() {
                const modal = document.getElementById('supplement-info-modal');
                modal.style.opacity = '0';
                modal.querySelector('.card').style.transform = 'scale(0.95)';
                setTimeout(() => {
                    modal.style.display = 'none';
                    document.body.style.overflow = '';
                }, 300);
            };
            
            document.addEventListener('DOMContentLoaded', () => {
                const modal = document.getElementById('festivos-modal');
                if (modal) {
                    modal.addEventListener('click', (e) => {
                        if (e.target === modal) {
                            closeFestivosModal();
                        }
                    });
                }

                const suppModal = document.getElementById('supplement-info-modal');
                if (suppModal) {
                    suppModal.addEventListener('click', (e) => {
                        if (e.target === suppModal) {
                            closeSupplementInfoModal();
                        }
                    });
                }

                // Toggle Supplements Logic
                const toggleBtn = document.getElementById('toggle-supplements-btn');
                const extraItems = document.querySelectorAll('.supplement-item-extra');
                const suppText = document.getElementById('toggle-supp-text');
                const suppArrow = document.getElementById('toggle-supp-arrow');

                if (toggleBtn) {
                    toggleBtn.addEventListener('click', () => {
                        const isCollapsed = extraItems[0].style.display === 'none' || extraItems[0].style.display === '';
                        extraItems.forEach(item => {
                            item.style.display = isCollapsed ? 'flex' : 'none';
                        });
                        suppText.textContent = isCollapsed ? 'Ver menos' : 'Ver todos los suplementos';
                        suppArrow.style.transform = isCollapsed ? 'rotate(180deg)' : 'rotate(0deg)';
                    });
                }
            });
        </script>

