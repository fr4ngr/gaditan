---
---
        <!-- Precios -->
        <section class="pricing-section" id="tarifas" style="position: relative; overflow: hidden;">
            <!-- Ambient Glow -->
            <div class="ambient-glow" style="top: -10%; left: -10%; background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 70%);"></div>
            <div class="ambient-glow" style="bottom: -10%; right: -10%; background: radial-gradient(circle, rgba(0, 204, 102, 0.1) 0%, transparent 70%); animation-delay: -7s;"></div>
            
            <div class="container" style="position: relative; z-index: 1;">
                <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                    <span data-translate="pricing-title">Tarifas Oficiales</span>
                    <i data-lucide="badge-check" style="color: var(--brand-blue); fill: var(--brand-blue); stroke: #0f172a;" size="36"></i>
                </h2>
                <p class="section-subtitle" style="text-align: center; color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.1rem;">Precios regulados y garantizados por el Ayuntamiento de Cádiz</p>
                <div style="text-align: center; margin-bottom: 2.5rem;">
                    <div class="scope-toggle-wrapper">
                        <button class="scope-pill active" data-scope="urban">Viaje Urbano</button>
                        <button class="scope-pill" data-scope="interurban">Viaje Interurbano</button>
                    </div>
                </div>

                <div id="urban-section" class="scope-section active-section" style="display: block;">
                    <div class="theme-toggle-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem; max-width: 580px; margin-left: auto; margin-right: auto; width: 100%; flex-wrap: wrap;">
                                    <button class="tarifa-pill active" data-target="day" data-lottie="/moon-lottie.json" data-title="Día" data-subtitle="Lunes a Viernes (7h - 21h)">Día</button>
                                    <button class="tarifa-pill" data-target="night" data-lottie="/moon-lottie.json" data-title="Noche" data-subtitle="Lunes a Viernes de 21 a 7h">Noche</button>
                                    <button class="tarifa-pill" data-target="night" data-lottie="/weekend-lottie.json" data-title="Fin de semana" data-subtitle="">Fin de Semana</button>
                                    <button class="tarifa-pill" data-target="night" data-lottie="/festivos-lottie.json" data-title="Festivos" data-subtitle="">Festivo</button>
                                </div>
                                <div class="tarifas-grid single-card-mode">
                    <div class="fare-wrapper dynamic-fare-card" style="width: 100%; display: flex; flex-direction: column;" id="urban-fare-card">
                        <div class="glass card tarifas-card-hover" style="padding: 0; overflow: hidden; display: flex; flex-direction: column; gap: 0; text-align: left; background: #ffffff; border: 1px solid rgba(6, 182, 212, 0.25);">
                            <div style="background: var(--brand-cyan); padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; border-bottom: 1px solid rgba(15, 23, 42, 0.15);">
                                <div style="display: flex; align-items: center; gap: 1rem;">
                                    <div class="lottie-container">
                                        <lottie-player class="lottie-anim lottie-default" src="/moon-lottie.json" background="transparent" speed="1.5" style="opacity: 1;" mode="normal"></lottie-player>
                                    </div>
                                    <div>
                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                            <h4 class="dyn-title" style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--bg-base); transition: opacity 0.3s;" data-day="Día" data-night="Noche">Día</h4>
                                            <button class="festivos-info-btn" style="display: none; background: rgba(15, 23, 42, 0.12); border: none; border-radius: 50%; width: 34px; height: 34px; align-items: center; justify-content: center; cursor: pointer; color: var(--bg-base); transition: transform 0.2s, opacity 0.3s; transform-origin: center;" onclick="openFestivosModal()" title="Ver próximos festivos" onmouseover="this.style.transform='scale(1.1)';" onmouseout="this.style.transform='scale(1)';">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                            </button>
                                        </div>
                                        <p class="dyn-subtitle" style="margin: 0.2rem 0 0 0; font-size: 0.98rem; color: rgba(15, 23, 42, 0.75); font-weight: 500; transition: opacity 0.3s;" data-day="Lunes a Viernes (7h - 21h)" data-night="Noches, Sábados, Domingos y Festivos">Lunes a Viernes (7h - 21h)</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div style="padding: 2rem; display: flex; flex-direction: column; gap: 1rem; background: #ffffff;">
                                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                    <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="min-fare">Carrera mínima</span>
                                    <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="3,56" data-night="4,43">3,56</span> €</strong>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                    <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="flag-drop">Bajada bandera</span>
                                    <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="1,39" data-night="1,73">1,39</span> €</strong>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                    <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="price-km">Precio kilómetro</span>
                                    <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="0,70" data-night="0,90">0,70</span> €</strong>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 0.2rem;">
                                    <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="waiting-hour">Hora de espera</span>
                                    <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="18,95" data-night="23,66">18,95</span> €</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta Unificada de Suplementos -->
                <div class="glass card tarifas-card-hover" style="padding: 0; overflow: hidden; display: flex; flex-direction: column; text-align: left; background: #ffffff; border: 1px solid rgba(6, 182, 212, 0.25); margin-bottom: 1.5rem;">
                    <div style="background: var(--brand-cyan); padding: 0.6rem 2rem; display: flex; align-items: center; gap: 0.6rem; border-bottom: 1px solid rgba(15, 23, 42, 0.15);">
                        <div style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-left: -3px;">
                            <lottie-player src="/moneda.json" background="transparent" speed="1" style="width: 30px; height: 30px;" loop autoplay></lottie-player>
                        </div>
                        <h4 style="margin: 0; font-size: 1.1rem; color: var(--bg-base); font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;" data-translate="supplements-title">Suplementos Municipales</h4>
                    </div>
                    <div style="padding: 1.5rem 2rem; background: #ffffff;">
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
                            <div class="supplement-item" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;" data-translate="supp-train">Estación de Tren</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">0,82 €</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('train')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;" data-translate="supp-luggage">Equipaje grande</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">0,51 €</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('luggage')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="supplement-item supplement-item-extra" style="display: none; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;">Puertos y astilleros</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">1,06 €</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('ports')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="supplement-item supplement-item-extra" style="display: none; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;">Cortadura - Torregorda</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">4,46 €</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('cortadura')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="supplement-item supplement-item-extra" style="display: none; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;">6ª y 7ª plaza (por plaza)</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">0,91 €</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('seats')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="supplement-item supplement-item-extra" style="display: none; justify-content: space-between; align-items: center; padding-bottom: 0.5rem;">
                                <span style="color: rgba(15, 23, 42, 0.75); font-size: 0.95rem;">Madrugadas fin de semana</span>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <strong style="color: var(--bg-base); font-size: 1.05rem;">+20%</strong>
                                    <button class="supp-info-btn" onclick="openSupplementInfoModal('early')" title="Más información">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div style="text-align: center; margin-top: 1rem;">
                            <button id="toggle-supplements-btn" style="background: var(--brand-cyan); border: none; border-radius: 9999px; color: var(--bg-base); font-weight: 800; cursor: pointer; display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; padding: 0.6rem 1.4rem; transition: background 0.2s, transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.background='#22d3ee'; this.style.transform='scale(1.03)'; this.style.boxShadow='0 4px 12px rgba(6, 182, 212, 0.35)';" onmouseout="this.style.background='var(--brand-cyan)'; this.style.transform='scale(1)'; this.style.boxShadow='none';">
                                <span id="toggle-supp-text">Ver todos los suplementos</span>
                                <svg id="toggle-supp-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.3s;"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; margin-top: 0.5rem; margin-bottom: 2.5rem; padding: 0 0.5rem;">
                    <div class="source-free-text" title="Boletín Oficial de la Junta de Andalucía. Boletín número 10 de 16/01/2026">
                        <span>FUENTES: Boletín Oficial de la Junta de Andalucía</span>
                        <span class="flag-circle-andalucia">A</span>
                    </div>
                    <div class="source-free-text" title="Boletín Oficial de la Provincia de Cádiz">
                        <span>Boletín Oficial Provincia de Cádiz</span>
                        <span class="flag-circle-cadiz">C</span>
                    </div>
                </div>
                </div>

                <div id="interurban-section" class="scope-section" style="display: none;">
                    <div class="theme-toggle-wrapper" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem; max-width: 580px; margin-left: auto; margin-right: auto; width: 100%; flex-wrap: wrap;">
                        <button class="tarifa-pill active" data-target="day" data-lottie="/moon-lottie.json" data-title="Día" data-subtitle="Lunes a Viernes (6h - 22h)">Día</button>
                        <button class="tarifa-pill" data-target="night" data-lottie="/moon-lottie.json" data-title="Noche" data-subtitle="Lunes a Viernes de 22 a 6h">Noche</button>
                        <button class="tarifa-pill" data-target="night" data-lottie="/weekend-lottie.json" data-title="Fin de semana" data-subtitle="">Fin de Semana</button>
                        <button class="tarifa-pill" data-target="night" data-lottie="/festivos-lottie.json" data-title="Festivos" data-subtitle="">Festivo</button>
                    </div>
                    <div class="tarifas-grid single-card-mode" style="margin-top: 1rem;">
                        <div class="fare-wrapper dynamic-fare-card" style="width: 100%; display: flex; flex-direction: column;" id="interurban-fare-card">
                            <div class="glass card tarifas-card-hover" style="padding: 0; overflow: hidden; display: flex; flex-direction: column; gap: 0; text-align: left; background: #ffffff; border: 1px solid rgba(6, 182, 212, 0.25);">
                                <div style="background: var(--brand-cyan); padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; border-bottom: 1px solid rgba(15, 23, 42, 0.15);">
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <div class="lottie-container">
                                            <lottie-player class="lottie-anim lottie-default" src="/moon-lottie.json" background="transparent" speed="1.5" style="opacity: 1;" mode="normal"></lottie-player>
                                        </div>
                                        <div>
                                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                <h4 class="dyn-title" style="margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--bg-base); transition: opacity 0.3s;" data-day="Día" data-night="Noche">Día</h4>
                                                <button class="festivos-info-btn" style="display: none; background: rgba(15, 23, 42, 0.12); border: none; border-radius: 50%; width: 34px; height: 34px; align-items: center; justify-content: center; cursor: pointer; color: var(--bg-base); transition: transform 0.2s, opacity 0.3s; transform-origin: center;" onclick="openFestivosModal()" title="Ver próximos festivos" onmouseover="this.style.transform='scale(1.1)';" onmouseout="this.style.transform='scale(1)';">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                                </button>
                                            </div>
                                            <p class="dyn-subtitle" style="margin: 0.2rem 0 0 0; font-size: 0.98rem; color: rgba(15, 23, 42, 0.75); font-weight: 500; transition: opacity 0.3s;" data-day="Lunes a Viernes (6h - 22h)" data-night="Noches y Festivos">Lunes a Viernes (6h - 22h)</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div style="padding: 2rem; display: flex; flex-direction: column; gap: 1rem; background: #ffffff;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                        <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="min-fare">Carrera mínima</span>
                                        <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="3,83" data-night="4,51">3,83</span> €</strong>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                            <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="flag-drop">Bajada bandera</span>
                                            <button class="supp-info-btn" style="width: 22px; height: 22px;" onclick="openSupplementInfoModal('flagDrop')" title="Más información">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" style="width: 13px; height: 13px; stroke-width: 3px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                                            </button>
                                        </div>
                                        <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="3,66" data-night="3,60">3,66</span> €</strong>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(15, 23, 42, 0.1); padding-bottom: 0.5rem;">
                                        <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="price-km">Precio kilómetro</span>
                                        <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="0,71" data-night="0,82">0,71</span> €</strong>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 0.2rem;">
                                        <span style="color: rgba(15, 23, 42, 0.75); font-weight: 500;" data-translate="waiting-hour">Hora de espera</span>
                                        <strong style="color: var(--bg-base); font-size: 1.1rem;"><span class="dyn-price" style="transition: opacity 0.3s;" data-day="17,57" data-night="20,71">17,57</span> €</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; margin-top: 1rem; margin-bottom: 2rem; padding: 0 0.5rem;">
                        <div class="source-free-text" title="Boletín Oficial de la Junta de Andalucía. Boletín número 49 de 12/03/2026">
                            <span>FUENTE: Boletín Oficial de la Junta de Andalucía</span>
                            <span class="flag-circle-andalucia">A</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dynamic style and script for single card toggle mode -->
        <style>
            .lottie-container {
                width: 70px !important;
                height: 70px !important;
                border-radius: 50% !important;
                overflow: hidden !important;
                position: relative !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                box-shadow: none !important;
                border: none !important;
                background: transparent !important;
                flex-shrink: 0 !important;
                margin-left: -5px;
            }

            .lottie-anim {
                width: 100% !important;
                height: 100% !important;
                position: absolute !important;
                transition: opacity 0.6s ease-in-out !important;
            }

            .lottie-default {
                transform: scale(1.7) !important;
            }
            .tarifas-grid.single-card-mode {
                display: block !important;
                max-width: 580px;
                margin-left: auto;
                margin-right: auto;
                width: 100%;
            }
            .tarifas-grid.single-card-mode > .fare-wrapper {
                width: 100%;
                display: flex !important;
            }
            .supp-info-btn {
                background: rgba(15, 23, 42, 0.08);
                border: none;
                border-radius: 50%;
                width: 28px;
                height: 28px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                color: var(--bg-base);
                transition: background 0.2s, transform 0.2s;
                flex-shrink: 0;
            }
            .supp-info-btn:hover {
                background: rgba(15, 23, 42, 0.15);
                transform: scale(1.1);
            }
            .supp-info-btn svg {
                width: 17px;
                height: 17px;
                stroke-width: 3px;
            }
            .source-free-text {
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                color: #ffffff;
                font-size: 0.82rem;
                font-weight: 500;
                letter-spacing: 0.5px;
                cursor: help;
                opacity: 0.75;
