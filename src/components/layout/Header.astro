---
// src/components/layout/Header.astro
---

<header class="chat-header" id="main-header" style="display: flex; justify-content: space-between; align-items: center; position: relative; max-width: 448px; width: calc(100% - 32px); margin: 16px auto 0 auto; background: color-mix(in srgb, var(--header-bg) 75%, transparent); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid var(--header-border); border-radius: 40px; box-shadow: 0 8px 32px rgba(0,0,0,0.1); z-index: 2000; padding: 0 16px; height: 60px; flex-shrink: 0;">
    
    <!-- Info Central (Avatar y Títulos) -->
    <div class="chat-header-info" id="header-info" style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 1; min-width: 0;">
        <div class="logo" id="header-lottie" style="width: 44px; height: 44px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center;"></div>
        <div class="chat-title-group" id="header-title-group" style="display: flex; flex-direction: column; justify-content: center; min-width: 0; margin-top: 2px;">
            <h1 id="header-title" style="margin: 0; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 18px;">gaditan</h1>
            <button id="header-subtitle-btn" onclick="window.openCityModal()" style="background: none; border: none; padding: 0; margin: 0; display: flex; align-items: center; gap: 4px; cursor: pointer; color: var(--text-secondary); font-size: 0.8rem; line-height: 1.2; white-space: nowrap; transition: color 0.2s; text-align: left;">
                <span class="chat-subtitle" id="header-subtitle" style="margin: 0; padding: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Cádiz Capital</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="m6 9 6 6 6-6"/></svg>
            </button>
        </div>
    </div>
    
    <!-- Botones de Acción (Derecha) -->
    <div class="theme-picker-container" id="header-actions" style="display: flex; align-items: center; gap: 6px; position: relative; flex-shrink: 0;">
        <button id="header-weather-chip" aria-label="Ver clima" onclick="window.openWeatherModal()" style="display: none; align-items: center; justify-content: center; gap: 4px; background: var(--primary-color); color: white; border: none; padding: 4px 10px; border-radius: 16px; font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: opacity 0.2s; flex-shrink: 0; white-space: nowrap;">
            <span id="header-weather-icon"></span>
            <span id="header-weather-temp"></span>
        </button>


        <button id="theme-btn" class="theme-btn" aria-label="Opciones" onclick="const m = document.getElementById('dropdown-menu'); m.style.display = m.style.display === 'flex' ? 'none' : 'flex';">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
            </svg>
        </button>
        
        <!-- Menú de opciones -->
        <div id="dropdown-menu" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 8px; background: var(--header-bg); border: 1px solid var(--header-border); border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); flex-direction: column; min-width: 180px; z-index: 1000; overflow: hidden;">
            <button id="bookmarks-menu-btn" onclick="window.switchPanel('guardados'); document.getElementById('dropdown-menu').style.display = 'none';" style="display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; width: 100%; background: none; border: none; cursor: pointer; color: var(--text-primary); border-bottom: 1px solid var(--border-color); font-weight: 600; font-size: 14px; text-align: left; transition: background 0.2s;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/>
                    </svg>
                    Mis Guardados
                </div>
                <span id="bookmarks-badge" style="display: none; background: #ef4444; color: white; border-radius: 10px; padding: 2px 6px; font-size: 11px; font-weight: bold;">0</span>
            </button>
            <button id="profile-menu-btn" onclick="window.openLoginModal(); document.getElementById('dropdown-menu').style.display = 'none';" style="display: flex; align-items: center; gap: 8px; padding: 12px 16px; width: 100%; background: none; border: none; cursor: pointer; color: var(--text-primary); border-bottom: 1px solid var(--border-color); font-weight: 600; font-size: 14px; text-align: left; transition: background 0.2s;">
                <div style="display: flex; align-items: center; justify-content: center; width: 18px; height: 18px; overflow: hidden; border-radius: 50%;">
                    <svg id="profile-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                    <img id="profile-avatar" src="" alt="Avatar" style="display: none; width: 18px; height: 18px; object-fit: cover;" />
                </div>
                Mi Perfil
            </button>
            <button onclick="window.toggleDarkMode(); document.getElementById('dropdown-menu').style.display = 'none';" style="display: flex; align-items: center; gap: 8px; padding: 12px 16px; width: 100%; background: none; border: none; cursor: pointer; color: var(--primary-color); font-weight: 600; font-size: 14px; text-align: left; transition: background 0.2s;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
                </svg>
                Modo Oscuro
            </button>
        </div>
    </div>
</header>
