        <!-- Destinos Populares -->
        <section class="destination-section" id="destinos">
            <div class="container">
                <!-- ================= AEROPUERTOS ================= -->
                <div id="section-aeropuertos" style="margin-bottom: 4rem;">
                    <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                        <span data-translate="frequent-destinations">Traslados a Aeropuertos</span>
                    </h2>
                    <p class="section-subtitle" style="text-align: center; color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.1rem;" data-translate="frequent-destinations-sub">Conexiones directas a aeropuertos: La manera más cómoda de llegar a los aeropuertos más cercanos.</p>
                    
                    <!-- Estado por defecto: Grid de tarjetas -->
                    <div id="aeropuertos-grid-dinamico" class="mini-dest-grid"></div>

                    <!-- Estado activo: Mapa + Opciones (Oculto por defecto) -->
                    <div id="aeropuertos-active-view" style="display: none;">
                        <button class="md3-btn md3-tonal btn-volver-destinos" data-grid="aeropuertos" onclick="hideDestinoDetails('aeropuertos')" style="margin-bottom: 1.5rem; font-size: 0.85rem; border-radius: 9999px;">
                            <i data-lucide="arrow-left" style="width: 16px; height: 16px; margin-right: 0.4rem;"></i> Volver a Aeropuertos
                        </button>
                        
                        <div class="map-container" style="position: relative; border-radius: 30px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2); margin-bottom: 1.5rem;">
                            <!-- Overlay dinámico -->
                            <div id="map-overlay-info-aeropuertos" style="position: absolute; top: 15px; left: 15px; right: 15px; z-index: 90; display: none; pointer-events: none; transition: all 0.4s cubic-bezier(0.1, 0.9, 0.2, 1); transform: translateY(-20px); opacity: 0;"></div>
                            <!-- Mapa Base -->
                            <div id="map-aeropuertos" style="width: 100%; aspect-ratio: 16/9; max-height: 50vh; background-color: #e5e3df; filter: contrast(1.1) opacity(0.9) saturate(1.2);"></div>
                        </div>

                        <!-- Opciones de transporte -->
                        <div id="aeropuertos-opciones-container"></div>
                    </div>
                </div>

                <!-- ================= DESTINOS FAVORITOS ================= -->
                <div id="section-favoritos">
                    <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                        <span data-translate="popular-destinations">Destinos Favoritos</span>
                    </h2>
                    <p class="section-subtitle" style="text-align: center; color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.1rem;" data-translate="popular-destinations-sub">Los viajes más solicitados por nuestros clientes desde Cádiz capital</p>
                    
                    <!-- Estado por defecto: Grid de tarjetas -->
                    <div id="favoritos-grid-dinamico" class="mini-dest-grid"></div>
                    
                    <!-- Estado activo: Mapa + Opciones (Oculto por defecto) -->
                    <div id="favoritos-active-view" style="display: none;">
                        <button class="md3-btn md3-tonal btn-volver-destinos" data-grid="favoritos" onclick="hideDestinoDetails('favoritos')" style="margin-bottom: 1.5rem; font-size: 0.85rem; border-radius: 9999px;">
                            <i data-lucide="arrow-left" style="width: 16px; height: 16px; margin-right: 0.4rem;"></i> Volver a Favoritos
                        </button>
                        
                        <div class="map-container" style="position: relative; border-radius: 30px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2); margin-bottom: 1.5rem;">
                            <!-- Overlay dinámico -->
                            <div id="map-overlay-info-favoritos" style="position: absolute; top: 15px; left: 15px; right: 15px; z-index: 90; display: none; pointer-events: none; transition: all 0.4s cubic-bezier(0.1, 0.9, 0.2, 1); transform: translateY(-20px); opacity: 0;"></div>
                            <!-- Mapa Base -->
                            <div id="map-favoritos" style="width: 100%; aspect-ratio: 16/9; max-height: 50vh; background-color: #e5e3df; filter: contrast(1.1) opacity(0.9) saturate(1.2);"></div>
                        </div>

                        <!-- Opciones de transporte -->
                        <div id="favoritos-opciones-container"></div>
                    </div>
                </div>
            </div>
        </section>