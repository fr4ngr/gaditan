                        <!-- CALCULATOR SECTION -->
        <section class="calculator-section" id="calculadora" style="padding: 4rem 0;">
            <div class="container">
                <h2 class="section-title" data-translate="calc-title">Taxímetro Inteligente</h2>
                <p class="section-subtitle" data-translate="calc-subtitle">Calcula el precio estimado de tu trayecto al instante</p>
                <div class="booking-card glass" style="margin: 0 auto;">
                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                        
                        <!-- Origen -->
                        <div class="form-group integrated-pill-container" style="gap: 0;">
                            <div class="integrated-pill">
                                <div class="input-icon-wrapper" style="flex: 1; min-width: 0;">
                                    <i data-lucide="locate" style="cursor: pointer; pointer-events: auto; color: var(--brand-cyan);" onclick="window.geolocateOrigin('calc-origin', 'calc-origin-num')"></i>
                                    <input type="text" id="calc-origin" class="glass-input with-icon pill-left" placeholder="Origen (ej. Av. Andalucía)" autocomplete="off" style="width: 100%;">
                                    <div id="origin-suggestions" class="autocomplete-suggestions hidden"></div>
                                </div>
                                <div class="pill-divider"></div>
                                <div class="input-icon-wrapper num-wrapper">
                                    <input type="text" inputmode="numeric" id="calc-origin-num" class="glass-input pill-right" placeholder="Nº" style="width: 100%; text-align: center;" aria-label="Número de Origen">
                                </div>
                            </div>
                        </div>
                        </div>
                        
                        <!-- Destino -->
                        <div class="form-group integrated-pill-container" style="gap: 0; margin-top: 1rem;">
                            <div class="integrated-pill">
                                <div class="input-icon-wrapper" style="flex: 1; min-width: 0;">
                                    <i data-lucide="flag"></i>
                                    <input type="text" id="calc-destination" class="glass-input with-icon pill-left" placeholder="Destino (ej. Plaza Asdrúbal)" autocomplete="off" style="width: 100%;">
                                    <div id="dest-suggestions" class="autocomplete-suggestions hidden"></div>
                                </div>
                                <div class="pill-divider"></div>
                                <div class="input-icon-wrapper num-wrapper">
                                    <input type="text" inputmode="numeric" id="calc-dest-num" class="glass-input pill-right" placeholder="Nº" style="width: 100%; text-align: center;" aria-label="Número de Destino">
                                </div>
                            </div>
                        </div>

                        

                        <!-- Fecha y Hora (Oculto por defecto) -->
                        <div id="calc-datetime-container" class="form-row" style="display: flex; gap: 1rem; flex-wrap: nowrap;">
                            <div class="form-group" style="flex: 1; min-width: 0;">
                                <label for="calc-date"><span>Fecha</span></label>
                                <div class="input-icon-wrapper">
                                    <i data-lucide="calendar"></i>
                                    <input type="date" id="calc-date" class="glass-input with-icon">
                                </div>
                            </div>
                            <div class="form-group" style="flex: 1; min-width: 0;">
                                <label for="calc-time"><span>Hora</span></label>
                                <div class="input-icon-wrapper">
                                    <i data-lucide="clock"></i>
                                    <input type="time" id="calc-time" class="glass-input with-icon">
                                </div>
                            </div>
                        </div>

                        <!-- Botón SUPLEMENTOS -->
                        <div style="margin-top: 0.5rem;">
                            <button type="button" id="btn-calc-supplements" onclick="toggleCalcSupplements()" style="width: 100%; display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.8rem 1rem; border-radius: 12px; cursor: pointer; font-weight: 600; font-family: 'Outfit', sans-serif;">
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <i data-lucide="plus-circle" style="color: var(--brand-cyan);"></i> SUPLEMENTOS
                                </div>
                                <i data-lucide="chevron-down" id="calc-supplements-chevron"></i>
                            </button>
                            
                            <!-- Contenedor de Suplementos -->
                            <div id="calc-supplements-container" class="hidden" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 1rem; margin-top: 0.5rem;">
                                <div class="chip-group" style="justify-content: flex-start;">
                                    <div class="chip-wrapper">
                                        <span class="chip-label">Maletas grandes</span>
                                        <div class="booking-chip stepper-chip-container">
                                            <button type="button" class="stepper-btn-full" onclick="updateCalcLuggage(-1)">-</button>
                                            <div class="stepper-content">
                                                <i data-lucide="briefcase" class="chip-icon"></i> <span class="chip-text" id="calc-luggage">0</span>
                                            </div>
                                            <button type="button" class="stepper-btn-full" onclick="updateCalcLuggage(1)">+</button>
                                        </div>
                                    </div>
                                    <div class="chip-wrapper" style="width: 100%; margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.5rem;">
                                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--text-muted); font-size: 0.9rem;">
                                            <input type="checkbox" id="calc-renfe-toggle" onchange="window.triggerAutoCalc && window.triggerAutoCalc()" style="accent-color: var(--brand-cyan); width: 16px; height: 16px;">
                                            Estación Renfe (+0,82€)
                                        </label>
                                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--text-muted); font-size: 0.9rem;">
                                            <input type="checkbox" id="calc-puerto-toggle" onchange="window.triggerAutoCalc && window.triggerAutoCalc()" style="accent-color: var(--brand-cyan); width: 16px; height: 16px;">
                                            Puerto / Cruceros (+1,06€)
                                        </label>
                                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--text-muted); font-size: 0.9rem;">
                                            <input type="checkbox" id="calc-cortadura-toggle" onchange="window.triggerAutoCalc && window.triggerAutoCalc()" style="accent-color: var(--brand-cyan); width: 16px; height: 16px;">
                                            Cortadura - Torregorda (+4,46€)
                                        </label>
                                        <p style="font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.2rem;">*Los suplementos no se aplican si la ruta supera los 12km o sale de la ciudad.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        
                        
                                                <!-- Resultado -->
                        <div id="calc-result" style="display: none; text-align: center; margin-top: 1rem; border-top: 1px solid var(--glass-border); padding-top: 1.5rem;">
                            <div style="display: flex; justify-content: center; gap: 2rem; margin-bottom: 1rem;">
                                <p style="color: var(--text-muted); font-size: 0.9rem;"><span data-translate="calc-dist">Distancia:</span> <strong id="calc-dist-val" style="color: #fff;">0 km</strong></p>
                                <p style="color: var(--text-muted); font-size: 0.9rem;"><span data-translate="calc-time">Tiempo:</span> <strong id="calc-time-val" style="color: #fff;">0 min</strong></p>
                            </div>
                            <div class="pricing-split" style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                              
                              <!-- Tarjeta Precio Cerrado -->
                              <div class="price-card premium" style="background: rgba(0, 210, 255, 0.1); border: 1px solid rgba(0, 210, 255, 0.3); border-radius: 12px; padding: 1.5rem; position: relative; overflow: hidden; box-shadow: 0 4px 20px rgba(0, 210, 255, 0.15);">
                                  <div style="position: absolute; top: 0; right: 0; background: var(--brand-cyan); color: #000; font-size: 0.7rem; font-weight: bold; padding: 3px 10px; border-bottom-left-radius: 8px; letter-spacing: 0.5px;" data-translate="badge-guaranteed">GARANTIZADO</div>
                                  <h4 style="margin: 0; color: var(--brand-cyan); font-size: 1.2rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;" data-translate="calc-cerrado-title"><i data-lucide="shield-check"></i> Precio Cerrado Legal</h4>
                                  <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: #a0aec0;" data-translate="calc-cerrado-desc">Si reservas online. Inmune a atascos o semáforos.</p>
                                  <div style="font-size: 3.5rem; font-weight: 800; color: #fff; margin-top: 0.5rem; line-height: 1;" id="calc-price-cerrado">0,00€</div>
                                  <button class="btn btn-primary" style="width: 100%; margin-top: 1.5rem; border-radius: 8px; font-weight: 600; font-size: 1.1rem; padding: 1rem;" onclick="document.querySelector('#reserva').scrollIntoView({behavior:'smooth', block:'start'}); setTimeout(()=>window.scrollBy(0, -60), 400);" data-translate="calc-btn-book">Bloquear Precio Ahora</button>
                              </div>

                              <!-- Tarjeta Taxímetro Calle -->
                              <div class="price-card standard" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; padding: 1rem;">
                                  <h4 style="margin: 0; color: #cbd5e1; font-size: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;" data-translate="calc-street-title"><i data-lucide="calculator"></i> Taxímetro en Parada/Calle</h4>
                                  <p style="margin: 0.25rem 0 0 0; font-size: 0.8rem; color: #718096;" data-translate="calc-street-desc">Estimación que incluye un sobrecoste aprox. por semáforos y atascos según el BOJA.</p>
                                  <div style="font-size: 2rem; font-weight: 700; color: #a0aec0; margin-top: 0.5rem;" id="calc-price-taximetro">~ 0,00€</div>
                              </div>
                          </div>
                            
                            <!-- Mapa de la ruta -->
                            <div id="calc-map" style="width: 100%; height: 250px; border-radius: 10px; margin-top: 1.5rem; border: 1px solid var(--glass-border); display: none;"></div>
                        </div>
                        
                        <!-- Estados (Carga/Error) -->
                        <div id="calc-loading" style="display: none; text-align: center; margin-top: 1rem; color: var(--text-muted);">
                            <i data-lucide="loader-2" class="spin" style="animation: spin 1s linear infinite;"></i> <span data-translate="calc-loading">Calculando ruta óptima...</span>
                        </div>
                        <div id="calc-error" style="display: none; text-align: center; margin-top: 1rem; color: #ff6b6b; font-size: 0.9rem;">
                            <i data-lucide="alert-circle" size="14"></i> <span id="calc-error-text">No se pudo encontrar la ruta. Verifica las direcciones.</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>