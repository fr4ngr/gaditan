<!-- LOGIN MODAL -->
<div id="login-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
    <div style="background: var(--header-bg); border: 1px solid var(--header-border); border-radius: 24px; padding: 32px 24px; width: 90%; max-width: 340px; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.2); position: relative;">
        <button onclick="document.getElementById('login-modal').style.display = 'none'" style="position: absolute; top: 16px; right: 16px; background: none; border: none; color: var(--text-secondary); font-size: 20px; cursor: pointer;">✕</button>
        
        <div style="width: 64px; height: 64px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 32px; margin: 0 auto 16px;">
            👤
        </div>
        
        <h2 style="margin: 0 0 8px 0; font-size: 20px; color: var(--text-primary);">Tu Perfil Público</h2>
        <p style="margin: 0 0 24px 0; font-size: 14px; color: var(--text-secondary); line-height: 1.4;">Únete a la comunidad de Cádiz para guardar tus favoritos y compartir recomendaciones.</p>
        
        <a href="/api/auth/google" style="display: flex; align-items: center; justify-content: center; gap: 12px; background: #ffffff; color: #3c4043; border: 1px solid #dadce0; padding: 12px; border-radius: 12px; font-weight: 500; font-size: 15px; text-decoration: none; box-shadow: 0 1px 2px rgba(0,0,0,0.05); transition: background 0.2s;">
            <svg width="20" height="20" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                <path fill="none" d="M1 1h22v22H1z"/>
            </svg>
            Continuar con Google
        </a>
        
        <div id="user-info-section" style="display: none; margin-top: 20px; text-align: left; background: var(--chat-bg); padding: 16px; border-radius: 12px; border: 1px solid var(--header-border);">
            <div style="font-size: 12px; color: var(--text-secondary); text-transform: uppercase; font-weight: 700; margin-bottom: 4px;">Sesión Iniciada</div>
            <div id="logged-user-name" style="font-weight: 600; color: var(--text-primary); font-size: 15px;"></div>
            <div id="logged-user-email" style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px;"></div>
            
            <button onclick="window.logout()" style="width: 100%; padding: 8px; border-radius: 8px; border: 1px solid #ef4444; background: none; color: #ef4444; font-weight: 500; cursor: pointer; transition: background 0.2s;">
                Cerrar Sesión
            </button>
        </div>
    </div>
</div>
