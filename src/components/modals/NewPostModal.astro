---
// src/components/modals/NewPostModal.astro
---
<!-- NEW POST MODAL -->
<div id="new-post-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
    <div style="background: var(--header-bg); border: 1px solid var(--header-border); padding: 24px; border-radius: 20px; width: 90%; max-width: 400px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: flex; flex-direction: column; gap: 16px;">
        <h3 style="margin: 0; color: var(--text-primary); font-size: 20px;">Subir al Perfil</h3>
        <textarea id="new-post-content" placeholder="¿Qué sitio de Cádiz quieres recomendar hoy?" rows="3" style="width: 100%; border-radius: 12px; padding: 12px; border: 1px solid var(--header-border); background: var(--bg-color); color: var(--text-primary); font-family: inherit; resize: vertical; box-sizing: border-box;"></textarea>
        
        <div style="text-align: left; margin-bottom: 8px;">
            <label for="new-post-image" style="display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 14px; font-weight: 600;">Añadir Foto (Opcional)</label>
            <input type="file" id="new-post-image" accept="image/png, image/jpeg, image/webp" style="color: var(--text-primary); font-size: 14px; width: 100%;" />
        </div>

        <div style="text-align: left; display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.05); padding: 12px; border-radius: 12px; border: 1px solid var(--header-border);">
            <button id="record-audio-btn" type="button" style="background: var(--primary-color); border: none; border-radius: 50%; width: 40px; height: 40px; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; transition: transform 0.2s;">🎙️</button>
            <div id="record-audio-status" style="color: var(--text-secondary); font-size: 14px;">Grabar nota de voz</div>
            <button id="delete-audio-btn" type="button" style="display: none; background: transparent; border: none; color: #ef4444; cursor: pointer; font-size: 18px; margin-left: auto;">🗑️</button>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 8px;">
            <button onclick="document.getElementById('new-post-modal').style.display='none'" style="flex: 1; padding: 12px; border-radius: 12px; background: transparent; border: 1px solid var(--header-border); color: var(--text-secondary); font-weight: 600; cursor: pointer;">Cancelar</button>
            <button id="submit-post-btn" onclick="window.submitNewPost()" style="flex: 1; padding: 12px; border-radius: 12px; background: var(--primary-color); border: none; color: white; font-weight: 600; cursor: pointer; display: flex; justify-content: center; align-items: center; gap: 8px;">Publicar</button>
        </div>
    </div>
</div>
