---
// src/components/tabs/MuroTab.astro
---
<!-- TAB MURO -->
<div id="tab-muro" style="display: none; flex: 1; width: 100%; min-height: 0; flex-direction: column; background: var(--bg-color); max-width: 480px; margin: 0 auto; overflow-y: auto; padding-top: 84px;">
    <div style="padding: 16px; border-bottom: 1px solid var(--header-border); display: flex; justify-content: flex-end; align-items: center; position: sticky; top: 84px; background: var(--header-bg); z-index: 10; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); min-height: 56px;">
        <!-- Add Post Vertical Speed Dial -->
        <div class="radial-menu-wrapper" id="radial-menu-muro" style="position: absolute; right: 16px; top: 16px; z-index: 1005;">
            <button class="radial-pill-item" style="--ty: 60px;" onclick="window.openNewPostModal('photo')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                Foto
            </button>
            <button class="radial-pill-item" style="--ty: 120px;" onclick="window.openNewPostModal('video')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                Vídeo
            </button>
            <button class="radial-pill-item" style="--ty: 180px;" onclick="window.openNewPostModal('audio')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="22"></line></svg>
                Nota de voz
            </button>
            
            <button class="radial-main-btn primary" onclick="window.toggleRadialMenu('muro')" aria-label="Añadir publicación">
                <div class="plus-icon">+</div>
            </button>
        </div>
    </div>
    <div id="feed-container" style="flex: 1; padding: 16px; display: flex; flex-direction: column; gap: 16px; padding-bottom: 100px;">
        <div style="text-align: center; color: var(--text-secondary); margin-top: 20px;">Cargando muro...</div>
    </div>
</div>
