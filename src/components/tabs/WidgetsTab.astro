---
// src/components/tabs/WidgetsTab.astro
---

<style>
.widgets-container {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
    z-index: 50;
}
.widget-pill {
    flex: 1;
    height: 36px;
    background: linear-gradient(135deg, var(--header-bg), var(--bg-color));
    border: 1px solid var(--border-color);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    user-select: none;
    touch-action: pan-x; /* Allow horizontal scroll on page, but capture vertical for swipe */
}
.widget-add-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--header-bg);
    border: 1px dashed var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-color);
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.2s, background 0.2s;
}
.widget-add-btn:active {
    transform: scale(0.9);
    background: var(--chat-bg);
}
.widget-pill-content {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s;
    position: absolute;
    width: 100%;
    justify-content: center;
}

</style>

<div class="widgets-container" id="widgets-main-container">
    <div class="widget-pill" id="widget-active-pill">
        <div class="widget-pill-content" id="widget-pill-inner">
            <span style="color: var(--text-secondary);">Elige tus widgets</span>
        </div>
    </div>
    
    <div class="widget-add-btn" id="widget-add-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
    </div>


</div>

<script>
    const AVAILABLE_WIDGETS = [
        { id: 'clima', icon: '⛅', title: 'Clima local', value: '24°C Soleado', action: 'window.openWeatherModal()' },
        { id: 'transporte', icon: '🚌', title: 'Bus L1', value: 'Llega en 4 min' },
        { id: 'agenda', icon: '🎭', title: 'Carnaval', value: 'Faltan 142 días' },
        { id: 'mareas', icon: '🌊', title: 'Mareas', value: 'Pleamar 14:30' }
    ];

    let selectedWidgets = [];
    let currentIndex = 0;
    let currentUserId = null;

    const addBtn = document.getElementById('widget-add-btn');
    const pill = document.getElementById('widget-active-pill');
    const pillInner = document.getElementById('widget-pill-inner');

    async function initWidgets() {
        try {
            const res = await fetch('/api/auth/me');
            const data = await res.json();
            if (data.user) {
                currentUserId = data.user.id;
                const saved = localStorage.getItem('gaditan_widgets_' + currentUserId);
                if (saved) {
                    selectedWidgets = JSON.parse(saved);
                }
            } else {
                selectedWidgets = []; 
            }
        } catch (e) {
            console.error('Error fetching user for widgets', e);
        }

        renderPill();
        renderPill();
    }

    (window as any).toggleWidget = function(widgetId, btnEl) {
        const widget = AVAILABLE_WIDGETS.find(w => w.id === widgetId);
        if (!widget) return;
        
        const isSelected = selectedWidgets.some(w => w.id === widgetId);
        if (isSelected) {
            selectedWidgets = selectedWidgets.filter(w => w.id !== widgetId);
            btnEl.style.borderColor = 'var(--border-color)';
            btnEl.style.background = 'transparent';
            const checkCircle = btnEl.querySelector('.check-circle');
            checkCircle.innerHTML = '';
            checkCircle.style.borderColor = 'var(--border-color)';
            checkCircle.style.background = 'transparent';
        } else {
            selectedWidgets.push(widget);
            btnEl.style.borderColor = 'var(--primary-color)';
            btnEl.style.background = 'var(--chat-bg)';
            const checkCircle = btnEl.querySelector('.check-circle');
            checkCircle.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            checkCircle.style.borderColor = 'var(--primary-color)';
            checkCircle.style.background = 'var(--primary-color)';
        }
        
        if (currentUserId) {
            localStorage.setItem('gaditan_widgets_' + currentUserId, JSON.stringify(selectedWidgets));
        }
        currentIndex = 0;
        renderPill();
    };

    function renderPill(direction = 0) {
        if (selectedWidgets.length === 0) {
            pillInner.innerHTML = '<span style="color: var(--text-secondary);">Elige tus widgets</span>';
            pill.onclick = null;
            return;
        }
        
        if (currentIndex >= selectedWidgets.length) currentIndex = 0;
        if (currentIndex < 0) currentIndex = selectedWidgets.length - 1;

        const activeWidget = selectedWidgets[currentIndex];

        if (direction !== 0) {
            const oldInner = pillInner.cloneNode(true);
            oldInner.id = '';
            pill.appendChild(oldInner);
            pillInner.style.transition = 'none';
            pillInner.style.transform = `translateY(${direction > 0 ? 100 : -100}%)`;
            pillInner.style.opacity = '0';
            
            // Set new content immediately for the animation to show it sliding in
            pillInner.innerHTML = `
                <span style="font-size:16px;">${activeWidget.icon}</span>
                <span>${activeWidget.title} <span style="color:var(--text-secondary); font-weight:normal; margin-left:4px;">${activeWidget.value}</span></span>
            `;
            
            requestAnimationFrame(() => {
                pillInner.style.transition = 'transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s';
                pillInner.style.transform = 'translateY(0)';
                pillInner.style.opacity = '1';
                
                oldInner.style.transform = `translateY(${direction > 0 ? -100 : 100}%)`;
                oldInner.style.opacity = '0';
                setTimeout(() => oldInner.remove(), 300);
            });
        } else {
            pillInner.innerHTML = `
                <span style="font-size:16px;">${activeWidget.icon}</span>
                <span>${activeWidget.title} <span style="color:var(--text-secondary); font-weight:normal; margin-left:4px;">${activeWidget.value}</span></span>
            `;
        }
        
        if (activeWidget.action) {
            pill.onclick = () => eval(activeWidget.action);
            pill.style.cursor = 'pointer';
        } else {
            pill.onclick = null;
            pill.style.cursor = 'default';
        }
    }

    addBtn.onclick = (e) => {
        e.stopPropagation();
        
        let html = `
            <div style="margin-bottom: 12px; color: var(--text-primary); font-size: 14px;">
                Aquí tienes los widgets disponibles. Toca para activarlos o desactivarlos:
            </div>
            <div style="display: flex; flex-direction: column; gap: 8px;">
        `;
        
        AVAILABLE_WIDGETS.forEach(widget => {
            const isSelected = selectedWidgets.some(w => w.id === widget.id);
            const border = isSelected ? 'var(--primary-color)' : 'var(--border-color)';
            const bg = isSelected ? 'var(--chat-bg)' : 'transparent';
            const circleBg = isSelected ? 'var(--primary-color)' : 'transparent';
            const circleCheck = isSelected ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>' : '';
            
            html += `
                <div onclick="window.toggleWidget('${widget.id}', this)" style="display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border: 1px solid ${border}; background: ${bg}; border-radius: 12px; cursor: pointer; transition: all 0.2s;">
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span style="font-size:18px;">${widget.icon}</span>
                        <span style="font-weight:600; font-size:13px; color:var(--text-primary);">${widget.title}</span>
                    </div>
                    <div class="check-circle" style="width:20px; height:20px; border-radius:50%; border:2px solid ${border}; background:${circleBg}; display:flex; align-items:center; justify-content:center; transition: all 0.2s;">
                        ${circleCheck}
                    </div>
                </div>
            `;
        });
        
        html += `</div>`;
        
        if (typeof (window as any).addMessage === 'function') {
            (window as any).addMessage('bot', html);
        } else {
            console.warn("addMessage function not found in window");
        }
    };

    let startY = 0;
    let isSwiping = false;

    pill.addEventListener('touchstart', (e) => {
        if (selectedWidgets.length <= 1) return;
        startY = e.touches[0].clientY;
        isSwiping = true;
    }, { passive: true });

    pill.addEventListener('touchmove', (e) => {
        if (!isSwiping) return;
    }, { passive: true });

    pill.addEventListener('touchend', (e) => {
        if (!isSwiping) return;
        isSwiping = false;
        const endY = e.changedTouches[0].clientY;
        const diff = endY - startY;

        if (Math.abs(diff) > 20) {
            if (diff > 0) {
                currentIndex--;
                renderPill(-1);
            } else {
                currentIndex++;
                renderPill(1);
            }
        }
    });


    initWidgets();
</script>
