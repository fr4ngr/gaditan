---
// AnimatedMoon.astro
---
<div class="lottie-moon-wrapper">
  <lottie-player
    src="/moon-lottie.json"
    background="transparent"
    speed="1"
    style="width: 100%; height: 100%;"
    loop
    autoplay>
  </lottie-player>
</div>

<script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>

<style>
.lottie-moon-wrapper {
  width: 70px;
  height: 70px;
  min-width: 70px;
  min-height: 70px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>
