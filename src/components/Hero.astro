---
---
<!-- Hero Section con Carrusel Magnético -->
<section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-carousel-container">
        <div class="hero-carousel-track" id="heroTrack">
            <!-- SLIDE 1 (Principal) -->
            <div class="hero-slide">
                <div class="container hero-content" style="padding:0; margin:0;">
                    <div class="hero-badge" style="margin-inline: auto; width: fit-content;"><span class="pulse-dot"></span> <span data-translate="hero-pretitle">LA MEJOR GUÍA INFORMATIVA SOBRE</span></div>
                    <h1 class="hero-title" id="hero-title" data-translate="hero-title">Taxis Oficiales <br>en Cádiz</h1>
                    <p class="hero-subtitle" data-translate="hero-subtitle">Pide un taxi, resérvalo o consulta las tarifas. Toda la info que necesitas en cadiz.taxi</p>
                    <div class="hero-actions" style="max-width: 600px; margin-inline: auto; display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">
                        <a href="#reservas" class="btn btn-glow" style="width: 100%; justify-content: center; padding: 1rem;">
                            <i data-lucide="calculator"></i> Calculadora de Viaje
                        </a>
                        <div style="display: flex; gap: 1rem; width: 100%;">
                            <a href="#tarifas" class="btn" style="flex: 1; background: rgba(255,255,255,0.08); border: 1px solid var(--glass-border); justify-content: center; backdrop-filter: blur(10px); color: white; padding: 1rem 0.5rem;">
                                <i data-lucide="badge-check" style="width:18px;height:18px;color:var(--brand-cyan);"></i> Tarifas
                            </a>
                            <a href="#reservas" class="btn" style="flex: 1; background: rgba(255,255,255,0.08); border: 1px solid var(--glass-border); justify-content: center; backdrop-filter: blur(10px); color: white; padding: 1rem 0.5rem;">
                                <i data-lucide="calendar" style="width:18px;height:18px;"></i> Reservas
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SLIDE 2 (Empresas - Provisional) -->
            <div class="hero-slide">
                <div class="container hero-content" style="padding:0; margin:0;">
                    <div class="hero-badge" style="margin-inline: auto; width: fit-content;"><i data-lucide="briefcase" style="width:14px;height:14px;"></i> <span style="margin-left: 0.4rem;">SERVICIOS PARA EMPRESAS</span></div>
                    <h2 class="hero-title" style="font-size: 2.8rem; line-height: 1.2; margin-bottom: 1rem;">Viajes de<br>Negocios</h2>
                    <p class="hero-subtitle">Facturación mensual, recogidas en el aeropuerto y puntualidad garantizada para ti y tus clientes.</p>
                    <div class="hero-actions" style="max-width: 600px; margin-inline: auto; display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">
                        <a href="#faq" class="btn btn-glow" style="width: 100%; justify-content: center; padding: 1rem;">
                            <i data-lucide="phone"></i> Contactar ahora
                        </a>
                    </div>
                </div>
            </div>

            <!-- SLIDE 3 (Turismo - Provisional) -->
            <div class="hero-slide">
                <div class="container hero-content" style="padding:0; margin:0;">
                    <div class="hero-badge" style="margin-inline: auto; width: fit-content;"><i data-lucide="map" style="width:14px;height:14px;"></i> <span style="margin-left: 0.4rem;">DESCUBRE LA PROVINCIA</span></div>
                    <h2 class="hero-title" style="font-size: 2.8rem; line-height: 1.2; margin-bottom: 1rem;">Rutas y<br>Turismo</h2>
                    <p class="hero-subtitle">Conoce los pueblos blancos, las playas de la costa o reserva excursiones a medida con nuestros conductores.</p>
                    <div class="hero-actions" style="max-width: 600px; margin-inline: auto; display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">
                        <a href="#destinos" class="btn btn-glow" style="width: 100%; justify-content: center; padding: 1rem;">
                            <i data-lucide="compass"></i> Ver Destinos
                        </a>
                    </div>
                </div>
            </div>

        </div>

        <!-- Pagination Dots -->
        <div class="hero-dots" id="heroDots">
            <div class="hero-dot active" data-index="0"></div>
            <div class="hero-dot" data-index="1"></div>
            <div class="hero-dot" data-index="2"></div>
        </div>
    </div>
</section>

<script>
    // Lógica del Carrusel Magnético Nativo
    document.addEventListener('DOMContentLoaded', () => {
        const track = document.getElementById('heroTrack');
        const dots = document.querySelectorAll('.hero-dot');
        const slides = document.querySelectorAll('.hero-slide');
        
        if(!track || dots.length === 0) return;

        let currentIndex = 0;
        let autoPlayTimer;
        
        // Tiempos personalizados: 10s para la principal, 5s para las otras
        const timings = [10000, 5000, 5000];

        const updateDots = (index) => {
            dots.forEach(dot => dot.classList.remove('active'));
            if(dots[index]) dots[index].classList.add('active');
        };

        const goToSlide = (index) => {
            if(index < 0 || index >= slides.length) return;
            currentIndex = index;
            track.scrollTo({
                left: slides[index].offsetLeft,
                behavior: 'smooth'
            });
            updateDots(index);
            startAutoPlay();
        };

        const nextSlide = () => {
            let nextIdx = currentIndex + 1;
            if(nextIdx >= slides.length) nextIdx = 0;
            goToSlide(nextIdx);
        };

        const startAutoPlay = () => {
            clearTimeout(autoPlayTimer);
            const time = timings[currentIndex] || 5000;
            autoPlayTimer = setTimeout(nextSlide, time);
        };

        // Interacción manual (click en puntitos)
        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const index = parseInt(e.target.dataset.index);
                goToSlide(index);
            });
        });

        // Interacción manual (scroll/swipe táctil)
        let isScrolling;
        track.addEventListener('scroll', () => {
            clearTimeout(autoPlayTimer); // Pausar autoplay mientras se desliza
            
            // Detectar cuando el usuario suelta el dedo y se asienta la diapositiva
            window.clearTimeout(isScrolling);
            isScrolling = setTimeout(() => {
                const scrollLeft = track.scrollLeft;
                const slideWidth = track.offsetWidth;
                const newIndex = Math.round(scrollLeft / slideWidth);
                
                if (newIndex !== currentIndex && newIndex >= 0 && newIndex < slides.length) {
                    currentIndex = newIndex;
                    updateDots(currentIndex);
                }
                
                // Reanudar el temporizador inteligente
                startAutoPlay();
            }, 150);
        });

        // Iniciar motor
        startAutoPlay();
    });
</script>
