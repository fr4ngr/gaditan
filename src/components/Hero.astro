---
<!-- Hero Section Fija + Subtarjetas Magnéticas -->
<section class="hero" style="padding-bottom: 2rem;">
    <div class="hero-glow"></div>
    
    <!-- CABECERA FIJA INTOCABLE -->
    <div class="container hero-content" style="padding-bottom: 1rem;">
        <div class="hero-badge" style="margin-inline: auto; width: fit-content;"><span class="pulse-dot"></span> <span data-translate="hero-pretitle">LA MEJOR GUÍA INFORMATIVA SOBRE</span></div>
        <h1 class="hero-title" id="hero-title" data-translate="hero-title">Taxis Oficiales <br>en Cádiz</h1>
        <p class="hero-subtitle" data-translate="hero-subtitle">Pide un taxi, resérvalo o consulta las tarifas. Toda la info que necesitas en cadiz.taxi</p>
        
        <div class="hero-actions" style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
            <a href="#reservas" class="btn btn-turquoise" style="padding-left: 2rem; padding-right: 2rem;"><i data-lucide="calendar"></i> Reservar</a>
        </div>
    </div>

    <!-- SUBTARJETAS DINÁMICAS (CARRUSEL 85%) -->
    <div class="hero-subcards-carousel">
        <div class="carousel-section-title" style="text-align: center; margin-bottom: 0.8rem; display: flex; align-items: center; justify-content: center;">
            <span style="font-size: 0.72rem; font-weight: 700; letter-spacing: 2.5px; color: rgba(255, 255, 255, 0.35); text-transform: uppercase;" data-translate="carousel-section-title">HERRAMIENTAS POPULARES</span>
        </div>
        <div class="hero-carousel-track" id="heroTrack">
            
            <!-- CLON: Destinos (para el scroll infinito hacia atrás) -->
            <a href="#destinos" class="hero-slide-card clone" data-real-index="2" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 0; overflow: hidden; gap: 0;">
                    <div style="background: var(--brand-cyan); padding: 1rem; display: flex; align-items: center; justify-content: center; height: 100%;">
                        <div class="card-glow-circle">
                            <i data-lucide="clock" style="width: 32px; height: 32px; color: var(--bg-base);"></i>
                        </div>
                    </div>
                    <div style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); padding: 1.2rem 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; height: 100%;">
                        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; text-align: left; align-items: flex-start;">
                            <h3 style="color: var(--bg-base); margin-bottom: 0.2rem; font-size: 1.2rem; line-height: 1.2; margin-top: 0;">Taxi 24h</h3>
                            <p style="color: var(--text-muted); font-size: 0.82rem; margin: 0; line-height: 1.4;">Disponible de día y noche.</p>
                        </div>
                        <div style="align-self: flex-end; margin-top: 0.4rem;">
                            <a href="tel:+34600000000" style="text-decoration: none; background-color: var(--brand-cyan); color: var(--bg-base); padding: 0.3rem 0.8rem; border-radius: 12px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 2px 8px rgba(6, 182, 212, 0.25);">
                                Llamar <i data-lucide="phone" style="width: 14px; height: 14px;"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </a>

            <!-- TARJETA 1: Calculadora -->
            <a href="#calculadora" class="hero-slide-card" data-real-index="0" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 0; overflow: hidden; gap: 0;">
                    <div style="background: var(--brand-cyan); padding: 1rem; display: flex; align-items: center; justify-content: center; height: 100%;">
                        <div class="card-glow-circle">
                            <i data-lucide="calculator" style="width: 32px; height: 32px; color: var(--bg-base);"></i>
                        </div>
                    </div>
                    <div style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); padding: 1.2rem 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; height: 100%;">
                        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; text-align: left; align-items: flex-start;">
                            <h3 style="color: var(--bg-base); margin-bottom: 0.2rem; font-size: 1.2rem; line-height: 1.2; margin-top: 0;">Calculadora Inteligente</h3>
                            <p style="color: var(--text-muted); font-size: 0.82rem; margin: 0; line-height: 1.4;">Calcula tu precio al instante.</p>
                        </div>
                        <div style="align-self: flex-end; margin-top: 0.4rem;">
                            <span style="background-color: var(--brand-cyan); color: var(--bg-base); padding: 0.3rem 0.8rem; border-radius: 12px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 2px 8px rgba(6, 182, 212, 0.25);">
                                Calcular <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </a>

            <!-- TARJETA 2: Mapa de Paradas -->
            <a href="#paradas" class="hero-slide-card" data-real-index="1" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 0; overflow: hidden; gap: 0;">
                    <div style="background: var(--brand-cyan); padding: 1rem; display: flex; align-items: center; justify-content: center; height: 100%;">
                        <div class="card-glow-circle" style="display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            <lottie-player src="/map-lottie.json" background="transparent" speed="1" style="width: 48px; height: 48px;" loop autoplay></lottie-player>
                        </div>
                    </div>
                    <div style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); padding: 1.2rem 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; height: 100%;">
                        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; text-align: left; align-items: flex-start;">
                            <h3 style="color: var(--bg-base); margin-bottom: 0.2rem; font-size: 1.2rem; line-height: 1.2; margin-top: 0;">Mapa de Paradas</h3>
                            <p style="color: var(--text-muted); font-size: 0.82rem; margin: 0; line-height: 1.4;">Tu parada más cercana.</p>
                        </div>
                        <div style="align-self: flex-end; margin-top: 0.4rem;">
                            <span style="background-color: var(--brand-cyan); color: var(--bg-base); padding: 0.3rem 0.8rem; border-radius: 12px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 2px 8px rgba(6, 182, 212, 0.25);">
                                Ver mapa <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </a>

            <!-- TARJETA 3: Destinos -->
            <a href="#destinos" class="hero-slide-card" data-real-index="2" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 0; overflow: hidden; gap: 0;">
                    <div style="background: var(--brand-cyan); padding: 1rem; display: flex; align-items: center; justify-content: center; height: 100%;">
                        <div class="card-glow-circle">
                            <i data-lucide="clock" style="width: 32px; height: 32px; color: var(--bg-base);"></i>
                        </div>
                    </div>
                    <div style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); padding: 1.2rem 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; height: 100%;">
                        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; text-align: left; align-items: flex-start;">
                            <h3 style="color: var(--bg-base); margin-bottom: 0.2rem; font-size: 1.2rem; line-height: 1.2; margin-top: 0;">Taxi 24h</h3>
                            <p style="color: var(--text-muted); font-size: 0.82rem; margin: 0; line-height: 1.4;">Disponible de día y noche.</p>
                        </div>
                        <div style="align-self: flex-end; margin-top: 0.4rem;">
                            <a href="tel:+34600000000" style="text-decoration: none; background-color: var(--brand-cyan); color: var(--bg-base); padding: 0.3rem 0.8rem; border-radius: 12px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 2px 8px rgba(6, 182, 212, 0.25);">
                                Llamar <i data-lucide="phone" style="width: 14px; height: 14px;"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </a>
            
            <!-- CLON: Calculadora (para el scroll infinito hacia adelante) -->
            <a href="#calculadora" class="hero-slide-card clone" data-real-index="0" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 0; overflow: hidden; gap: 0;">
                    <div style="background: var(--brand-cyan); padding: 1.5rem; display: flex; align-items: center; justify-content: center; height: 100%;">
                        <div class="card-glow-circle">
                            <i data-lucide="calculator" style="width: 22px; height: 22px; color: var(--bg-base);"></i>
                        </div>
                    </div>
                    <div style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%); padding: 1.2rem 1.5rem; display: flex; flex-direction: column; justify-content: center; flex: 1; height: 100%;">
                        <div style="flex: 1; display: flex; flex-direction: column; justify-content: center;">
                            <h3 style="color: var(--bg-base); margin-bottom: 0.2rem; font-size: 1.2rem; line-height: 1.2; margin-top: 0;">Calculadora Inteligente</h3>
                            <p style="color: var(--text-muted); font-size: 0.82rem; margin: 0; line-height: 1.4;">Calcula tu precio al instante.</p>
                        </div>
                        <div style="align-self: flex-end; margin-top: 0.4rem;">
                            <span style="background-color: var(--brand-cyan); color: var(--bg-base); padding: 0.3rem 0.8rem; border-radius: 12px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 2px 8px rgba(6, 182, 212, 0.25);">
                                Calcular <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </a>

        </div>

        <!-- Paginación -->
        <div class="hero-dots" id="heroDots">
            <div class="hero-dot active" data-index="0"><div class="hero-dot-progress"></div></div>
            <div class="hero-dot" data-index="1"><div class="hero-dot-progress"></div></div>
            <div class="hero-dot" data-index="2"><div class="hero-dot-progress"></div></div>
        </div>
    </div>
</section>

<script>
    // Lógica del Carrusel Magnético Infinito
    document.addEventListener('DOMContentLoaded', () => {
        const track = document.getElementById('heroTrack');
        const dots = document.querySelectorAll('.hero-dot');
        const slides = document.querySelectorAll('.hero-slide-card');
        
        if(!track || dots.length === 0) return;

        let currentDomIndex = 1;
        let autoPlayTimer;
        const slideTime = 5000;
        let isProgrammaticScroll = false;
        let slideCenters = [];

        const cacheSlidePositions = () => {
            slideCenters = Array.from(slides).map((slide) => {
                return slide.offsetLeft - track.offsetLeft + (slide.offsetWidth / 2);
            });
        };

        const getCenterScrollLeft = (index) => {
            const slide = slides[index];
            if (!slide) return 0;
            const slideLeft = slide.offsetLeft - track.offsetLeft;
            return slideLeft + (slide.offsetWidth / 2) - (track.offsetWidth / 2);
        };

        const updateActiveFactors = () => {
            const trackCenter = track.scrollLeft + (track.offsetWidth / 2);
            const slideWidth = slides[0].offsetWidth;
            if (slideCenters.length === 0 || !slideWidth) return;
            
            for (let i = 0; i < slides.length; i++) {
                const distance = Math.abs(trackCenter - slideCenters[i]);
                let factor = 0;
                if (distance < slideWidth) {
                    factor = 1 - (distance / slideWidth);
                    factor = factor * factor;
                }
                slides[i].style.setProperty('--active-factor', factor.toFixed(3));
            }
        };

        const updateDotsAndClasses = (domIndex) => {
            if(!slides[domIndex]) return;
            const realIndex = parseInt(slides[domIndex].dataset.realIndex);
            
            dots.forEach((dot, i) => {
                dot.classList.remove('active');
                const progress = dot.querySelector('.hero-dot-progress');
                if(progress) {
                    progress.style.transition = 'none';
                    progress.style.width = '0%';
                }
                if(i === realIndex) {
                    dot.classList.add('active');
                }
            });
            
            slides.forEach((slide, i) => {
                if (i === domIndex) {
                    slide.classList.add('active-slide');
                } else {
                    slide.classList.remove('active-slide');
                }
            });
        };

        const startAutoPlay = () => {
            clearTimeout(autoPlayTimer);
            const realIndex = parseInt(slides[currentDomIndex].dataset.realIndex);
            const activeProgress = dots[realIndex]?.querySelector('.hero-dot-progress');
            
            if(activeProgress) {
                activeProgress.style.transition = 'none';
                activeProgress.style.width = '0%';
                void activeProgress.offsetWidth; 
                
                activeProgress.style.transition = `width ${slideTime}ms linear`;
                activeProgress.style.width = '100%';
            }
            autoPlayTimer = setTimeout(nextSlide, slideTime);
        };

        const stopAutoPlay = () => {
            clearTimeout(autoPlayTimer);
            const realIndex = parseInt(slides[currentDomIndex].dataset.realIndex);
            const activeProgress = dots[realIndex]?.querySelector('.hero-dot-progress');
            if(activeProgress) {
                const computedWidth = window.getComputedStyle(activeProgress).width;
                activeProgress.style.transition = 'none';
                activeProgress.style.width = computedWidth;
            }
        };

        const getClosestSlideIndex = () => {
            let minDiff = Infinity;
            let closestIndex = 1;
            const trackCenter = track.scrollLeft + (track.offsetWidth / 2);
            
            slideCenters.forEach((center, index) => {
                const diff = Math.abs(trackCenter - center);
                if (diff < minDiff) {
                    minDiff = diff;
                    closestIndex = index;
                }
            });
            return closestIndex;
        };

        const goToDomIndex = (index, smooth = true) => {
            if(index < 0 || index >= slides.length) return;
            
            isProgrammaticScroll = true;
            
            if (!smooth) {
                track.classList.add('no-transition-jump');
            }

            currentDomIndex = index;
            
            track.style.scrollBehavior = smooth ? 'smooth' : 'auto';
            track.scrollTo({
                left: getCenterScrollLeft(index)
            });
            
            updateDotsAndClasses(index);

            if (!smooth) {
                void track.offsetWidth; 
                setTimeout(() => {
                    track.classList.remove('no-transition-jump');
                    isProgrammaticScroll = false;
                    startAutoPlay();
                }, 50);
            } else {
                setTimeout(() => {
                    isProgrammaticScroll = false;
                    
                    if (currentDomIndex === slides.length - 1) {
                        goToDomIndex(1, false);
                    } else if (currentDomIndex === 0) {
                        goToDomIndex(slides.length - 2, false);
                    } else {
                        startAutoPlay();
                    }
                }, 600); 
            }
        };

        const nextSlide = () => {
            goToDomIndex(currentDomIndex + 1);
        };

        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const targetDot = e.target.closest('.hero-dot');
                if(!targetDot) return;
                const realIndex = parseInt(targetDot.dataset.index);
                goToDomIndex(realIndex + 1, true);
            });
        });

        let isScrolling;
        track.addEventListener('scroll', () => {
            updateActiveFactors(); 
            
            if (isProgrammaticScroll) return;
            
            stopAutoPlay();
            
            window.clearTimeout(isScrolling);
            isScrolling = setTimeout(() => {
                if (isProgrammaticScroll) return;
                
                const newIndex = getClosestSlideIndex();
                currentDomIndex = newIndex;
                updateDotsAndClasses(currentDomIndex);
                
                if (currentDomIndex === slides.length - 1) {
                    goToDomIndex(1, false);
                } else if (currentDomIndex === 0) {
                    goToDomIndex(slides.length - 2, false);
                } else {
                    startAutoPlay();
                }
            }, 150);
        });

        let isInitialized = false;
        const initCarousel = () => {
            if (isInitialized) return;
            if (track.offsetWidth === 0 || slides[0].offsetWidth === 0) {
                setTimeout(initCarousel, 50);
                return;
            }
            isInitialized = true;

            isProgrammaticScroll = true;
            cacheSlidePositions();
            track.style.scrollBehavior = 'auto';
            track.scrollTo({ left: getCenterScrollLeft(currentDomIndex) });
            
            setTimeout(() => {
                track.style.scrollBehavior = 'smooth';
                updateActiveFactors();
                updateDotsAndClasses(currentDomIndex);
                startAutoPlay();
                setTimeout(() => {
                    isProgrammaticScroll = false;
                }, 100);
            }, 50);
        };

        initCarousel();
        window.addEventListener('load', initCarousel);

        window.addEventListener('resize', () => {
            isProgrammaticScroll = true;
            cacheSlidePositions();
            track.style.scrollBehavior = 'auto';
            track.scrollTo({ left: getCenterScrollLeft(currentDomIndex) });
            updateActiveFactors();
            setTimeout(() => {
                track.style.scrollBehavior = 'smooth';
                isProgrammaticScroll = false;
            }, 50);
        });
    });
</script>
