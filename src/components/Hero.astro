---
---
<!-- Hero Section Fija + Subtarjetas Magnéticas -->
<section class="hero" style="padding-bottom: 2rem;">
    <div class="hero-glow"></div>
    
    <!-- CABECERA FIJA INTOCABLE -->
    <div class="container hero-content" style="padding-bottom: 1rem;">
        <div class="hero-badge" style="margin-inline: auto; width: fit-content;"><span class="pulse-dot"></span> <span data-translate="hero-pretitle">LA MEJOR GUÍA INFORMATIVA SOBRE</span></div>
        <h1 class="hero-title" id="hero-title" data-translate="hero-title">Taxis Oficiales <br>en Cádiz</h1>
        <p class="hero-subtitle" data-translate="hero-subtitle">Pide un taxi, resérvalo o consulta las tarifas. Toda la info que necesitas en cadiz.taxi</p>
        
        <div class="hero-actions" style="margin-bottom: 2rem;">
            <a href="#calculadora" class="btn btn-glow" style="padding-left: 3rem; padding-right: 3rem;"><i data-lucide="calculator"></i> Calculadora de Viaje</a>
        </div>
    </div>

    <!-- SUBTARJETAS DINÁMICAS (CARRUSEL 85%) -->
    <div class="hero-subcards-carousel">
        <div class="hero-carousel-track" id="heroTrack">
            
            <!-- CLON: Destinos (para el scroll infinito hacia atrás) -->
            <a href="#destinos" class="hero-slide-card clone" data-real-index="2" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 1.2rem; text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                    <h3 style="color: white; margin-bottom: 0.4rem; font-size: 1.3rem; line-height: 1.2;">Viajes a la Provincia</h3>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.4;">Conoce los pueblos blancos, playas o viaja al aeropuerto.</p>
                </div>
            </a>

            <!-- TARJETA 1: Calculadora -->
            <a href="#calculadora" class="hero-slide-card" data-real-index="0" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 1.2rem; text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                    <h3 style="color: white; margin-bottom: 0.4rem; font-size: 1.3rem; line-height: 1.2;">Calculadora de Viaje</h3>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.4;">Estima tu trayecto basado en las tarifas oficiales publicadas en el BOJA.</p>
                </div>
            </a>

            <!-- TARJETA 2: Mapa de Paradas -->
            <a href="#paradas" class="hero-slide-card" data-real-index="1" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 1.2rem; text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                    <h3 style="color: white; margin-bottom: 0.4rem; font-size: 1.3rem; line-height: 1.2;">Mapa de Paradas</h3>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.4;">Encuentra la parada oficial más cercana a tu ubicación actual.</p>
                </div>
            </a>

            <!-- TARJETA 3: Destinos -->
            <a href="#destinos" class="hero-slide-card" data-real-index="2" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 1.2rem; text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                    <h3 style="color: white; margin-bottom: 0.4rem; font-size: 1.3rem; line-height: 1.2;">Viajes a la Provincia</h3>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.4;">Conoce los pueblos blancos, playas o viaja al aeropuerto.</p>
                </div>
            </a>
            
            <!-- CLON: Calculadora (para el scroll infinito hacia adelante) -->
            <a href="#calculadora" class="hero-slide-card clone" data-real-index="0" style="text-decoration: none; display: block;">
                <div class="glass card" style="padding: 1.2rem; text-align: left; height: 100%; display: flex; flex-direction: column; justify-content: center;">
                    <h3 style="color: white; margin-bottom: 0.4rem; font-size: 1.3rem; line-height: 1.2;">Calculadora de Viaje</h3>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.4;">Estima tu trayecto basado en las tarifas oficiales publicadas en el BOJA.</p>
                </div>
            </a>

        </div>

        <!-- Paginación -->
        <div class="hero-dots" id="heroDots">
            <div class="hero-dot active" data-index="0"><div class="hero-dot-progress"></div></div>
            <div class="hero-dot" data-index="1"><div class="hero-dot-progress"></div></div>
            <div class="hero-dot" data-index="2"><div class="hero-dot-progress"></div></div>
        </div>
    </div>
</section>

<script>
    // Lógica del Carrusel Magnético Infinito
    document.addEventListener('DOMContentLoaded', () => {
        const track = document.getElementById('heroTrack');
        const dots = document.querySelectorAll('.hero-dot');
        const slides = document.querySelectorAll('.hero-slide-card');
        
        if(!track || dots.length === 0) return;

        let currentDomIndex = 1; // 1 is the first REAL slide (since 0 is the clone of the last slide)
        let autoPlayTimer;
        const slideTime = 5000;

        // Position initial scroll seamlessly
        setTimeout(() => {
            track.style.scrollBehavior = 'auto';
            track.scrollTo({ left: slides[currentDomIndex].offsetLeft - track.offsetLeft - (track.offsetWidth * 0.075) });
            setTimeout(() => {
                track.style.scrollBehavior = 'smooth';
                updateDotsAndClasses(currentDomIndex);
                startAutoPlay();
            }, 50);
        }, 100);

        const updateDotsAndClasses = (domIndex) => {
            if(!slides[domIndex]) return;
            const realIndex = parseInt(slides[domIndex].dataset.realIndex);
            
            dots.forEach((dot, i) => {
                dot.classList.remove('active');
                const progress = dot.querySelector('.hero-dot-progress');
                if(progress) {
                    progress.style.transition = 'none';
                    progress.style.width = '0%';
                }
                if(i === realIndex) {
                    dot.classList.add('active');
                }
            });
            
            slides.forEach((slide, i) => {
                if (i === domIndex) {
                    slide.classList.add('active-slide');
                } else {
                    slide.classList.remove('active-slide');
                }
            });
        };

        const goToDomIndex = (index, smooth = true) => {
            if(index < 0 || index >= slides.length) return;
            currentDomIndex = index;
            
            track.style.scrollBehavior = smooth ? 'smooth' : 'auto';
            track.scrollTo({
                left: slides[index].offsetLeft - track.offsetLeft - (track.offsetWidth * 0.075)
            });
            
            updateDotsAndClasses(index);
        };

        const handleInfiniteScroll = () => {
            // Wait for smooth scrolling to visually finish
            setTimeout(() => {
                if (currentDomIndex === slides.length - 1) {
                    // Reached the end clone, silently jump to real first slide
                    goToDomIndex(1, false);
                } else if (currentDomIndex === 0) {
                    // Reached the start clone, silently jump to real last slide
                    goToDomIndex(slides.length - 2, false);
                }
            }, 400); 
        };

        const nextSlide = () => {
            goToDomIndex(currentDomIndex + 1);
            handleInfiniteScroll();
            startAutoPlay();
        };

        const startAutoPlay = () => {
            clearTimeout(autoPlayTimer);
            const realIndex = parseInt(slides[currentDomIndex].dataset.realIndex);
            const activeProgress = dots[realIndex]?.querySelector('.hero-dot-progress');
            
            if(activeProgress) {
                // Ensure the transition starts from 0 cleanly
                activeProgress.style.transition = 'none';
                activeProgress.style.width = '0%';
                void activeProgress.offsetWidth; 
                
                activeProgress.style.transition = `width ${slideTime}ms linear`;
                activeProgress.style.width = '100%';
            }
            autoPlayTimer = setTimeout(nextSlide, slideTime);
        };

        const stopAutoPlay = () => {
            clearTimeout(autoPlayTimer);
            const realIndex = parseInt(slides[currentDomIndex].dataset.realIndex);
            const activeProgress = dots[realIndex]?.querySelector('.hero-dot-progress');
            if(activeProgress) {
                const computedWidth = window.getComputedStyle(activeProgress).width;
                activeProgress.style.transition = 'none';
                activeProgress.style.width = computedWidth;
            }
        };

        // Determine which slide is visually closest to the center
        const getClosestSlideIndex = () => {
            let minDiff = Infinity;
            let closestIndex = 1;
            const trackCenter = track.scrollLeft + (track.offsetWidth / 2);
            
            slides.forEach((slide, index) => {
                const slideCenter = slide.offsetLeft - track.offsetLeft + (slide.offsetWidth / 2);
                const diff = Math.abs(trackCenter - slideCenter);
                if (diff < minDiff) {
                    minDiff = diff;
                    closestIndex = index;
                }
            });
            return closestIndex;
        };

        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const targetDot = e.target.closest('.hero-dot');
                if(!targetDot) return;
                const realIndex = parseInt(targetDot.dataset.index);
                // Map dot index to real slide DOM index (offset by 1 due to the first clone)
                goToDomIndex(realIndex + 1);
                startAutoPlay();
            });
        });

        let isScrolling;
        track.addEventListener('scroll', () => {
            stopAutoPlay();
            
            window.clearTimeout(isScrolling);
            isScrolling = setTimeout(() => {
                const newIndex = getClosestSlideIndex();
                
                if (newIndex !== currentDomIndex) {
                    currentDomIndex = newIndex;
                    updateDotsAndClasses(currentDomIndex);
                    handleInfiniteScroll();
                } else {
                    updateDotsAndClasses(currentDomIndex);
                }
                
                startAutoPlay();
            }, 150);
        });
    });
</script>
