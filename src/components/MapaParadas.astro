---
<section id="paradas" style="height: 200vh; position: relative; display: block;">
    <!-- Text above the map -->
    <div class="container" style="padding-top: 1.5rem; padding-bottom: 1rem; z-index: 10;">
        <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; color: #ffffff; margin-bottom: 0.2rem;">
            <span data-translate="map-title">Mapa de Paradas</span>
        </h2>
        <p class="section-subtitle" style="text-align: center; color: var(--text-muted); margin-bottom: 0; font-size: 1.1rem;" data-translate="stops-map-sub">Encuentra la parada de taxi más cercana a tu ubicación en Cádiz.</p>
    </div>

    <!-- Sticky Map Wrapper (dejamos 85px para el zócalo inferior cadizcab) -->
    <div style="position: sticky; top: 0; height: calc(100dvh - 85px); width: 100%; overflow: hidden;">
        <taxi-map style="width: 100%; height: 100%; display: block;"></taxi-map>
    </div>
</section>

<link rel="stylesheet" href="/widget/taxi-map.css">
<script type="module" src="/widget/taxi-map.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const section = document.getElementById('paradas');
        const stickyWrapper = section ? section.querySelector('div[style*="position: sticky"]') : null;
        let scrollTimeout;

        if (!stickyWrapper) return;

        window.addEventListener('scroll', () => {
            // Clear the timeout while the user is still actively scrolling
            clearTimeout(scrollTimeout);

            // Wait 150ms after the user stops scrolling
            scrollTimeout = setTimeout(() => {
                const rect = stickyWrapper.getBoundingClientRect();
                
                // If the sticky wrapper is visible by at least 50% (its top is in the upper half of the screen)
                // but it's not perfectly at the top yet (rect.top > 5)
                if (rect.top > 5 && rect.top < window.innerHeight * 0.5) {
                    const targetY = window.scrollY + rect.top;
                    
                    // Smoothly snap to make the map 100% full screen
                    window.scrollTo({
                        top: targetY,
                        behavior: 'smooth'
                    });
                }
            }, 150);
        }, { passive: true });
    });
</script>