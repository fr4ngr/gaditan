---
<section id="paradas" style="height: 200vh; position: relative; display: block;">
    <!-- Text above the map -->
    <div class="container" style="padding-top: 1.5rem; padding-bottom: 1rem; z-index: 10;">
        <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; color: #ffffff; margin-bottom: 0.2rem;">
            <span data-translate="map-title">Mapa de Paradas</span>
        </h2>
        <p class="section-subtitle" style="text-align: center; color: var(--text-muted); margin-bottom: 0; font-size: 1.1rem;" data-translate="stops-map-sub">Encuentra la parada de taxi más cercana a tu ubicación en Cádiz.</p>
    </div>

    <!-- Sticky Map Wrapper -->
    <div style="position: sticky; top: 0; height: 100vh; width: 100%; overflow: hidden;">
        <taxi-map style="width: 100%; height: 100%; display: block;"></taxi-map>
    </div>
</section>

<link rel="stylesheet" href="/widget/taxi-map.css">
<script type="module" src="/widget/taxi-map.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const section = document.getElementById('paradas');
        let hasSnapped = false;
        let lastScrollY = window.scrollY;

        // Auto-scroll (snap) to map when it becomes at least 50% visible
        window.addEventListener('scroll', () => {
            const currentScrollY = window.scrollY;
            const scrollingDown = currentScrollY > lastScrollY;
            lastScrollY = currentScrollY;

            if (!section) return;
            
            const rect = section.getBoundingClientRect();
            const threshold = window.innerHeight * 0.5;
            
            // If scrolling down, and the section top enters the upper 50% of the screen
            if (scrollingDown && rect.top > 0 && rect.top < threshold && !hasSnapped) {
                hasSnapped = true;
                
                // Smooth scroll so the section aligns perfectly to the top of the screen (100% visible)
                window.scrollTo({
                    top: currentScrollY + rect.top,
                    behavior: 'smooth'
                });
                
                // Reset snap flag after a delay to allow the user to scroll away freely
                setTimeout(() => {
                    hasSnapped = false;
                }, 1500);
            }
            
            // Also reset flag if we scrolled back above the section completely
            if (rect.top > window.innerHeight) {
                hasSnapped = false;
            }
        }, { passive: true });
    });
</script>