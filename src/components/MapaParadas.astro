---
---
<section id="paradas" style="height: 200vh; position: relative;">
    <div style="position: sticky; top: 0; height: 100vh; width: 100%; overflow: hidden; display: flex; flex-direction: column;">
        
        <!-- Text overlay on top of the map -->
        <div style="position: absolute; top: 0; left: 0; width: 100%; z-index: 1000; padding: 2rem 1rem 4rem 1rem; background: linear-gradient(to bottom, rgba(15,23,42,0.9) 0%, rgba(15,23,42,0.6) 40%, transparent 100%); pointer-events: none;">
            <div class="container" style="pointer-events: auto;">
                <h2 class="section-title" style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; color: #ffffff; margin-bottom: 0.5rem; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
                    <span data-translate="map-title">Mapa de Paradas</span>
                </h2>
                <p class="section-subtitle" style="text-align: center; color: rgba(255,255,255,0.9); margin-bottom: 0; font-size: 1.1rem; text-shadow: 0 1px 5px rgba(0,0,0,0.5);" data-translate="stops-map-sub">Encuentra la parada de taxi más cercana a tu ubicación en Cádiz.</p>
            </div>
        </div>

        <taxi-map style="flex: 1; height: 100%; width: 100%; display: block;"></taxi-map>
    </div>
</section>

<link rel="stylesheet" href="/widget/taxi-map.css">
<script type="module" src="/widget/taxi-map.js"></script>