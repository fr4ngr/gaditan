---
import ChatLayout from '../layouts/ChatLayout.astro';
---

<ChatLayout title="Cádiz Plus | Asistente de Movilidad">
    
    <!-- El contenedor de mensajes está vacío inicialmente, se llena con JS -->
    <div id="chat-messages-container" style="display: contents;">
        <!-- Los mensajes se inyectarán aquí -->
    </div>

</ChatLayout>

<style is:global>
    /* Estilos para las Tarjetas Generativas (Generative UI) */
    .ai-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        overflow: hidden;
        margin-top: 5px;
        max-width: 100%;
        animation: slideIn 0.3s ease-out;
    }
    .card-header {
        padding: 12px 16px;
        font-weight: 600;
        font-size: 0.95rem;
        border-bottom: 1px solid #eee;
    }
    .price-card .card-header { background: #e3f2fd; color: #1565c0; }
    .rule-card .card-header { background: #fff3e0; color: #e65100; }
    .contact-card .card-header { background: #e8f5e9; color: #2e7d32; }
    .map-card .card-header { background: #f3e5f5; color: #6a1b9a; }
    
    .card-body {
        padding: 16px;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #333;
    }
    .price-estimate {
        font-size: 2rem;
        font-weight: 700;
        color: #1565c0;
        text-align: center;
        margin: 10px 0;
    }
    .route-details {
        font-size: 0.85rem;
        color: #666;
        text-align: center;
        background: #f5f5f5;
        padding: 8px;
        border-radius: 8px;
    }
    .law-source {
        margin-top: 12px;
        font-size: 0.8rem;
        color: #666;
        font-style: italic;
        border-left: 3px solid #ffb74d;
        padding-left: 8px;
    }
    .phone-number {
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        letter-spacing: 1px;
        margin: 10px 0;
    }
    .ai-card .call-btn {
        display: block;
        width: 100%;
        padding: 14px;
        text-align: center;
        background: #007bff;
        color: white;
        text-decoration: none;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background 0.2s;
    }
    .ai-card .call-btn:hover { background: #0056b3; }
    .contact-card .call-btn { background: #2e7d32; }
    .contact-card .call-btn:hover { background: #1b5e20; }
    
    .map-container {
        width: 100%;
        height: 250px;
        border-radius: 0 0 16px 16px;
        overflow: hidden;
        margin-top: 10px;
    }
    .map-container iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
    
    @keyframes slideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    // --- ESTADO DEL CHAT ---
    const messagesContainer = document.getElementById('messages-container');
    const inputField = document.querySelector('.chat-input') as HTMLInputElement;
    const sendButton = document.querySelector('.send-button');
    let chatHistory: any[] = [];

    // --- RENDERIZADO BÁSICO ---
    function scrollToBottom() {
        if (messagesContainer) {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
    }

    function addMessage(sender: 'user' | 'bot', htmlContent: string) {
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}`;
        messageDiv.innerHTML = `${htmlContent}<span class="message-time">${time}</span>`;
        messagesContainer?.appendChild(messageDiv);
        scrollToBottom();
    }

    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const div = document.createElement('div');
        div.className = 'message bot';
        div.id = id;
        div.innerHTML = `
            <div class="bubble typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        messagesContainer?.appendChild(div);
        scrollToBottom();
        return id;
    }

    function removeTypingIndicator(id: string) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // --- GENERATIVE UI ENGINE (TARJETAS) ---
    function renderCard(data: any, msgId: string): string {
        if (data.cardType === 'PriceCard') {
            return `
            <div class="ai-card price-card">
                <div class="card-header">🧮 Estimación de Precio</div>
                <div class="card-body">
                    <p>${data.content}</p>
                    ${data.priceEstimate ? `<div class="price-estimate">${data.priceEstimate}</div>` : ''}
                    ${data.routeDetails ? `<div class="route-details">${data.routeDetails}</div>` : ''}
                </div>
                <button class="call-btn" onclick="window.sendToAI('Quiero pedir un taxi ahora')">🚕 Llamar Taxi Ahora</button>
            </div>`;
        }
        if (data.cardType === 'RuleCard') {
            return `
            <div class="ai-card rule-card">
                <div class="card-header">⚖️ Normativa Oficial</div>
                <div class="card-body">
                    <p>${data.content}</p>
                    ${data.lawSource ? `<div class="law-source">📚 Fuente: ${data.lawSource}</div>` : ''}
                </div>
            </div>`;
        }
        if (data.cardType === 'ContactCard') {
            const phone = data.phoneNumber || '956 21 21 21';
            const cleanPhone = phone.replace(/[^0-9+]/g, '');
            return `
            <div class="ai-card contact-card">
                <div class="card-header">📞 Contacto Directo</div>
                <div class="card-body">
                    <p>${data.content}</p>
                    <div class="phone-number">${phone}</div>
                </div>
                <a href="tel:${cleanPhone}" class="call-btn">Llamar Ahora</a>
            </div>`;
        }
        if (data.cardType === 'MapCard') {
            return `
            <div class="ai-card map-card" id="map-card-${msgId}">
                <div class="card-header">📍 Ubicación de la Parada</div>
                <div class="card-body">
                    <p><strong>${data.stopName || 'Parada oficial'}</strong></p>
                    <p>${data.content}</p>
                    ${data.lat && data.lon ? `
                    <button class="call-btn expand-map-btn" style="display: none; background: #6a1b9a;" onclick="window.openMapPanel('${data.lat}', '${data.lon}', '${msgId}')">🗺️ Ver en Pantalla Grande</button>
                    <div class="map-container" id="map-container-${msgId}" style="display: none;"></div>
                    ` : ''}
                </div>
            </div>`;
        }
        if (data.cardType === 'NavigationCard') {
            return `
            <div class="ai-card map-card" id="map-card-${msgId}">
                <div class="card-header">🗺️ Ruta en Vivo</div>
                <div class="card-body">
                    <p><strong>Ruta hacia: ${data.stopName || 'Destino'}</strong></p>
                    <p>${data.content}</p>
                    ${data.lat && data.lon ? `
                    <button class="call-btn expand-map-btn" style="display: none; background: #1565c0;" onclick="window.openMapPanel('${data.lat}', '${data.lon}', '${msgId}', true)">🛣️ Ver Ruta Completa</button>
                    <div class="map-container" id="map-container-${msgId}" style="display: none;"></div>
                    ` : ''}
                </div>
            </div>`;
        }
        // Fallback para TextCard o desconocidos
        return `<span class="bubble">${data.content}</span>`;
    }

    // --- CONEXIÓN CON EL CEREBRO DE IA ---
    async function sendMessageToAI(text: string) {
        if (!text.trim()) return;
        
        // 1. Pintar mensaje del usuario y guardarlo en historial
        addMessage('user', `<span class="bubble">${text}</span>`);
        chatHistory.push({ role: 'user', parts: [{ text }] });
        inputField.value = '';

        // 2. Mostrar "Pensando..."
        const typingId = showTypingIndicator();

        try {
            // 3. Llamar al API Endpoint de Astro (SSR)
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, history: chatHistory })
            });

            const data = await response.json();
            removeTypingIndicator(typingId);

            if (data.error) {
                addMessage('bot', `<span class="bubble" style="background:#ffebee; color:#c62828;">Error del servidor: ${data.error}</span>`);
                chatHistory.pop(); // Remove failed user message from history
                return;
            }

            // Guardar respuesta del bot en el historial (como JSON string para que el modelo lo lea)
            chatHistory.push({ role: 'model', parts: [{ text: JSON.stringify(data) }] });

            // 4. Renderizar la Tarjeta generada por la IA
            const msgId = Date.now().toString();
            const cardHtml = renderCard(data, msgId);
            addMessage('bot', cardHtml);

            // 5. Manejar Split-Screen automáticamente
            if ((data.cardType === 'MapCard' || data.cardType === 'NavigationCard') && data.lat && data.lon) {
                const isRouting = data.cardType === 'NavigationCard';
                window.openMapPanel(data.lat, data.lon, msgId, isRouting);
            }

        } catch (error) {
            removeTypingIndicator(typingId);
            addMessage('bot', `<span class="bubble" style="background:#ffebee; color:#c62828;">Error de conexión. Inténtalo de nuevo.</span>`);
        }
    }

    // --- LÓGICA DE PANTALLA DIVIDIDA Y LEAFLET ---
    let currentMap: any = null;
    let routingControl: any = null;

    window.openMapPanel = function(lat: string, lon: string, msgId: string, routing = false) {
        const topPanel = document.getElementById('top-panel');
        if (!topPanel) return;
        
        // Limpiar el contenedor de la burbuja por si tenía el iframe/mapa
        const container = document.getElementById(`map-container-${msgId}`);
        if (container) {
            container.style.display = 'none';
            container.innerHTML = '';
        }
        const expandBtn = document.querySelector(`#map-card-${msgId} .expand-map-btn`) as HTMLElement;
        if (expandBtn) expandBtn.style.display = 'none';

        // Preparar panel superior
        topPanel.innerHTML = `
            <button class="close-panel-btn" onclick="window.closeMapPanel('${lat}', '${lon}', '${msgId}', ${routing})">✕</button>
            ${routing ? `<button id="dev-mock-btn" style="position:absolute; top:10px; left:50px; z-index:1000; padding:5px 10px; background:#d32f2f; color:white; font-size:12px; font-weight:bold; border:none; border-radius:4px; cursor:pointer; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">BOTÓN DESARROLLO: Fake GPS</button>` : ''}
            <div id="leaflet-map-large" style="width:100%; height:100%;"></div>
        `;
        topPanel.classList.remove('closed');
        
        setTimeout(() => {
            if (currentMap) currentMap.remove();
            
            // Inicializar Leaflet (usar L)
            const mapL = (window as any).L;
            currentMap = mapL.map('leaflet-map-large').setView([lat, lon], 16);
            mapL.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '© OpenStreetMap, © CartoDB',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(currentMap);
            
            const destMarker = mapL.marker([lat, lon]).addTo(currentMap)
                .bindPopup('Destino')
                .openPopup();

            if (routing) {
                const startRouting = (userLat: number, userLon: number, isFake = false) => {
                    if (routingControl) {
                        currentMap.removeControl(routingControl);
                    }
                    routingControl = mapL.Routing.control({
                        waypoints: [
                            mapL.latLng(userLat, userLon),
                            mapL.latLng(lat, lon)
                        ],
                        routeWhileDragging: false,
                        language: 'es',
                        showAlternatives: false,
                        createMarker: function() { return null; }
                    }).addTo(currentMap);
                    
                    const label = isFake ? 'Ubicación simulada' : 'Tu ubicación';
                    mapL.circleMarker([userLat, userLon], { radius: 8, color: isFake ? '#d32f2f' : '#3b82f6', fillOpacity: 0.8 }).addTo(currentMap).bindPopup(label).openPopup();
                };

                // Lógica Botón de Desarrollo
                const devBtn = document.getElementById('dev-mock-btn');
                if (devBtn) {
                    let isDevModeActive = false;
                    devBtn.addEventListener('click', () => {
                        isDevModeActive = true;
                        devBtn.style.background = '#388e3c';
                        devBtn.innerText = 'HAZ CLIC EN EL MAPA';
                    });

                    currentMap.on('click', (e: any) => {
                        if (isDevModeActive) {
                            startRouting(e.latlng.lat, e.latlng.lng, true);
                            isDevModeActive = false;
                            devBtn.style.background = '#d32f2f';
                            devBtn.innerText = 'BOTÓN DESARROLLO: Fake GPS';
                        }
                    });
                }

                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(
                        (position) => {
                            // Solo iniciar ruta real si no hay un control ya (por si el dev se adelantó)
                            if (!routingControl) {
                                startRouting(position.coords.latitude, position.coords.longitude);
                            }
                        },
                        (error) => {
                            console.error("Error obteniendo ubicación:", error);
                        }
                    );
                }
            }

            scrollToBottom();
        }, 300);
    };

    window.closeMapPanel = function(lat: string, lon: string, msgId: string, routing = false) {
        const topPanel = document.getElementById('top-panel');
        if (!topPanel) return;

        topPanel.classList.add('closed');
        setTimeout(() => {
            if (currentMap) {
                currentMap.remove();
                currentMap = null;
            }
            if (routingControl) {
                routingControl = null;
            }
            topPanel.innerHTML = '';
            
            // Transportar el mapa a la burbuja del chat
            const container = document.getElementById(`map-container-${msgId}`);
            if (container) {
                container.style.display = 'block';
                container.innerHTML = `<div id="leaflet-map-small-${msgId}" style="width:100%; height:100%;"></div>`;
                
                // Reinicializar un mini-mapa estático en la burbuja
                const mapL = (window as any).L;
                const miniMap = mapL.map(`leaflet-map-small-${msgId}`, {
                    zoomControl: false,
                    dragging: false,
                    scrollWheelZoom: false
                }).setView([lat, lon], 15);
                
                mapL.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(miniMap);
                mapL.marker([lat, lon]).addTo(miniMap);
            }
            
            // Mostrar botón para volver a expandir
            const expandBtn = document.querySelector(`#map-card-${msgId} .expand-map-btn`) as HTMLElement;
            if (expandBtn) expandBtn.style.display = 'block';
            
            scrollToBottom();
        }, 300); // Esperar a que termine la animación
    };

    // Exponer función global para botones internos de las tarjetas
    window.sendToAI = sendMessageToAI;

    // --- EVENT LISTENERS ---
    sendButton?.addEventListener('click', () => {
        sendMessageToAI(inputField.value);
    });

    inputField?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            sendMessageToAI(inputField.value);
        }
    });

    // --- INICIALIZACIÓN (MOMENTO 0) ---
    setTimeout(() => {
        const welcomeHtml = `
            <span class="bubble">¡Hola! 👋 Soy Cádiz Plus, tu asistente dotado de Inteligencia Artificial. Conozco toda la normativa de taxis de Cádiz al dedillo. ¿En qué puedo ayudarte?</span>
            <div class="action-chips">
                <button class="chip" onclick="window.sendToAI('Quiero calcular un viaje')">🧮 Calcular Viaje</button>
                <button class="chip" onclick="window.sendToAI('¿Cuánto cobran por maleta?')">🎒 Info Equipaje</button>
                <button class="chip" onclick="window.sendToAI('Voy en silla de ruedas')">♿ Movilidad</button>
            </div>
        `;
        addMessage('bot', welcomeHtml);
    }, 500);

    // Tipado global
    declare global {
        interface Window {
            sendToAI: (text: string) => void;
            openMapPanel: (lat: string, lon: string, msgId: string, routing?: boolean) => void;
            closeMapPanel: (lat: string, lon: string, msgId: string, routing?: boolean) => void;
            L: any;
        }
    }
</script>
