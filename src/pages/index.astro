---
import ChatLayout from '../layouts/ChatLayout.astro';
---

<ChatLayout title="Cádiz Plus | Asistente de Movilidad">
    
    <!-- El contenedor de mensajes está vacío inicialmente, se llena con JS -->
    <div id="chat-messages-container" style="display: contents;">
        <!-- Los mensajes se inyectarán aquí -->
    </div>

</ChatLayout>

<style is:global>
    /* Estilos para las Tarjetas Generativas (Generative UI) */
    .ai-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #e0e0e0;
        overflow: hidden;
        margin-top: 5px;
        max-width: 100%;
        animation: slideIn 0.3s ease-out;
    }
    .card-header {
        padding: 12px 16px;
        font-weight: 600;
        font-size: 0.95rem;
        border-bottom: 1px solid #eee;
    }
    .price-card .card-header { background: #e3f2fd; color: #1565c0; }
    .rule-card .card-header { background: #fff3e0; color: #e65100; }
    .contact-card .card-header { background: #e5f8eb; color: #20873c; }
    .map-card .card-header { background: #f3e5f5; color: #6a1b9a; }
    
    .card-body {
        padding: 16px;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #333;
    }
    .price-estimate {
        font-size: 2rem;
        font-weight: 700;
        color: #1565c0;
        text-align: center;
        margin: 10px 0;
    }
    .route-details {
        font-size: 0.85rem;
        color: #666;
        text-align: center;
        background: #f5f5f5;
        padding: 8px;
        border-radius: 8px;
    }
    .law-source {
        margin-top: 12px;
        font-size: 0.8rem;
        color: #666;
        font-style: italic;
        border-left: 3px solid #ffb74d;
        padding-left: 8px;
    }
    .phone-number {
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        letter-spacing: 1px;
        margin: 10px 0;
    }
    .ai-card .call-btn {
        display: block;
        width: 100%;
        padding: 14px;
        text-align: center;
        background: #007bff;
        color: white;
        text-decoration: none;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background 0.2s;
    }
    .ai-card .call-btn:hover { background: #0056b3; }
    .contact-card .call-btn { background: var(--primary-color); }
    .contact-card .call-btn:hover { filter: brightness(0.9); }
    
    @media (max-width: 600px) {
        .contact-card .call-btn, .contact-card .wa-btn {
            border-radius: 50% !important;
            padding: 10px !important;
            width: 46px !important;
            height: 46px !important;
            justify-content: center;
        }
        .contact-card .call-btn svg, .contact-card .wa-btn svg {
            width: 24px !important;
            height: 24px !important;
        }
        .contact-card .btn-text {
            display: none;
        }
    }
    
    .map-container {
        width: 100%;
        height: 250px;
        border-radius: 0 0 16px 16px;
        overflow: hidden;
        margin-top: 10px;
    }
    .map-container iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
    
    @keyframes slideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    // --- ESTADO DEL CHAT ---
    const messagesContainer = document.getElementById('messages-container');
    const inputField = document.querySelector('.chat-input') as HTMLInputElement;
    const sendButton = document.querySelector('.send-button');
    let chatHistory: any[] = [];

    // --- RENDERIZADO BÁSICO ---
    function scrollToBottom() {
        if (messagesContainer) {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
    }

    function addMessage(sender: 'user' | 'bot', htmlContent: string) {
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}`;
        
        let saveBtnHTML = '';
        if (sender === 'bot') {
            const rawContent = encodeURIComponent(htmlContent);
            saveBtnHTML = `<button class="save-msg-btn" onclick="window.saveMessage(this, '${rawContent}')" aria-label="Guardar">🔖</button>`;
        }
        
        messageDiv.innerHTML = `${htmlContent}<div class="message-meta">${saveBtnHTML}<span class="message-time">${time}</span></div>`;
        messagesContainer?.appendChild(messageDiv);
        scrollToBottom();
    }

    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const div = document.createElement('div');
        div.className = 'message bot';
        div.id = id;
        div.innerHTML = `
            <div class="bubble typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        messagesContainer?.appendChild(div);
        scrollToBottom();
        return id;
    }

    function removeTypingIndicator(id: string) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // --- GENERATIVE UI ENGINE (TARJETAS) ---
    function renderCard(data: any, msgId: string): string {
        if (data.cardType === 'PriceCard') {
            return `
            <div class="ai-card price-card">
                <div class="card-header">🧮 Estimación de Precio</div>
                <div class="card-body">
                    <p>${data.content}</p>
                    ${data.priceEstimate ? `<div class="price-estimate">${data.priceEstimate}</div>` : ''}
                    ${data.routeDetails ? `<div class="route-details">${data.routeDetails}</div>` : ''}
                </div>
                <button class="call-btn" onclick="window.sendToAI('Quiero pedir un taxi ahora')">🚕 Llamar Taxi Ahora</button>
            </div>`;
        }
        if (data.cardType === 'RuleCard') {
            return `
            <div class="ai-card rule-card">
                <div class="card-header">⚖️ Normativa Oficial</div>
                <div class="card-body">
                    <p>${data.content}</p>
                    ${data.lawSource ? `<div class="law-source">📚 Fuente: ${data.lawSource}</div>` : ''}
                </div>
            </div>`;
        }
        if (data.cardType === 'ContactCard') {
            return `
            <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                <span class="bubble" style="border-bottom-left-radius: 4px;">${data.content}</span>
                <div class="info-card contact-card">
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <span style="font-weight: 600; color: #333;">RadioTaxi Cádiz</span>
                        <div style="display: flex; gap: 8px;">
                            <a href="tel:956212121" class="call-btn" style="text-decoration: none; width: auto; padding: 8px 12px; margin: 0; display: flex; align-items: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.28-.28.67-.36 1.02-.25 1.12.37 2.32.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg> <span class="btn-text">Llamar</span></a>
                            <a href="https://wa.me/34956212121" class="wa-btn" target="_blank" rel="noopener noreferrer" style="background: #25D366; color: white; border-radius: 8px; font-weight: 600; text-decoration: none; width: auto; padding: 8px 12px; margin: 0; display: flex; align-items: center; gap: 6px; transition: opacity 0.2s;" onmouseover="this.style.opacity=0.8" onmouseout="this.style.opacity=1"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg> <span class="btn-text">WhatsApp</span></a>
                        </div>
                    </div>
                </div>
                <span class="bubble" style="border-top-left-radius: 4px; margin-top: 4px;">Si quieres, te puedo mostrar las tarifas actuales, ayudar a calcular el coste aproximado de tu viaje o encontrar tu parada más cercana. ¿Por dónde seguimos?</span>
            </div>`;
        }
        if (data.cardType === 'ReservationCard') {
            const email = "reservas@cadiz.taxi";
            const subject = encodeURIComponent("Reserva de Taxi");
            const body = encodeURIComponent("Hola, me gustaría reservar un taxi.\n\nMis datos:\n- Fecha y Hora:\n- Dirección de origen:\n- Dirección de destino:\n- Necesidades especiales (silla bebé, maletas grandes...):\n");
            
            return `
            <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                <span class="bubble" style="border-bottom-left-radius: 4px;">${data.content}</span>
                <div class="info-card" style="background: linear-gradient(135deg, #eff6ff, #dbeafe); border: 1px solid #bfdbfe; padding: 15px; border-radius: 12px;">
                    <div style="display: flex; flex-direction: column; gap: 10px; align-items: center; text-align: center;">
                        <span style="font-size: 2rem;">📅</span>
                        <h3 style="margin: 0; color: #1565c0; font-size: 1.1rem;">Reserva tu Taxi</h3>
                        <p style="margin: 0; font-size: 0.9rem; color: #555;">Haz tu reserva con antelación enviándonos un email con los detalles de tu viaje.</p>
                        <a href="mailto:${email}?subject=${subject}&body=${body}" class="call-btn" style="text-decoration: none; width: 100%; padding: 12px; margin-top: 5px; font-size: 1rem;">✉️ Enviar Email de Reserva</a>
                    </div>
                </div>
            </div>`;
        }
        if (data.cardType === 'MapCard') {
            return `
            <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%; max-width: 100%; align-self: flex-start;">
                <span class="bubble">${data.content}</span>
                <button class="call-btn" style="background: #e3f2fd; color: #1565c0; font-size: 0.95rem; display: flex; align-items: center; justify-content: center; gap: 8px; border-radius: 20px; border: 1px solid #bbdefb;" onclick="window.openFullscreenMap(${data.lat ? `'${data.lat}', '${data.lon}', '${msgId}'` : `null, null, '${msgId}'`})">
                    <span>📍</span> Abrir Mapa Interactivo
                </button>
            </div>`;
        }
        if (data.cardType === 'NavigationCard') {
            return `
            <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%; max-width: 85%; align-self: flex-start;">
                <span class="bubble">${data.content}</span>
                ${data.lat && data.lon ? `
                <div style="border-radius: 18px; overflow: hidden; width: 100%; box-shadow: 0 2px 5px rgba(0,0,0,0.1); background: white; padding: 10px; display: flex; flex-direction: column; gap: 10px;">
                    <div style="font-weight: 600; text-align: center; color: var(--text-primary);">📍 Destino: ${data.stopName || 'Parada Seleccionada'}</div>
                    <button class="call-btn" style="background: var(--primary-color); margin: 0; display: flex; align-items: center; justify-content: center; gap: 8px;" onclick="window.startLiveNavigation('${data.lat}', '${data.lon}', '${data.stopName || 'Destino'}')">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z" fill="currentColor"/>
                        </svg>
                        Iniciar Navegación
                    </button>
                </div>
                ` : ''}
            </div>`;
        }
        if (data.cardType === 'TextCard') {
            return `<span class="bubble">${data.content}</span>`;
        }

        if (data.cardType === 'TariffCard') {
            return `
            <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                <span class="bubble" style="border-bottom-left-radius: 4px;">${data.content}</span>
                <div class="tariff-card" id="tariff-widget-${msgId}">
                    <!-- Fila 1: Pestañas Principales -->
                    <div class="tariff-tabs-row1">
                        <button class="t-tab active" onclick="window.changeTariffTab('${msgId}', 'urbana')">Urbana</button>
                        <button class="t-tab" onclick="window.changeTariffTab('${msgId}', 'interurbana')">Interurbana</button>
                        <button class="t-tab" onclick="window.changeTariffTab('${msgId}', 'suplementos')">Suplementos</button>
                    </div>
                    
                    <!-- Fila 2: Sub-pestañas de Tiempo (Solo Urbana/Interurbana) -->
                    <div class="tariff-tabs-row2" id="row2-${msgId}">
                        <button class="t-subtab active" onclick="window.changeTariffTime('${msgId}', 'dia')">Día</button>
                        <button class="t-subtab" onclick="window.changeTariffTime('${msgId}', 'noche')">Noche</button>
                        <button class="t-subtab" onclick="window.changeTariffTime('${msgId}', 'finde')">Fin de semana</button>
                        <button class="t-subtab" onclick="window.changeTariffTime('${msgId}', 'festivo')">Festivo</button>
                    </div>

                    <!-- Fila 3: Tabla de Precios -->
                    <div class="tariff-body" id="tbody-${msgId}">
                        <!-- Renderizado dinámico aquí -->
                    </div>
                </div>
                <span class="bubble" style="border-top-left-radius: 4px; margin-top: 4px;">Si quieres, te puedo ayudar a usar estos precios oficiales para calcular el coste aproximado de tu viaje. ¿Probamos?</span>
            </div>`;
        }

        // Fallback para desconocidos
        return `<span class="bubble">${data.content}</span>`;
    }

    // --- CONEXIÓN CON EL CEREBRO DE IA ---
    async function sendMessageToAI(text: string) {
        if (!text.trim()) return;
        
        // 1. Pintar mensaje del usuario y guardarlo en historial
        addMessage('user', `<span class="bubble">${text}</span>`);
        chatHistory.push({ role: 'user', parts: [{ text }] });
        inputField.value = '';

        // 2. Mostrar "Pensando..."
        const typingId = showTypingIndicator();

        try {
            // 3. Llamar al API Endpoint de Astro (SSR)
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text, history: chatHistory })
            });

            const data = await response.json();
            removeTypingIndicator(typingId);

            if (data.error) {
                let errorMsg = typeof data.error === 'string' ? data.error : JSON.stringify(data.error);
                if (errorMsg.includes('503') || errorMsg.includes('high demand') || errorMsg.includes('demasiada gente')) {
                    errorMsg = "Servidores de Inteligencia Artificial saturados temporalmente. Por favor, inténtalo de nuevo en unos segundos.";
                }
                
                const safeText = text.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                addMessage('bot', `
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <span class="bubble" style="background:#ffebee; color:#c62828;">⚠️ ${errorMsg}</span>
                        <button class="call-btn" style="background: #c62828; margin: 0; align-self: flex-start; padding: 6px 12px; font-size: 0.85rem;" onclick="window.sendToAI('${safeText}')">🔄 Reintentar</button>
                    </div>
                `);
                
                chatHistory.pop(); // Remove failed user message from history
                return;
            }

            // Guardar respuesta del bot en el historial (como JSON string para que el modelo lo lea)
            chatHistory.push({ role: 'model', parts: [{ text: JSON.stringify(data) }] });

            // 4. Renderizar la Tarjeta generada por la IA
            const msgId = Date.now().toString();
            let finalHtml = renderCard(data, msgId);

            // Renderizar Suggested Blocks (Botones)
            if (data.suggestedBlocks && data.suggestedBlocks.length > 0) {
                const buttonsHtml = data.suggestedBlocks.map((block: string) => {
                    return `<button class="suggested-btn" onclick="window.sendToAI('${block}')">${block}</button>`;
                }).join('');
                finalHtml += `<div class="suggested-blocks-container">${buttonsHtml}</div>`;
            }
            
            addMessage('bot', finalHtml);

            // Inicializar Widget de Tarifas si corresponde
            if (data.cardType === 'TariffCard') {
                setTimeout(() => {
                    if (window.changeTariffTab) {
                        // Determinar periodo actual
                        const now = new Date();
                        const day = now.getDay(); // 0=Dom, 1=Lun, ..., 6=Sab
                        const hour = now.getHours();
                        let currentTime = 'dia';

                        if (day === 0 || day === 6) {
                            currentTime = 'finde';
                        } else if (hour >= 21 || hour < 7) {
                            currentTime = 'noche';
                        }
                        
                        window.changeTariffTab(msgId, 'urbana', currentTime);
                    }
                }, 10);
            }

            // 5. Instanciar el mapa en línea o activar navegación
            if (data.cardType === 'NavigationCard' && data.lat && data.lon) {
                setTimeout(() => {
                    window.startLiveNavigation(data.lat, data.lon, data.stopName || 'Destino');
                }, 800); // Dar un poco de tiempo para leer el mensaje antes de abrir a pantalla completa
            }

        } catch (error) {
            removeTypingIndicator(typingId);
            addMessage('bot', `<span class="bubble" style="background:#ffebee; color:#c62828;">Error de conexión. Inténtalo de nuevo.</span>`);
        }
    }

    window.openFullscreenMap = function(lat: string | null, lon: string | null, msgId: string) {
        // Deslizar al panel derecho
        const swiper = document.getElementById('main-swiper');
        if (swiper) swiper.scrollTo({ left: window.innerWidth * 2, behavior: 'smooth' });

        const container = document.getElementById('fullscreen-widget-area');
        if (!container) return;

        // Limpiar contenedor e inyectar el div del mapa
        container.innerHTML = `<div id="fullscreen-leaflet-${msgId}" style="width: 100%; height: 100%;"></div>`;

        setTimeout(() => {
            const mapL = (window as any).L;
            const map = mapL.map(`fullscreen-leaflet-${msgId}`, { zoomControl: false });
            mapL.control.zoom({ position: 'bottomright' }).addTo(map);
            
            mapL.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '© OpenStreetMap, © CartoDB', subdomains: 'abcd', maxZoom: 20
            }).addTo(map);

            if (lat && lon) {
                map.setView([lat, lon], 16);
                mapL.marker([lat, lon]).addTo(map).bindPopup('Destino').openPopup();
            } else {
                map.setView([36.516, -6.283], 13);
                const taxiIcon = mapL.divIcon({
                    html: '<div style="background:#20873c; color:white; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; border:2px solid white; box-shadow:0 2px 5px rgba(0,0,0,0.3);">📍</div>',
                    className: '', iconSize: [24, 24], iconAnchor: [12, 12]
                });
                CADIZ_STOPS.forEach(stop => {
                    mapL.marker([stop.lat, stop.lon], {icon: taxiIcon}).addTo(map).bindPopup(`<b>${stop.name}</b>`);
                });
            }
            // Forzar resize para que Leaflet dibuje bien en el nuevo panel
            setTimeout(() => map.invalidateSize(), 300);
        }, 100);
    };

    // --- LÓGICA DE GUARDADOS (LOCALSTORAGE) ---
    window.saveMessage = function(btn: HTMLElement, encodedHtml: string) {
        const html = decodeURIComponent(encodedHtml);
        let saved = JSON.parse(localStorage.getItem('cadiz_saved_messages') || '[]');
        
        // Comprobar si ya existe para quitarlo (toggle)
        const index = saved.indexOf(html);
        if (index > -1) {
            saved.splice(index, 1);
            btn.classList.remove('saved');
        } else {
            saved.push(html);
            btn.classList.add('saved');
        }
        
        localStorage.setItem('cadiz_saved_messages', JSON.stringify(saved));
        window.renderSavedMessages();
    };

    window.renderSavedMessages = function() {
        const container = document.getElementById('saved-messages-container');
        if (!container) return;
        
        const saved = JSON.parse(localStorage.getItem('cadiz_saved_messages') || '[]');
        if (saved.length === 0) {
            container.innerHTML = '<p style="color:var(--text-secondary); text-align:center; margin-top:40px;">No tienes mensajes guardados aún.</p>';
            return;
        }

        container.innerHTML = '';
        // Mostramos de más nuevo a más viejo (invertimos el array)
        [...saved].reverse().forEach((html, i) => {
            const div = document.createElement('div');
            div.className = 'message bot';
            // Añadimos botón para eliminar desde la propia vista de guardados
            const rawContent = encodeURIComponent(html);
            div.innerHTML = `${html}<div class="message-meta"><button class="save-msg-btn saved" onclick="window.saveMessage(this, '${rawContent}')" aria-label="Eliminar">🗑️</button></div>`;
            container.appendChild(div);
        });
    };

    // Cargar guardados al iniciar
    document.addEventListener('DOMContentLoaded', () => {
        window.renderSavedMessages();
    });

    // --- DATOS DEL WIDGET DE TARIFAS ---
    const TARIFF_DATA: Record<string, any> = {
        urbana: {
            dia: [
                { name: 'Bajada de Bandera', price: '1.39 €' },
                { name: 'Precio por Kilómetro', price: '0.70 €' },
                { name: 'Carrera Mínima', price: '3.56 €' },
                { name: 'Hora de Espera', price: '18.95 €' }
            ],
            noche: [
                { name: 'Bajada de Bandera', price: '1.73 €' },
                { name: 'Precio por Kilómetro', price: '0.90 €' },
                { name: 'Carrera Mínima', price: '4.43 €' },
                { name: 'Hora de Espera', price: '23.66 €' }
            ],
