---
import ChatLayout from '../layouts/ChatLayout.astro';
---

<ChatLayout title="Cádiz Plus | Asistente de Movilidad">
    
    <!-- El contenedor de mensajes está vacío inicialmente, se llena con JS -->
    <div id="chat-messages-container" style="display: contents;">
        <!-- Los mensajes se inyectarán aquí -->
    </div>

</ChatLayout>

<script>
    import { chatNodes, taxiKnowledge } from '../data/chatFlows.ts';
    
    // --- ESTADO DEL CHAT ---
    const messagesContainer = document.getElementById('messages-container');
    const inputField = document.querySelector('.chat-input') as HTMLInputElement;
    const sendButton = document.querySelector('.send-button');

    // Máquina de estados para flujos de texto (Calculadora)
    let chatState = 'IDLE'; 
    let calcData = { origen: '', destino: '', maletas: '' };

    // --- RENDERIZADO BÁSICO ---
    function scrollToBottom() {
        if (messagesContainer) {
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
    }

    function addMessage(sender: 'user' | 'bot', text: string, htmlContent: string = '') {
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}`;
        
        let contentHtml = htmlContent ? htmlContent : `<span class="bubble">${text}</span>`;
        messageDiv.innerHTML = `
            ${contentHtml}
            <span class="message-time">${time}</span>
        `;
        
        messagesContainer?.appendChild(messageDiv);
        scrollToBottom();
    }

    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const div = document.createElement('div');
        div.className = 'message bot';
        div.id = id;
        div.innerHTML = `
            <div class="bubble typing-indicator">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        `;
        messagesContainer?.appendChild(div);
        scrollToBottom();
        return id;
    }

    function removeTypingIndicator(id: string) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // --- MOTOR DE ÁRBOL DE DECISIÓN (NODOS) ---
    
    window.handleAction = function(nodeId: string) {
        // 1. Excepción: Iniciar Calculadora
        if (nodeId === 'CALCULADORA_START') {
            const typingId = showTypingIndicator();
            setTimeout(() => {
                removeTypingIndicator(typingId);
                chatState = 'CALC_ORIGEN';
                addMessage('bot', chatNodes['CALCULADORA_START'].text);
                inputField.focus();
                inputField.placeholder = "Ej: Plaza de las Flores";
            }, 600);
            return;
        }

        // 2. Procesamiento Genérico de Nodos
        const node = chatNodes[nodeId];
        if (!node) return;

        // Opcional: Mostrar la elección del usuario (si no es el inicio)
        if (nodeId !== 'HOME') {
            // Buscamos la etiqueta del botón que pulsó para pintarlo como mensaje del usuario
            // Nota: Podríamos pasarlo como parámetro, pero para mantenerlo limpio lo omitimos o simulamos
        }

        const typingId = showTypingIndicator();
        setTimeout(() => {
            removeTypingIndicator(typingId);
            
            // Renderizamos texto e HTML del bot
            if (node.text && node.htmlContent) {
                addMessage('bot', node.text, `<span class="bubble">${node.text}</span>` + node.htmlContent);
            } else if (node.text) {
                addMessage('bot', node.text);
            } else if (node.htmlContent) {
                addMessage('bot', '', node.htmlContent);
            }

            // Renderizamos los botones (Opciones) correspondientes a este nodo
            if (node.options && node.options.length > 0) {
                let chipsHtml = '<div class="action-chips">';
                node.options.forEach(opt => {
                    chipsHtml += `<button class="chip" onclick="window.handleAction('${opt.nextNodeId}')">${opt.label}</button>`;
                });
                chipsHtml += '</div>';
                
                // Un pequeño delay extra para mostrar los botones
                setTimeout(() => addMessage('bot', '', chipsHtml), 300);
            }
        }, 600);
    };

    // --- LÓGICA DE TEXTO LIBRE (CALCULADORA) ---
    function handleUserInput(text: string) {
        if (!text.trim()) return;
        
        addMessage('user', text);
        inputField.value = '';

        const typingId = showTypingIndicator();
        
        setTimeout(() => {
            removeTypingIndicator(typingId);

            if (chatState === 'CALC_ORIGEN') {
                calcData.origen = text;
                chatState = 'CALC_DESTINO';
                addMessage('bot', 'Perfecto. ¿A dónde te diriges?');
                inputField.placeholder = "Ej: Hospital Puerta del Mar";
            } 
            else if (chatState === 'CALC_DESTINO') {
                calcData.destino = text;
                chatState = 'CALC_MALETAS';
                addMessage('bot', '¿Llevas alguna maleta de equipaje en el maletero? (Responde con el número, ej: 0, 1, 2)');
                inputField.type = 'number';
                inputField.placeholder = "Número de maletas";
            }
            else if (chatState === 'CALC_MALETAS') {
                calcData.maletas = text;
                chatState = 'IDLE';
                inputField.type = 'text';
                inputField.placeholder = "Pregunta por un taxi, bus, ruta...";
                
                const numMaletas = parseInt(calcData.maletas) || 0;
                const costeMaletas = numMaletas * taxiKnowledge.suplementos[0].precio;
                const costeViaje = taxiKnowledge.tarifasUrbanas.T1.bajada + (4 * taxiKnowledge.tarifasUrbanas.T1.km) + costeMaletas;
                const precioFinal = Math.max(costeViaje, taxiKnowledge.tarifasUrbanas.T1.minima).toFixed(2);
                
                addMessage('bot', `Resumen: De **${calcData.origen}** a **${calcData.destino}** con ${numMaletas} maletas. \n\nEl precio estimado en Tarifa Diurna (T1) sería de **${precioFinal}€**. \n*(Cálculo oficial de la Junta: Bajada 1,39€ + 0,70€/km + 0,51€/maleta)*`);
                
                setTimeout(() => {
                    const html = `
                        <div class="action-chips">
                            <button class="chip" onclick="window.handleAction('HOME')">⬅️ Volver al Inicio</button>
                        </div>
                    `;
                    addMessage('bot', '', html);
                }, 500);
            }
            else {
                addMessage('bot', 'Por ahora estoy en fase de aprendizaje guiado. Usa el menú de botones para moverte 👆');
            }
        }, 1000);
    }

    // --- EVENT LISTENERS ---
    sendButton?.addEventListener('click', () => {
        handleUserInput(inputField.value);
    });

    inputField?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            handleUserInput(inputField.value);
        }
    });

    // --- INICIALIZACIÓN (MOMENTO 0) ---
    setTimeout(() => {
        window.handleAction('HOME');
    }, 400);

    // Tipado global para window
    declare global {
        interface Window {
            handleAction: (nodeId: string) => void;
        }
    }
</script>
