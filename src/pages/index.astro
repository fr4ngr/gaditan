---
import ChatLayout from '../layouts/ChatLayout.astro';
---

<ChatLayout title="Cádiz Plus | Asistente de Movilidad">
    
    <div class="message bot">
        <span class="bubble">¡Hola! 👋 Soy tu asistente de movilidad y turismo en Cádiz. ¿En qué puedo ayudarte hoy?</span>
        <span class="message-time">10:00</span>
    </div>

    <div class="message user">
        <span class="bubble">Necesito ir a la estación de tren rápido</span>
        <span class="message-time">10:02</span>
    </div>

    <div class="message bot">
        <span class="bubble">La forma más rápida es en taxi. Estás a unos 5 minutos. ¿Quieres que te facilite el número de RadioTaxi?</span>
        <span class="message-time">10:02</span>
    </div>

    <!-- Ejemplo de cómo podríamos inyectar HTML complejo como botones en el futuro -->
    <div class="message bot">
        <div class="bubble" style="display: flex; flex-direction: column; gap: 0.5rem;">
            <span>También puedes consultar los horarios de trenes directamente:</span>
            <button style="background: var(--bg-color); border: 1px solid var(--primary-color); color: var(--primary-color); padding: 0.5rem; border-radius: 0.5rem; cursor: pointer; font-weight: 500;">Ver Horarios Renfe</button>
        </div>
        <span class="message-time">10:03</span>
    </div>

</ChatLayout>
