    // Estado del widget por msgId
    const widgetState: Record<string, { type: string, time: string }> = {};

    window.changeTariffTab = (msgId: string, type: string, forceTime?: string) => {
        if (!widgetState[msgId]) widgetState[msgId] = { type: 'urbana', time: 'dia' };
        widgetState[msgId].type = type;
        if (forceTime) widgetState[msgId].time = forceTime;

        const widget = document.getElementById(`tariff-widget-${msgId}`);
        if (!widget) return;

        // Actualizar visual de pestañas Fila 1
        widget.querySelectorAll('.t-tab').forEach(btn => btn.classList.remove('active'));
        const activeTab = widget.querySelector(`.t-tab[onclick*="'${type}'"]`);
        if (activeTab) activeTab.classList.add('active');

