        const initialBlocks = ['🚕 Pedir taxi', '💶 Tarifas', '📍 Mapa paradas', '⭐ Destinos favoritos', '✈️ Traslados a aeropuertos', '🧮 Calculadora', '📅 Reservas', '❓ Preguntas frecuentes', '🎲 Juegos didácticos'];
        const buttonsHtml = initialBlocks.map(block => {
            return `<button class="suggested-btn" onclick="window.sendToAI('${block}')">${block}</button>`;
        }).join('');
        
        addMessage('bot', `
            <span class="bubble">¡Hola! 👋 Soy tu asistente virtual de Cádiz.<br><br>Tengo acceso a fuentes oficiales en diferentes áreas para ayudarte con cualquier duda sobre la ciudad de Cádiz. Parece que estás buscando información sobre taxis.<br><br>Cuéntame, ¿qué necesitas saber exactamente?</span>
            <div class="suggested-blocks-container" style="margin-top: 8px;">${buttonsHtml}</div>
        `);
    }, 500);

    // Tipado global
    declare global {
        interface Window {
            sendToAI: (text: string) => void;
            initInlineMap: (lat: string, lon: string, msgId: string) => void;
            startLiveNavigation: (lat: string, lon: string, name: string) => void;
            exitLiveNavigation: () => void;
            changeTariffTab: (msgId: string, type: string) => void;
            changeTariffTime: (msgId: string, time: string) => void;
            L: any;
        }
    }
</script>
