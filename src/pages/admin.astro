        };

        window.loadSystemPrompt = async function() {
            document.getElementById('base-context-text').value = 'Cargando personalidad desde GitHub...';
            document.getElementById('system-prompt-date').innerText = '';
            currentRules = [];
            window.renderRuleCards();
            
            try {
                const res = await fetch(`/api/admin/system`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                if (res.ok) {
                    const rawContent = data.content;
                    
                    // Parse Date Header
                    const dateMatch = rawContent.match(/^> \[!NOTE\]\n> \*\*Leyes aplicadas desde:\*\* (.*)\n\n/);
                    let cleanContent = rawContent;
                    if (dateMatch) {
                        document.getElementById('system-prompt-date').innerText = `Última modificación: ${dateMatch[1]}`;
                        cleanContent = rawContent.replace(dateMatch[0], '');
                    }
                    
                    // Parse Rules vs Base Context
                    // Split by "### REGLA X: Title"
                    const ruleRegex = /### REGLA \d+:\s*(.*)\n([\s\S]*?)(?=### REGLA \d+:|$)/g;
                    
                    // Find first rule index to separate base context
                    const firstRuleMatch = /### REGLA 1:/.exec(cleanContent);
                    if (firstRuleMatch) {
                        document.getElementById('base-context-text').value = cleanContent.substring(0, firstRuleMatch.index).trim();
                        
                        let match;
                        while ((match = ruleRegex.exec(cleanContent)) !== null) {
                            currentRules.push({
                                title: match[1].trim(),
                                content: match[2].trim()
                            });
                        }
                    } else {
                        // Legacy or no rules yet
                        document.getElementById('base-context-text').value = cleanContent.trim();
                    }
                    window.renderRuleCards();
                    
                } else {
                    document.getElementById('base-context-text').value = "Error al cargar: " + data.error;
                }
            } catch(e) {
                document.getElementById('base-context-text').value = "Error de red.";
            }
        };

