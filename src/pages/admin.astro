---
import '../styles/chat.css';
import '../styles/components.css';
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Admin - Cádiz Taxi</title>
        <!-- PDF.js para extraer texto de PDFs en el cliente sin saturar el servidor -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
        <script>
            // @ts-ignore
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        </script>
        <style>
            body {
                background: var(--ds-bg-light);
                padding: 2rem 1rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                font-family: system-ui, -apple-system, sans-serif;
            }
            .admin-container {
                max-width: 600px;
                width: 100%;
            }
            .form-group {
                display: flex;
                flex-direction: column;
                gap: 8px;
                margin-bottom: 16px;
            }
            label {
                font-weight: 600;
                color: var(--ds-text-primary);
            }
            input[type="password"], textarea, input[type="file"] {
                padding: 10px;
                border: 1px solid var(--bubble-bot-border);
                border-radius: var(--ds-border-radius-sm);
                font-family: inherit;
                width: 100%;
                box-sizing: border-box;
            }
            textarea {
                min-height: 150px;
                resize: vertical;
            }
            .loader {
                display: none;
                text-align: center;
                margin-top: 10px;
                color: var(--ds-primary);
            }
        </style>
    </head>
    <body>
        <div class="admin-container">
            <div class="card">
                <div class="card-header primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                    <h2>Actualizar Conocimiento (Cerebro IA)</h2>
                </div>
                <div class="card-body">
                    <p class="text-muted">Sube un PDF oficial o pega el texto para actualizar el archivo <code>taxi-knowledge.ts</code>. Los cambios se guardarán en GitHub y la web se redesplegará automáticamente.</p>
                    
                    <form id="admin-form">
                        <div class="form-group">
                            <label for="admin-pwd">Contraseña de Administrador:</label>
                            <input type="password" id="admin-pwd" required placeholder="Contraseña..." />
                        </div>
                        
                        <div class="form-group">
                            <label for="pdf-upload">1. Extraer desde PDF (Opcional):</label>
                            <input type="file" id="pdf-upload" accept="application/pdf" />
                            <small class="text-muted">Selecciona un PDF y su texto se extraerá en la caja de abajo.</small>
                        </div>
                        
                        <div class="form-group">
                            <label for="knowledge-text">2. Texto a inyectar en el bot:</label>
                            <textarea id="knowledge-text" required placeholder="Pega aquí la normativa, precios, etc..."></textarea>
                        </div>

                        <div class="info-pill mb-sm">
                            <span>⚠️ Ten en cuenta que esto reemplazará el contenido anterior de la base de conocimiento en texto libre. Asegúrate de incluir TODO lo importante.</span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" id="submit-btn">
                            <div class="icon-circle"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
                            Actualizar Base de Datos
                        </button>
                        
                        <div class="loader" id="loader">Procesando y guardando en GitHub... Esto puede tardar unos segundos.</div>
                        <div id="result-msg" style="margin-top: 10px; font-weight: 500; text-align: center;"></div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            // --- Lógica de Extracción PDF ---
            document.getElementById('pdf-upload').addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                const textArea = document.getElementById('knowledge-text');
                textArea.value = "Extrayendo texto del PDF... Por favor espera.";
                
                try {
                    const arrayBuffer = await file.arrayBuffer();
                    // @ts-ignore
                    const pdf = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
                    let fullText = "";
                    
                    for (let i = 1; i <= pdf.numPages; i++) {
                        const page = await pdf.getPage(i);
                        const textContent = await page.getTextContent();
                        const pageText = textContent.items.map(item => item.str).join(" ");
                        fullText += pageText + "\\n\\n";
                    }
                    
                    textArea.value = fullText.trim();
                } catch (err) {
                    textArea.value = "Error al extraer PDF: " + err.message;
                    console.error(err);
                }
            });

            // --- Lógica de Envío al API Serverless ---
            document.getElementById('admin-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const pwd = document.getElementById('admin-pwd').value;
                const text = document.getElementById('knowledge-text').value;
                const btn = document.getElementById('submit-btn');
                const loader = document.getElementById('loader');
                const resultMsg = document.getElementById('result-msg');
                
                btn.style.display = 'none';
                loader.style.display = 'block';
                resultMsg.innerText = '';
                
                try {
                    const res = await fetch('/api/admin/upload', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': 'Bearer ' + pwd
                        },
                        body: JSON.stringify({ content: text })
                    });
                    
                    const data = await res.json();
                    if (res.ok) {
                        resultMsg.style.color = 'var(--ds-success)';
                        resultMsg.innerText = "¡Éxito! " + data.message;
                        document.getElementById('knowledge-text').value = '';
                    } else {
                        resultMsg.style.color = 'var(--ds-danger)';
                        resultMsg.innerText = "Error: " + (data.error || 'Desconocido');
                    }
                } catch (err) {
                    resultMsg.style.color = 'var(--ds-danger)';
                    resultMsg.innerText = "Error de red: " + err.message;
                } finally {
                    btn.style.display = 'flex';
                    loader.style.display = 'none';
                }
            });
        </script>
    </body>
</html>
