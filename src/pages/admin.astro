        // --- Simulador Tab ---
        let simHistory = [];
        
        window.sendSimMessage = async function() {
            const input = document.getElementById('sim-input');
            const msg = input.value.trim();
            if (!msg) return;
            
            input.value = '';
            appendSimBubble('User', msg);
            
            // Build history format for API
            const historyForApi = simHistory.map(h => ({ role: h.role, parts: [{ text: h.text }] }));
            historyForApi.push({ role: 'user', parts: [{ text: msg }] });
            
            simHistory.push({ role: 'user', text: msg });
            
            appendSimBubble('System', '...', true);
            
            try {
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg, history: historyForApi })
                });
                const data = await res.json();
                
                // remove loading bubble
                document.getElementById('sim-chat-window').lastChild.remove();
                
                if (res.ok) {
                    let botText = data.content;
                    if (data.cardType !== 'TextCard') {
                        botText += `\n\n[Tarjeta renderizada: ${data.cardType}]`;
                    }
                    if (data.suggestedBlocks) {
                        botText += `\n[Sugerencias: ${data.suggestedBlocks.join(' | ')}]`;
                    }
                    appendSimBubble('Bot', botText);
                    simHistory.push({ role: 'model', text: data.content }); // we only store pure text in history
                } else {
                    appendSimBubble('Error', data.error);
                }
            } catch(e) {
                document.getElementById('sim-chat-window').lastChild.remove();
                appendSimBubble('Error', 'Error de red conectando con el bot.');
            }
        };

