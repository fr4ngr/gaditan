        // --- AI Extraction Helper ---
        function setupAiExtractor() {
            const fileInput = document.getElementById('doc-pdf-upload');
            const processBtn = document.getElementById('btn-process-ai');
            if (processBtn && !processBtn.hasAttribute('data-bound')) {
                processBtn.setAttribute('data-bound', 'true');
                processBtn.addEventListener('click', async () => {
                    const textArea = document.getElementById('doc-content');
                    const appendModeCheckbox = document.getElementById('doc-pdf-append');
                    const appendMode = appendModeCheckbox ? appendModeCheckbox.checked : false;
                    
                    if (!fileInput.files || fileInput.files.length === 0) {
                        showMessage("Por favor, selecciona un archivo primero.", true);
                        return;
                    }
                    const file = fileInput.files[0];

                    const filenameInput = document.getElementById('doc-filename');
                    if (filenameInput && (!filenameInput.value || filenameInput.value === '')) {
                        const cleanName = file.name.replace(/\.[^/.]+$/, "").replace(/[^a-zA-Z0-9_-]/g, '_');
                        filenameInput.value = cleanName;
                    }
                    
                    const dateStr = new Date().toLocaleString('es-ES');
                    const originalText = appendMode && textArea.value ? textArea.value + `\n\n--- NUEVO DOCUMENTO AÑADIDO: ${dateStr} ---\n\n` : ``;
                    
                    // UI Indicators
                    document.getElementById('ai-upload-container').style.display = 'none';
                    document.getElementById('ai-error-indicator').style.display = 'none';
                    document.getElementById('ai-loading-indicator').style.display = 'flex';
                    const statusText = document.getElementById('ai-loading-text');
                    
                    statusText.innerText = "Empaquetando documento (Paso 1/2)...";
                    
                    try {
                        const reader = new FileReader();
                        reader.onload = async function(event) {
                            try {
                                const dataUrl = event.target.result;
                                const base64Data = dataUrl.split(',')[1];
                                const mimeType = file.type || 'application/pdf';

                                statusText.innerText = "Enviando a los servidores de Gemini (Paso 2/2). Esto puede tardar varios minutos si el archivo es grande...";

                                // 1. Obtener clave de la IA de forma segura
                                const keyRes = await fetch('/api/admin/keys', {
                                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                                });
                                if (!keyRes.ok) throw new Error("Fallo al autenticar la clave de la IA. Comprueba tu conexión.");
                                const { key } = await keyRes.json();

                                // 2. Llamada directa a Gemini desde el navegador para evitar el timeout de 30s de Cloudflare
                                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${key}`;
                                const prompt = `Eres un transcriptor y analista experto. Tu tarea es analizar este documento oficial y extraer su información y texto en formato JSON estructurado.

REGLAS:
1. El campo "markdown" debe contener todo el texto extraído del documento en formato Markdown. Organiza tablas y listas correctamente.
2. Extrae o deduce el nombre oficial del documento en el campo "nombre".
3. Extrae la fecha de publicación (o de firma) en el campo "fecha_publicacion".
4. Identifica la fuente de publicación. Debe ser EXCLUSIVAMENTE uno de estos valores: "BOP", "BOJA", "BOE", "Ayuntamiento" o "Otro". Ponlo en el campo "publicado_en".
5. Resume en una sola frase corta lo que regula este documento en el campo "regula".

Devuelve ÚNICAMENTE un objeto JSON válido, sin delimitadores de código markdown \`\`\`json.
Esquema requerido:
{
  "nombre": "...",
  "fecha_publicacion": "...",
  "publicado_en": "...",
  "regula": "...",
  "markdown": "..."
}`;
                                
                                const payload = {
                                    contents: [{
                                        parts: [
                                            { inlineData: { mimeType: mimeType, data: base64Data } },
                                            { text: prompt }
                                        ]
                                    }],
                                    generationConfig: {
                                        responseMimeType: "application/json"
                                    }
                                };

                                const res = await fetch(url, {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(payload)
                                });

                                if (!res.ok) {
                                    const errData = await res.json().catch(() => ({}));
                                    throw new Error(errData.error?.message || `HTTP ${res.status}`);
                                }

                                const data = await res.json();
                                if (data.candidates && data.candidates.length > 0) {
                                    const extractedText = data.candidates[0].content.parts[0].text;
                                    
                                    try {
                                        const parsedJson = JSON.parse(extractedText);
                                        
                                        // Auto-fill fields
                                        if (parsedJson.nombre) document.getElementById('doc-meta-nombre').value = parsedJson.nombre;
                                        if (parsedJson.fecha_publicacion) document.getElementById('doc-meta-fecha').value = parsedJson.fecha_publicacion;
                                        if (parsedJson.publicado_en) {
                                            const options = Array.from(document.getElementById('doc-meta-fuente').options).map(o => o.value);
                                            if (options.includes(parsedJson.publicado_en)) {
                                                document.getElementById('doc-meta-fuente').value = parsedJson.publicado_en;
                                            } else {
                                                document.getElementById('doc-meta-fuente').value = 'Otro';
                                            }
                                        }
                                        if (parsedJson.regula) document.getElementById('doc-meta-regula').value = parsedJson.regula;
                                        
                                        textArea.value = originalText + (parsedJson.markdown ? parsedJson.markdown.trim() : "");
                                    } catch (e) {
                                        console.warn("Fallo al parsear JSON, pegando texto bruto", e);
                                        textArea.value = originalText + extractedText.trim();
                                    }
                                    
                                    // Ocultar loader
                                    document.getElementById('ai-loading-indicator').style.display = 'none';
                                    document.getElementById('ai-upload-container').style.display = 'flex';
                                    fileInput.value = '';
                                    
                                    showMessage("✅ Archivo procesado. Metadatos y texto extraídos.");
                                } else {
                                    throw new Error("La IA no devolvió ningún texto. Puede que el archivo esté vacío o sea un escaneo no reconocible.");
                                }
                            } catch (err) {
                                document.getElementById('ai-loading-indicator').style.display = 'none';
                                document.getElementById('ai-error-indicator').style.display = 'block';
                                document.getElementById('ai-error-text').innerText = err.message;
                            }
                        };
                        reader.onerror = function() {
                            document.getElementById('ai-loading-indicator').style.display = 'none';
                            document.getElementById('ai-error-indicator').style.display = 'block';
                            document.getElementById('ai-error-text').innerText = "Error al leer el archivo desde tu dispositivo.";
                        };
                        reader.readAsDataURL(file);
                    } catch (err) {
                        document.getElementById('ai-loading-indicator').style.display = 'none';
                        document.getElementById('ai-error-indicator').style.display = 'block';
                        document.getElementById('ai-error-text').innerText = "Error preparando archivo: " + err.message;
                    }
                });
            }
        }
        setupAiExtractor();

        // Event Listeners for Analytics
        document.getElementById('init-db-btn').addEventListener('click', async () => {
            const btn = document.getElementById('init-db-btn');
            const originalText = btn.textContent;
            btn.textContent = 'Inicializando...';
            btn.disabled = true;

            try {
                const res = await fetch('/api/admin/db-init', {
