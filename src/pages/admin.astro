---
import '../styles/chat.css';
import '../styles/components.css';
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Cádiz Taxi</title>
    <!-- PDF.js para extraer texto de PDFs en el cliente -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        // @ts-ignore
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    </script>
    <style>
        body {
            background: var(--ds-bg-light);
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-family: system-ui, -apple-system, sans-serif;
            margin: 0;
        }
        .admin-container {
            max-width: 800px;
            width: 100%;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 16px;
        }
        label {
            font-weight: 600;
            color: var(--ds-text-primary);
        }
        input[type="password"], input[type="text"], textarea, input[type="file"] {
            padding: 10px;
            border: 1px solid var(--bubble-bot-border);
            border-radius: var(--ds-border-radius-sm);
            font-family: inherit;
            width: 100%;
            box-sizing: border-box;
        }
        textarea {
            min-height: 250px;
            resize: vertical;
        }
        .loader {
            display: none;
            text-align: center;
            margin-top: 10px;
            color: var(--ds-primary);
        }
        /* Tabs */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        .tab-btn {
            padding: 10px 20px;
            background: transparent;
            border: 1px solid var(--ds-primary);
            color: var(--ds-primary);
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        .tab-btn.active {
            background: var(--ds-primary);
            color: white;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }

        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        .status-item {
            padding: 15px;
            border-radius: 12px;
            border: 1px solid var(--bubble-bot-border);
            background: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .status-icon {
            font-size: 2rem;
        }

        .brain-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .brain-item {
            padding: 15px;
            border-radius: 8px;
            border: 1px solid var(--bubble-bot-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <!-- Login Section -->
        <div class="card" id="login-section">
            <div class="card-header primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                <h2>Acceso Admin Multi-Cerebro</h2>
            </div>
            <div class="card-body">
                <form id="login-form">
                    <div class="form-group">
                        <label for="admin-pwd">Contraseña de Administrador:</label>
                        <input type="password" id="admin-pwd" required placeholder="Contraseña..." />
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%">Entrar</button>
                    <div id="login-error" style="color: var(--ds-danger); margin-top: 10px; text-align: center;"></div>
                </form>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" style="display: none;">
            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('estado')">Estado del Servicio</button>
                <button class="tab-btn" onclick="switchTab('cerebros')">Mis Cerebros</button>
                <button class="tab-btn" onclick="switchTab('personalidad')">🤖 Personalidad</button>
                <button class="tab-btn" onclick="switchTab('simulador')">🧪 Simulador</button>
            </div>

            <div class="card">
                <div class="card-body">
                    <div id="msg-global" style="text-align: center; font-weight: bold; margin-bottom: 15px;"></div>

                    <!-- TAB 1: Estado -->
                    <div id="tab-estado" class="tab-content active">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div>
                                <h3 class="text-title">Estado del Sistema</h3>
                                <p class="text-muted">Verifica que todas las conexiones necesarias estén operativas.</p>
                            </div>
                            <button class="btn btn-primary" style="background: var(--ds-primary); border: none;" onclick="forceDeploy()">🚀 Forzar Actualización del Bot</button>
                        </div>
                        <button class="btn btn-secondary" onclick="checkStatus()">🔄 Comprobar ahora</button>
                        <div class="status-grid" id="status-grid">
                            <!-- Injected by JS -->
                        </div>
                    </div>

                    <!-- TAB 2: Gestor Jerárquico de Cerebros -->
                    <div id="tab-cerebros" class="tab-content">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                            <h3 class="text-title" id="cerebros-title">Materias de Conocimiento</h3>
                            <div style="display: flex; gap: 10px;">
                                <button class="btn btn-secondary" style="margin: 0; padding: 5px 15px;" id="btn-back-materias" onclick="showMaterias()" style="display:none;">⬅️ Volver</button>
                                <button class="btn btn-primary" style="margin: 0; padding: 5px 15px;" id="btn-new-materia" onclick="promptNewMateria()">➕ Nueva Materia</button>
                            </div>
                        </div>
                        <p class="text-muted" id="cerebros-subtitle">Gestiona las áreas de conocimiento. La IA sabrá diferenciar entre la información oficial y la comercial.</p>
                        
                        <!-- Vista 1: Lista de Materias -->
                        <div class="brain-list" id="materias-list">
                            <div class="text-center text-muted">Cargando...</div>
                        </div>

                        <!-- Vista 2: Dentro de una Materia (Subcerebros A y B) -->
                        <div id="materia-view" style="display: none; display: flex; flex-direction: column; gap: 20px;">
                            <!-- Zona A: Oficial -->
                            <div style="border: 1px solid var(--bubble-bot-border); border-radius: 8px; background: white; padding: 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 10px;">
                                    <h4 style="margin: 0; color: var(--ds-primary);">🏛️ A: Información Oficial / Pública</h4>
                                    <button class="btn btn-secondary" style="margin:0; padding:3px 10px; font-size:0.8rem;" onclick="showDocumentEditor('A_oficial')">+ Añadir Documento Oficial</button>
                                </div>
                                <div id="list-A_oficial" class="brain-list"></div>
                            </div>
                            
                            <!-- Zona B: Comercial -->
                            <div style="border: 1px solid #ffeeba; border-radius: 8px; background: #fffcf5; padding: 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ffeeba; padding-bottom: 10px; margin-bottom: 10px;">
                                    <h4 style="margin: 0; color: #856404;">💰 B: Información Comercial / Patrocinada</h4>
                                    <button class="btn btn-secondary" style="margin:0; padding:3px 10px; font-size:0.8rem;" onclick="showDocumentEditor('B_comercial')">+ Añadir Documento Comercial</button>
                                </div>
                                <div id="list-B_comercial" class="brain-list"></div>
                            </div>
                        </div>

                        <!-- Editor de Documento (Crear / Editar) -->
                        <div id="brain-editor" style="display: none; margin-top: 30px; border-top: 1px solid var(--bubble-bot-border); padding-top: 20px;">
                            <h3 class="text-title text-primary" id="editor-title">Documento</h3>
                            
                            <div class="form-group">
                                <label>Nombre del archivo (sin espacios, ej: "ordenanza_2026"):</label>
                                <input type="text" id="doc-filename" placeholder="nombre_archivo" />
                            </div>

                            <div class="form-group mt-sm">
                                <label>Cargar información desde un PDF (Opcional):</label>
                                <input type="file" id="doc-pdf-upload" accept="application/pdf" />
                                <div style="display: flex; gap: 10px; align-items: center; margin-top: 5px;">
                                    <input type="checkbox" id="doc-append-mode" checked style="width: auto;" />
                                    <label for="doc-append-mode" style="font-weight: normal; font-size: 0.9rem;">Añadir al texto existente (no borrar)</label>
                                </div>
                            </div>
                            
                            <div class="form-group" style="display: none;">
                                <label>Contenido del Texto (Markdown):</label>
                                <textarea id="doc-content" required></textarea>
                            </div>
                            
                            <div style="display: flex; gap: 10px;">
                                <button class="btn btn-primary" onclick="saveDocument()">💾 Guardar Documento</button>
                                <button class="btn btn-secondary" onclick="hideDocumentEditor()">Cancelar</button>
                            </div>
                        </div>
                    </div>

                    <!-- TAB 4: Personalidad -->
                    <div id="tab-personalidad" class="tab-content">
                        <h3 class="text-title">El "Alma" del Bot (System Prompt)</h3>
                        <p class="text-muted">Modifica la forma de ser, el tono y las reglas inquebrantables de la IA.</p>
                        
                        <div class="form-group">
                            <label>System Prompt (Markdown):</label>
                            <textarea id="system-prompt-text" style="display: block; min-height: 400px; font-family: monospace; font-size: 13px;" required></textarea>
                        </div>
                        
                        <button class="btn btn-primary" onclick="saveSystemPrompt()">💾 Guardar Personalidad</button>
                    </div>

                    <!-- TAB 5: Simulador -->
                    <div id="tab-simulador" class="tab-content">
                        <h3 class="text-title">Laboratorio de Pruebas</h3>
                        <p class="text-muted">Prueba cómo responde la IA con los cerebros actuales sin afectar a la web pública.</p>
                        
                        <div style="border: 1px solid var(--bubble-bot-border); border-radius: 8px; background: white; display: flex; flex-direction: column; height: 400px;">
                            <div id="sim-chat-window" style="flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px;">
                                <div style="background: var(--ds-bg-light); padding: 10px; border-radius: 8px; align-self: flex-start; max-width: 80%;">
                                    <strong>Bot:</strong> ¡Hola! Hazme preguntas para probar mi conocimiento.
                                </div>
                            </div>
                            <div style="border-top: 1px solid var(--bubble-bot-border); padding: 10px; display: flex; gap: 10px;">
                                <input type="text" id="sim-input" placeholder="Escribe un mensaje..." style="flex: 1; margin: 0;" onkeypress="if(event.key === 'Enter') sendSimMessage()" />
                                <button class="btn btn-primary" style="margin: 0;" onclick="sendSimMessage()">Enviar</button>
                            </div>
                        </div>
                        <button class="btn btn-secondary mt-sm" onclick="clearSimChat()">🧹 Limpiar Chat</button>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script>
        let sessionPwd = '';
        let currentEditingBrain = '';
        let currentEditingSha = '';

        // --- Auth & Tabs ---
        document.getElementById('login-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const pwd = document.getElementById('admin-pwd').value;
            const errDiv = document.getElementById('login-error');
            
            errDiv.innerText = "Comprobando...";
            try {
                const res = await fetch('/api/admin/status', {
                    headers: { 'Authorization': 'Bearer ' + pwd }
                });
                if (res.ok) {
                    sessionPwd = pwd;
                    document.getElementById('login-section').style.display = 'none';
                    document.getElementById('dashboard-section').style.display = 'block';
                    checkStatus();
                } else {
                    errDiv.innerText = "Contraseña incorrecta.";
                }
            } catch (e) {
                errDiv.innerText = "Error de red.";
            }
        });

        window.switchTab = function(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById('tab-' + tabId).classList.add('active');

            if (tabId === 'cerebros') showMaterias();
            if (tabId === 'personalidad') loadSystemPrompt();
        }

        function showMessage(msg, isError = false) {
            const div = document.getElementById('msg-global');
            div.innerText = msg;
            div.style.color = isError ? 'var(--ds-danger)' : 'var(--ds-success)';
            setTimeout(() => div.innerText = '', 5000);
        }

        // --- Status & Deploy ---
        async function checkStatus() {
            const grid = document.getElementById('status-grid');
            grid.innerHTML = "<div class='text-center w-100'>Cargando estado...</div>";
            try {
                const res = await fetch('/api/admin/status', {
                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                });
                const data = await res.json();
                
                if (res.ok) {
                    grid.innerHTML = `
                        <div class="status-item">
                            <div class="status-icon">${data.gemini ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">Cerebro Base (Gemini)</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Motor de IA activo</div>
                        </div>
                        <div class="status-item">
                            <div class="status-icon">${data.github ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">Memoria (GitHub)</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Acceso a archivos de sistema</div>
                        </div>
                        <div class="status-item">
                            <div class="status-icon">${data.aemet ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">Clima (AEMET)</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Datos meteorológicos</div>
                        </div>
                        <div class="status-item">
                            <div class="status-icon">${data.deployHook ? '✅' : '⚠️'}</div>
                            <div style="font-weight: 600;">Despliegue Rápido</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Botón de Forzar Actualización</div>
                        </div>
                        <div class="status-item" style="opacity: 0.6; background: #f8f9fa;">
                            <div class="status-icon">⏳</div>
                            <div style="font-weight: 600;">Mapas y Distancias</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Próximamente (Fase 4)</div>
                        </div>
                        <div class="status-item" style="opacity: 0.6; background: #f8f9fa;">
                            <div class="status-icon">⏳</div>
                            <div style="font-weight: 600;">Centralita (WhatsApp)</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Próximamente (Embudo)</div>
                        </div>
                        <div class="status-item" style="opacity: 0.6; background: #f8f9fa;">
                            <div class="status-icon">⏳</div>
                            <div style="font-weight: 600;">Analíticas (D1)</div>
                            <div style="font-size: 0.8rem; color: var(--ds-text-secondary); text-align: center;">Próximamente (Tendencias)</div>
                        </div>
                    `;
                }
            } catch (e) {
                grid.innerHTML = "<div class='text-danger'>Error al conectar con la API de estado.</div>";
            }
        }

        window.forceDeploy = async function() {
            if(!confirm("¿Forzar una actualización en todo el mundo ahora? (Tardará 1-2 minutos en completarse)")) return;
            showMessage("Enviando orden de despliegue a Cloudflare...", false);
            try {
                const res = await fetch('/api/admin/deploy', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                });
                if (res.ok) {
                    showMessage("🚀 ¡Orden recibida! Cloudflare está compilando y desplegando. Dale 2 minutos y tu bot estará actualizado mundialmente.");
                } else {
                    const data = await res.json();
                    showMessage("Error al desplegar: " + data.error + ". ¿Has configurado CLOUDFLARE_DEPLOY_HOOK en Cloudflare?", true);
                }
            } catch (e) {
                showMessage("Error de red enviando orden.", true);
            }
        }

        // --- Gestor Jerárquico (Materias -> A/B -> Documentos) ---
        let currentMateria = null;
        let currentSubtipo = null; // 'A_oficial' or 'B_comercial'
        let currentDocSha = null;

        window.showMaterias = async function() {
            currentMateria = null;
            document.getElementById('materia-view').style.display = 'none';
            document.getElementById('brain-editor').style.display = 'none';
            document.getElementById('btn-back-materias').style.display = 'none';
            document.getElementById('btn-new-materia').style.display = 'block';
            document.getElementById('cerebros-title').innerText = 'Materias de Conocimiento';
            document.getElementById('cerebros-subtitle').innerText = 'Gestiona las áreas de conocimiento. La IA sabrá diferenciar entre la información oficial y la comercial.';
            
            const container = document.getElementById('materias-list');
            container.style.display = 'flex';
            container.innerHTML = "Cargando materias...";

            try {
                const res = await fetch('/api/admin/brains?action=list&path=', { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                
                if (res.ok) {
                    const materias = data.filter(d => d.type === 'dir');
                    if (materias.length === 0) {
                        container.innerHTML = "<p class='text-muted'>No hay ninguna materia. ¡Crea la primera!</p>";
                        return;
                    }
                    container.innerHTML = materias.map(m => `
                        <div class="brain-item" style="cursor: pointer;" onclick="openMateria('${m.name}')">
                            <span style="font-weight:bold; font-size: 1.1rem;">📂 ${m.name}</span>
                            <span style="color: var(--ds-primary);">Abrir ➡️</span>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = "Error: " + data.error;
                }
            } catch (e) {
                container.innerHTML = "Error de red.";
            }
        };

        window.promptNewMateria = function() {
            const name = prompt("Introduce el nombre de la nueva materia (sin espacios, ej: Transporte):");
            if (name) {
                const cleanName = name.trim().replace(/[^a-zA-Z0-9_-]/g, '');
                if (cleanName) {
                    openMateria(cleanName); // Opening a non-existent materia will show it empty
                    showMessage("Materia creada. Añade un documento para que se guarde en GitHub.");
                }
            }
        };

        window.openMateria = async function(materiaName) {
            currentMateria = materiaName;
            document.getElementById('materias-list').style.display = 'none';
            document.getElementById('brain-editor').style.display = 'none';
            document.getElementById('btn-back-materias').style.display = 'block';
            document.getElementById('btn-new-materia').style.display = 'none';
            document.getElementById('cerebros-title').innerText = `Materia: ${materiaName}`;
            document.getElementById('cerebros-subtitle').innerText = 'Añade documentos oficiales (Leyes, Paradas) y comerciales (Restaurantes, Hoteles).';
            
            const view = document.getElementById('materia-view');
            view.style.display = 'flex';

            await fetchList(materiaName, 'A_oficial', 'list-A_oficial');
            await fetchList(materiaName, 'B_comercial', 'list-B_comercial');
        };

        async function fetchList(materia, tipo, containerId) {
            const container = document.getElementById(containerId);
            container.innerHTML = "<span class='text-muted'>Cargando...</span>";
            try {
                const res = await fetch(`/api/admin/brains?action=list&path=${materia}/${tipo}`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                
                if (res.ok) {
                    const files = data.filter(f => f.type === 'file' && f.name.endsWith('.md'));
                    if (files.length === 0) {
                        container.innerHTML = "<span class='text-muted' style='font-size: 0.9rem;'>No hay documentos aquí todavía.</span>";
                        return;
                    }
                    container.innerHTML = files.map(f => `
                        <div class="brain-item" style="padding: 10px; margin-bottom: 5px;">
                            <span>📄 ${f.name}</span>
                            <div style="display:flex; gap:8px;">
                                <button class="btn btn-secondary" style="margin:0; padding:2px 8px; font-size: 0.8rem;" onclick="editDocument('${tipo}', '${f.name.replace('.md', '')}')">Editar</button>
                                <button class="btn btn-danger" style="margin:0; padding:2px 8px; font-size: 0.8rem; background:var(--ds-danger); color:white; border:none; border-radius:4px;" onclick="deleteDocument('${tipo}', '${f.name}', '${f.sha}')">Borrar</button>
                            </div>
                        </div>
                    `).join('');
                } else {
                    if (res.status === 404) {
                        container.innerHTML = "<span class='text-muted' style='font-size: 0.9rem;'>Vacío (la carpeta se creará al añadir algo)</span>";
                    } else {
                        container.innerHTML = "Error: " + data.error;
                    }
                }
            } catch (e) {
                container.innerHTML = "Error de red.";
            }
        }

        window.showDocumentEditor = function(tipo) {
            currentSubtipo = tipo;
            currentDocSha = null;
            document.getElementById('brain-editor').style.display = 'block';
            document.getElementById('editor-title').innerText = `Nuevo Documento (${tipo})`;
            document.getElementById('doc-filename').value = '';
            document.getElementById('doc-filename').disabled = false;
            document.getElementById('doc-content').value = '';
            document.getElementById('doc-pdf-upload').value = '';
        };

        window.hideDocumentEditor = function() {
            document.getElementById('brain-editor').style.display = 'none';
        };

        window.editDocument = async function(tipo, filename) {
            currentSubtipo = tipo;
            document.getElementById('brain-editor').style.display = 'block';
            document.getElementById('editor-title').innerText = `Editando: ${filename}`;
            document.getElementById('doc-filename').value = filename;
            document.getElementById('doc-filename').disabled = true; // prevent rename for now
            document.getElementById('doc-content').value = 'Cargando...';
            document.getElementById('doc-pdf-upload').value = '';

            const path = `${currentMateria}/${tipo}/${filename}`;
            try {
                const res = await fetch(`/api/admin/brains?action=get&path=${path}`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                if (res.ok) {
                    document.getElementById('doc-content').value = data.content;
                    currentDocSha = data.sha;
                } else {
                    document.getElementById('doc-content').value = "Error al cargar: " + data.error;
                }
            } catch(e) {
                document.getElementById('doc-content').value = "Error de red.";
            }
        };

        window.saveDocument = async function() {
            let filename = document.getElementById('doc-filename').value.trim().replace(/[^a-zA-Z0-9_-]/g, '');
            const content = document.getElementById('doc-content').value;

            if (!filename || !content) {
                showMessage("El nombre y el contenido son obligatorios.", true);
                return;
            }

            const path = `${currentMateria}/${currentSubtipo}/${filename}`;
            showMessage("Guardando en GitHub...", false);

            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ path: path, content: content })
                });
                if (res.ok) {
                    showMessage("¡Documento guardado! El bot se actualizará.");
                    hideDocumentEditor();
                    openMateria(currentMateria); // refresh lists
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        window.deleteDocument = async function(tipo, filenameWithExt, sha) {
            if(!confirm(`¿Seguro que quieres borrar ${filenameWithExt}?`)) return;
            const filename = filenameWithExt.replace('.md', '');
            const path = `${currentMateria}/${tipo}/${filename}`;
            
            showMessage(`Borrando...`, false);
            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ path: path, sha: sha })
                });
                if (res.ok) {
                    showMessage("Documento eliminado.");
                    openMateria(currentMateria); // refresh
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        // --- Personalidad Tab ---
        window.loadSystemPrompt = async function() {
            document.getElementById('system-prompt-text').value = 'Cargando personalidad desde GitHub...';
            try {
                const res = await fetch(`/api/admin/system`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                if (res.ok) {
                    document.getElementById('system-prompt-text').value = data.content;
                } else {
                    document.getElementById('system-prompt-text').value = "Error al cargar: " + data.error;
                }
            } catch(e) {
                document.getElementById('system-prompt-text').value = "Error de red.";
            }
        };

        window.saveSystemPrompt = async function() {
            const text = document.getElementById('system-prompt-text').value;
            showMessage("Guardando nueva personalidad en GitHub...", false);
            try {
                const res = await fetch('/api/admin/system', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: text })
                });
                if (res.ok) {
                    showMessage("¡Personalidad actualizada! El bot usará esta configuración en unos minutos.");
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        // --- Simulador Tab ---
        let simHistory = [];
        
        window.sendSimMessage = async function() {
            const input = document.getElementById('sim-input');
            const msg = input.value.trim();
            if (!msg) return;
            
            input.value = '';
            appendSimBubble('User', msg);
            
            // Build history format for API
            const historyForApi = simHistory.map(h => ({ role: h.role, parts: [{ text: h.text }] }));
            historyForApi.push({ role: 'user', parts: [{ text: msg }] });
            
            simHistory.push({ role: 'user', text: msg });
            
            appendSimBubble('System', '...', true);
            
            try {
                const res = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg, history: historyForApi })
                });
                const data = await res.json();
                
                // remove loading bubble
                document.getElementById('sim-chat-window').lastChild.remove();
                
                if (res.ok) {
                    let botText = data.content;
                    if (data.cardType !== 'TextCard') {
                        botText += `\n\n[Tarjeta renderizada: ${data.cardType}]`;
                    }
                    if (data.suggestedBlocks) {
                        botText += `\n[Sugerencias: ${data.suggestedBlocks.join(' | ')}]`;
                    }
                    appendSimBubble('Bot', botText);
                    simHistory.push({ role: 'model', text: data.content }); // we only store pure text in history
                } else {
                    appendSimBubble('Error', data.error);
                }
            } catch(e) {
                document.getElementById('sim-chat-window').lastChild.remove();
                appendSimBubble('Error', 'Error de red conectando con el bot.');
            }
        };

        window.appendSimBubble = function(sender, text, isTemp = false) {
            const windowDiv = document.getElementById('sim-chat-window');
            const div = document.createElement('div');
            div.style.padding = '10px';
            div.style.borderRadius = '8px';
            div.style.maxWidth = '80%';
            div.style.whiteSpace = 'pre-wrap';
            
            if (sender === 'User') {
                div.style.alignSelf = 'flex-end';
                div.style.background = 'var(--ds-primary)';
                div.style.color = 'white';
            } else if (sender === 'Error') {
                div.style.alignSelf = 'center';
                div.style.background = '#ffebee';
                div.style.color = '#c62828';
            } else {
                div.style.alignSelf = 'flex-start';
                div.style.background = 'var(--ds-bg-light)';
                div.style.border = '1px solid var(--bubble-bot-border)';
            }
            
            div.innerHTML = `<strong>${sender}:</strong> ${text}`;
            windowDiv.appendChild(div);
            windowDiv.scrollTop = windowDiv.scrollHeight;
        };

        window.clearSimChat = function() {
            simHistory = [];
            document.getElementById('sim-chat-window').innerHTML = `
                <div style="background: var(--ds-bg-light); padding: 10px; border-radius: 8px; align-self: flex-start; max-width: 80%;">
                    <strong>Bot:</strong> ¡Hola! Hazme preguntas para probar mi conocimiento.
                </div>
            `;
        };

        // --- PDF Extraction Helper ---
        async function extractPdfToTextarea(fileInputId, textAreaId, appendCheckboxId) {
            const fileInput = document.getElementById(fileInputId);
            const textArea = document.getElementById(textAreaId);
            const appendMode = document.getElementById(appendCheckboxId) ? document.getElementById(appendCheckboxId).checked : false;
            
            fileInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                const dateStr = new Date().toLocaleString('es-ES');
                const originalText = appendMode && textArea.value ? textArea.value + `\n\n--- NUEVO DOCUMENTO AÑADIDO: ${dateStr} ---\n\n` : `--- DOCUMENTO CREADO: ${dateStr} ---\n\n`;
                showMessage("Extrayendo PDF... no cierres la ventana.", false);
                
                try {
                    const arrayBuffer = await file.arrayBuffer();
                    // @ts-ignore
                    const pdf = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
                    let fullText = "";
                    
                    for (let i = 1; i <= pdf.numPages; i++) {
                        const page = await pdf.getPage(i);
                        const textContent = await page.getTextContent();
                        const pageText = textContent.items.map(item => item.str).join(" ");
                        fullText += pageText + "\n\n";
                    }
                    
                    textArea.value = originalText + fullText.trim();
                    showMessage("✅ PDF extraído y listo para guardar.");
                } catch (err) {
                    showMessage("Error al extraer PDF: " + err.message, true);
                }
            });
        }

        extractPdfToTextarea('doc-pdf-upload', 'doc-content', 'doc-append-mode');
    </script>
</body>
</html>
