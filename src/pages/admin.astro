        window.editDocument = async function(tipo, filename) {
            currentSubtipo = tipo;
            document.getElementById('brain-editor').style.display = 'block';
            document.getElementById('editor-title').innerText = `Editando: ${filename}`;
            document.getElementById('doc-filename').value = filename;
            document.getElementById('doc-filename').disabled = true; // prevent rename for now
            document.getElementById('doc-content').value = 'Cargando...';
            document.getElementById('doc-pdf-upload').value = '';

            const path = `${currentMateria}/${tipo}/${filename}`;
            try {
                const res = await fetch(`/api/admin/brains?action=get&path=${path}`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                const data = await res.json();
                if (res.ok) {
                    currentDocSha = data.sha;
                    let rawContent = data.content;
                    
                    // Reset fields
                    document.getElementById('doc-meta-nombre').value = '';
                    document.getElementById('doc-meta-fecha').value = '';
                    document.getElementById('doc-meta-fuente').value = '';
                    document.getElementById('doc-meta-regula').value = '';
                    
                    // Parse YAML frontmatter if exists
                    if (rawContent.startsWith('---')) {
                        const endOfYaml = rawContent.indexOf('---', 3);
                        if (endOfYaml > -1) {
                            const yamlBlock = rawContent.substring(3, endOfYaml).trim();
                            rawContent = rawContent.substring(endOfYaml + 3).trimStart();
                            
                            // Simple parsing for this specific format
                            const lines = yamlBlock.split('\n');
                            lines.forEach(line => {
                                const colonIdx = line.indexOf(':');
                                if (colonIdx > -1) {
                                    const key = line.substring(0, colonIdx).trim();
                                    const val = line.substring(colonIdx + 1).trim().replace(/^["']|["']$/g, ''); // remove quotes
                                    
                                    if (key === 'nombre') document.getElementById('doc-meta-nombre').value = val;
                                    if (key === 'fecha') document.getElementById('doc-meta-fecha').value = val;
                                    if (key === 'fuente') document.getElementById('doc-meta-fuente').value = val;
                                    if (key === 'regula') document.getElementById('doc-meta-regula').value = val;
                                }
                            });
                        }
                    }
                    
                    document.getElementById('doc-content').value = rawContent;
                } else {
                    document.getElementById('doc-content').value = "Error al cargar: " + data.error;
                }
            } catch(e) {
                document.getElementById('doc-content').value = "Error de red.";
            }
        };

        window.saveDocument = async function(btnElement) {
            let filename = document.getElementById('doc-filename').value.trim().replace(/[^a-zA-Z0-9_-]/g, '');
            const rawContent = document.getElementById('doc-content').value;
            
            const metaNombre = document.getElementById('doc-meta-nombre').value.trim();
            const metaFecha = document.getElementById('doc-meta-fecha').value.trim();
            const metaFuente = document.getElementById('doc-meta-fuente').value.trim();
            const metaRegula = document.getElementById('doc-meta-regula').value.trim();
            
            let finalContent = rawContent;
            
            // Build YAML frontmatter if any metadata exists
            if (metaNombre || metaFecha || metaFuente || metaRegula) {
                let yaml = '---\n';
                if (metaNombre) yaml += `nombre: "${metaNombre.replace(/"/g, '\\"')}"\n`;
                if (metaFecha) yaml += `fecha: "${metaFecha.replace(/"/g, '\\"')}"\n`;
                if (metaFuente) yaml += `fuente: "${metaFuente.replace(/"/g, '\\"')}"\n`;
                if (metaRegula) yaml += `regula: "${metaRegula.replace(/"/g, '\\"')}"\n`;
                yaml += '---\n\n';
                finalContent = yaml + rawContent;
            }

            if (!filename || !rawContent) {
                showMessage("El nombre y el contenido son obligatorios.", true);
                return;
            }

            const path = `${currentMateria}/${currentSubtipo}/${filename}`;
            showMessage("Guardando en GitHub...", false);

            if (btnElement) {
                btnElement.disabled = true;
            }

            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ path: path, content: finalContent })
                });
                if (res.ok) {
                    showMessage("¡Documento guardado! El bot se actualizará.");
                    hideDocumentEditor();
                    openMateria(currentMateria); // refresh lists
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            } finally {
                if (btnElement) {
                    btnElement.disabled = false;
                }
            }
        };

