---
import '../styles/chat.css';
import '../styles/components.css';
---

<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - Cádiz Taxi</title>
    <!-- PDF.js para extraer texto de PDFs en el cliente -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        // @ts-ignore
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    </script>
    <style>
        body {
            background: var(--ds-bg-light);
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-family: system-ui, -apple-system, sans-serif;
            margin: 0;
        }
        .admin-container {
            max-width: 800px;
            width: 100%;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 16px;
        }
        label {
            font-weight: 600;
            color: var(--ds-text-primary);
        }
        input[type="password"], input[type="text"], textarea, input[type="file"] {
            padding: 10px;
            border: 1px solid var(--bubble-bot-border);
            border-radius: var(--ds-border-radius-sm);
            font-family: inherit;
            width: 100%;
            box-sizing: border-box;
        }
        textarea {
            min-height: 250px;
            resize: vertical;
        }
        .loader {
            display: none;
            text-align: center;
            margin-top: 10px;
            color: var(--ds-primary);
        }
        /* Tabs */
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        .tab-btn {
            padding: 10px 20px;
            background: transparent;
            border: 1px solid var(--ds-primary);
            color: var(--ds-primary);
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        .tab-btn.active {
            background: var(--ds-primary);
            color: white;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }

        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        .status-item {
            padding: 15px;
            border-radius: 12px;
            border: 1px solid var(--bubble-bot-border);
            background: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .status-icon {
            font-size: 2rem;
        }

        .brain-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .brain-item {
            padding: 15px;
            border-radius: 8px;
            border: 1px solid var(--bubble-bot-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <!-- Login Section -->
        <div class="card" id="login-section">
            <div class="card-header primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                <h2>Acceso Admin Multi-Cerebro</h2>
            </div>
            <div class="card-body">
                <form id="login-form">
                    <div class="form-group">
                        <label for="admin-pwd">Contraseña de Administrador:</label>
                        <input type="password" id="admin-pwd" required placeholder="Contraseña..." />
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%">Entrar</button>
                    <div id="login-error" style="color: var(--ds-danger); margin-top: 10px; text-align: center;"></div>
                </form>
            </div>
        </div>

        <!-- Dashboard Section -->
        <div id="dashboard-section" style="display: none;">
            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('estado')">Estado del Servicio</button>
                <button class="tab-btn" onclick="switchTab('ver-cerebros')">Mis Cerebros</button>
                <button class="tab-btn" onclick="switchTab('crear-cerebro')">+ Nuevo Cerebro</button>
            </div>

            <div class="card">
                <div class="card-body">
                    <div id="msg-global" style="text-align: center; font-weight: bold; margin-bottom: 15px;"></div>

                    <!-- TAB 1: Estado -->
                    <div id="tab-estado" class="tab-content active">
                        <h3 class="text-title">Estado del Sistema</h3>
                        <p class="text-muted">Verifica que todas las conexiones necesarias estén operativas.</p>
                        <button class="btn btn-secondary" onclick="checkStatus()">🔄 Comprobar ahora</button>
                        <div class="status-grid" id="status-grid">
                            <!-- Injected by JS -->
                        </div>
                    </div>

                    <!-- TAB 2: Ver Cerebros -->
                    <div id="tab-ver-cerebros" class="tab-content">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <h3 class="text-title">Tus Cerebros Activos</h3>
                            <button class="btn btn-secondary" style="margin: 0; padding: 5px 15px;" onclick="loadBrainsList()">🔄 Refrescar</button>
                        </div>
                        <p class="text-muted">Estas son las áreas de conocimiento que la IA consulta actualmente.</p>
                        
                        <div class="brain-list" id="brains-list-container">
                            <div class="text-center text-muted">Cargando...</div>
                        </div>

                        <!-- Editor Modal/Section -->
                        <div id="brain-editor" style="display: none; margin-top: 30px; border-top: 1px solid var(--bubble-bot-border); padding-top: 20px;">
                            <h3 class="text-title text-primary" id="editor-title">Editando: ...</h3>
                            
                            <div class="form-group mt-sm">
                                <label>Extraer desde PDF (Opcional):</label>
                                <input type="file" id="edit-pdf-upload" accept="application/pdf" />
                                <div style="display: flex; gap: 10px; align-items: center; margin-top: 5px;">
                                    <input type="checkbox" id="edit-append-mode" checked style="width: auto;" />
                                    <label for="edit-append-mode" style="font-weight: normal; font-size: 0.9rem;">Añadir al final (no borrar el texto actual)</label>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label>Contenido del Cerebro (Markdown):</label>
                                <textarea id="edit-knowledge-text" required></textarea>
                            </div>
                            
                            <div style="display: flex; gap: 10px;">
                                <button class="btn btn-primary" onclick="saveEditedBrain()">💾 Guardar Cambios</button>
                                <button class="btn btn-secondary" onclick="document.getElementById('brain-editor').style.display='none'">Cancelar</button>
                            </div>
                        </div>
                    </div>

                    <!-- TAB 3: Crear Cerebro -->
                    <div id="tab-crear-cerebro" class="tab-content">
                        <h3 class="text-title">Añadir Nueva Área de Conocimiento</h3>
                        <p class="text-muted">Crea un archivo nuevo. Una vez guardado, el sistema se redesplegará e inyectará este nuevo cerebro en el chat.</p>
                        
                        <div class="form-group">
                            <label>Nombre del Cerebro (sin espacios ni símbolos raros, ej: "restaurantes"):</label>
                            <input type="text" id="new-brain-name" placeholder="historia_cadiz" required />
                        </div>

                        <div class="form-group mt-sm">
                            <label>Extraer desde PDF (Opcional):</label>
                            <input type="file" id="new-pdf-upload" accept="application/pdf" />
                        </div>
                        
                        <div class="form-group">
                            <label>Contenido del Cerebro (Markdown):</label>
                            <textarea id="new-knowledge-text" required placeholder="Pega aquí la información o súbela desde un PDF..."></textarea>
                        </div>
                        
                        <button class="btn btn-primary" onclick="createNewBrain()">➕ Crear Cerebro</button>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script>
        let sessionPwd = '';
        let currentEditingBrain = '';
        let currentEditingSha = '';

        // --- Auth & Tabs ---
        document.getElementById('login-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const pwd = document.getElementById('admin-pwd').value;
            const errDiv = document.getElementById('login-error');
            
            errDiv.innerText = "Comprobando...";
            try {
                const res = await fetch('/api/admin/status', {
                    headers: { 'Authorization': 'Bearer ' + pwd }
                });
                if (res.ok) {
                    sessionPwd = pwd;
                    document.getElementById('login-section').style.display = 'none';
                    document.getElementById('dashboard-section').style.display = 'block';
                    checkStatus();
                } else {
                    errDiv.innerText = "Contraseña incorrecta.";
                }
            } catch (e) {
                errDiv.innerText = "Error de red.";
            }
        });

        window.switchTab = function(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById('tab-' + tabId).classList.add('active');

            if (tabId === 'ver-cerebros') loadBrainsList();
        }

        function showMessage(msg, isError = false) {
            const div = document.getElementById('msg-global');
            div.innerText = msg;
            div.style.color = isError ? 'var(--ds-danger)' : 'var(--ds-success)';
            setTimeout(() => div.innerText = '', 5000);
        }

        // --- Status Tab ---
        async function checkStatus() {
            const grid = document.getElementById('status-grid');
            grid.innerHTML = "<div class='text-center w-100'>Cargando estado...</div>";
            try {
                const res = await fetch('/api/admin/status', {
                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                });
                const data = await res.json();
                
                if (res.ok) {
                    grid.innerHTML = `
                        <div class="status-item">
                            <div class="status-icon">${data.gemini ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">Gemini API</div>
                        </div>
                        <div class="status-item">
                            <div class="status-icon">${data.github ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">GitHub Token</div>
                        </div>
                        <div class="status-item">
                            <div class="status-icon">${data.aemet ? '✅' : '❌'}</div>
                            <div style="font-weight: 600;">AEMET API</div>
                        </div>
                    `;
                }
            } catch (e) {
                grid.innerHTML = "<div class='text-danger'>Error al conectar con la API de estado.</div>";
            }
        }

        // --- Brains List Tab ---
        async function loadBrainsList() {
            const container = document.getElementById('brains-list-container');
            container.innerHTML = "Cargando...";
            document.getElementById('brain-editor').style.display = 'none';

            try {
                const res = await fetch('/api/admin/brains', {
                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                });
                const data = await res.json();
                
                if (res.ok) {
                    if (data.length === 0) {
                        container.innerHTML = "<p>No hay cerebros. ¡Crea uno!</p>";
                        return;
                    }
                    container.innerHTML = data.map(b => `
                        <div class="brain-item">
                            <span style="font-weight:bold;">🧠 ${b.name}</span>
                            <div style="display:flex; gap:8px;">
                                <button class="btn btn-secondary" style="margin:0; padding:5px 10px;" onclick="editBrain('${b.name}')">✏️ Editar</button>
                                <button class="btn btn-danger" style="margin:0; padding:5px 10px; background:var(--ds-danger); color:white; border:none; border-radius:20px; cursor:pointer;" onclick="deleteBrain('${b.name}', '${b.sha}')">🗑️</button>
                            </div>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = "Error: " + data.error;
                }
            } catch (e) {
                container.innerHTML = "Error de red.";
            }
        }

        window.editBrain = async function(name) {
            document.getElementById('brain-editor').style.display = 'block';
            document.getElementById('editor-title').innerText = `Editando: ${name}`;
            document.getElementById('edit-knowledge-text').value = 'Cargando contenido desde GitHub...';
            currentEditingBrain = name;

            try {
                const res = await fetch(`/api/admin/brains?file=${name}`, {
                    headers: { 'Authorization': 'Bearer ' + sessionPwd }
                });
                const data = await res.json();
                if (res.ok) {
                    document.getElementById('edit-knowledge-text').value = data.content;
                    currentEditingSha = data.sha;
                } else {
                    document.getElementById('edit-knowledge-text').value = "Error al cargar: " + data.error;
                }
            } catch(e) {
                document.getElementById('edit-knowledge-text').value = "Error de red.";
            }
        };

        window.saveEditedBrain = async function() {
            const text = document.getElementById('edit-knowledge-text').value;
            showMessage("Guardando en GitHub...", false);
            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filename: currentEditingBrain, content: text })
                });
                if (res.ok) {
                    showMessage("¡Guardado exitosamente! El bot se actualizará en unos minutos.");
                    document.getElementById('brain-editor').style.display = 'none';
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        window.deleteBrain = async function(name, sha) {
            if(!confirm(`¿Seguro que quieres borrar el cerebro "${name}"?`)) return;
            showMessage(`Borrando ${name}...`, false);
            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filename: name, sha: sha })
                });
                if (res.ok) {
                    showMessage("Cerebro eliminado correctamente.");
                    loadBrainsList();
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        // --- Create Tab ---
        window.createNewBrain = async function() {
            const nameInput = document.getElementById('new-brain-name').value.trim().replace(/[^a-zA-Z0-9_-]/g, '');
            const text = document.getElementById('new-knowledge-text').value;

            if (!nameInput || !text) {
                showMessage("El nombre y el contenido son obligatorios.", true);
                return;
            }

            showMessage("Creando en GitHub...", false);
            try {
                const res = await fetch('/api/admin/brains', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ filename: nameInput, content: text })
                });
                if (res.ok) {
                    showMessage(`¡Cerebro "${nameInput}" creado! El bot se actualizará en unos minutos.`);
                    document.getElementById('new-brain-name').value = '';
                    document.getElementById('new-knowledge-text').value = '';
                } else {
                    const data = await res.json();
                    showMessage("Error: " + data.error, true);
                }
            } catch (e) {
                showMessage("Error de red", true);
            }
        };

        // --- PDF Extraction Helper ---
        async function extractPdfToTextarea(fileInputId, textAreaId, appendCheckboxId) {
            const fileInput = document.getElementById(fileInputId);
            const textArea = document.getElementById(textAreaId);
            const appendMode = document.getElementById(appendCheckboxId) ? document.getElementById(appendCheckboxId).checked : false;
            
            fileInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                
                const originalText = appendMode && textArea.value ? textArea.value + "\n\n--- NUEVO DOCUMENTO ---\n\n" : "";
                textArea.value = originalText + "Extrayendo texto del PDF... Por favor espera.";
                
                try {
                    const arrayBuffer = await file.arrayBuffer();
                    // @ts-ignore
                    const pdf = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
                    let fullText = "";
                    
                    for (let i = 1; i <= pdf.numPages; i++) {
                        const page = await pdf.getPage(i);
                        const textContent = await page.getTextContent();
                        const pageText = textContent.items.map(item => item.str).join(" ");
                        fullText += pageText + "\n\n";
                    }
                    
                    textArea.value = originalText + fullText.trim();
                } catch (err) {
                    textArea.value = originalText + "\nError al extraer PDF: " + err.message;
                }
                // Reset file input
                fileInput.value = '';
            });
        }

        extractPdfToTextarea('edit-pdf-upload', 'edit-knowledge-text', 'edit-append-mode');
        extractPdfToTextarea('new-pdf-upload', 'new-knowledge-text', null);
    </script>
</body>
</html>
