    <script>
        let sessionPwd = '';
        let currentEditingBrain = '';
        let currentEditingSha = '';

        // --- SIMULADOR UI ---
        function renderSimCard(data) {
            if (data.content) {
                data.content = data.content.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>').replace(/\*(.*?)\*/g, '<i>$1</i>').replace(/\n/g, '<br>');
            }
            const title = data.title || '';
            const subtitle = data.subtitle || '';
            const badge = data.badge ? `<div style="font-size: 0.75rem; text-transform: uppercase; font-weight: bold; color: var(--ds-primary); letter-spacing: 0.5px; margin-bottom: 4px;">${data.badge}</div>` : '';
            const img = data.imageUrl ? `<img src="${data.imageUrl}" alt="${title}" style="width: 100%; height: 180px; object-fit: cover;">` : '<div style="width: 100%; height: 180px; background: linear-gradient(45deg, #f1f5f9, #e2e8f0); display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 2.5rem; border-bottom: 1px solid var(--bubble-bot-border);">🖼️</div>';
            
            let buttonHtml = '';
            if (data.buttonText) {
                buttonHtml = `<button class="btn btn-primary btn-rect" style="width:100%; margin-top:12px;">${data.buttonText}</button>`;
            }

            if (data.cardType === 'TextCard') {
                return `<span class="bubble bubble-bot">${data.content || 'Sin texto'}</span>`;
            }

            if (data.cardType === 'HeroCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot" style="border-bottom-left-radius: 4px;">${data.content || ''}</span>
                    <div class="card mt-sm" style="overflow: hidden; border-radius: 12px; border: 1px solid var(--bubble-bot-border);">
                        ${img}
                        <div class="card-body">
                            ${badge}
                            <h3 style="margin:0 0 8px 0; color:var(--ds-text-primary);">${title}</h3>
                            ${subtitle ? `<p class="text-muted" style="margin:0">${subtitle}</p>` : ''}
                            ${buttonHtml}
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'ListCard') {
                let listHtml = '';
                if (data.listItems && Array.isArray(data.listItems)) {
                    listHtml = data.listItems.map((item, i) => `
                        <div style="display:flex; align-items:center; gap: 12px; padding: 12px 0; border-bottom: ${i < data.listItems.length - 1 ? '1px solid var(--bubble-bot-border)' : 'none'};">
                            <div style="font-size:1.5rem; width:40px; text-align:center; flex-shrink:0;">${item.icon || '📌'}</div>
                            <div style="flex:1;">
                                <div style="font-weight:600; color:var(--ds-text-primary);">${item.title}</div>
                                ${item.subtitle ? `<div style="font-size:0.85rem; color:var(--text-muted); margin-top:2px;">${item.subtitle}</div>` : ''}
                            </div>
                        </div>
                    `).join('');
                }
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot" style="border-bottom-left-radius: 4px;">${data.content || ''}</span>
                    <div class="card mt-sm">
                        <div class="card-body">
                            ${badge}
                            <h3 style="margin:0 0 12px 0; color:var(--ds-text-primary);">${title}</h3>
                            <div style="display:flex; flex-direction:column;">
                                ${listHtml}
                            </div>
                            ${buttonHtml}
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'BusinessCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot" style="border-bottom-left-radius: 4px;">${data.content || ''}</span>
                    <div class="card mt-sm">
                        <div class="card-body">
                            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 12px;">
                                <h4 style="margin:0; color:var(--ds-text-primary); font-size:1.1rem;">${title}</h4>
                                ${data.subtitle ? `<div style="background:var(--ds-success); color:white; padding:4px 8px; border-radius:12px; font-size:0.75rem; font-weight:bold;">${data.subtitle}</div>` : ''}
                            </div>
                            ${data.locationTitle ? `<div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; font-size:0.9rem;"><span>📍</span> <span style="color:var(--text-muted);">${data.locationTitle}</span></div>` : ''}
                            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:8px; margin-top:12px;">
                                ${data.phoneNumber ? `<button class="btn btn-secondary" style="font-size: 0.85rem; padding: 6px;">📞 Llamar</button>` : ''}
                                ${data.website ? `<button class="btn btn-primary" style="font-size: 0.85rem; padding: 6px;">🌐 Web</button>` : ''}
                            </div>
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'ProductCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot" style="border-bottom-left-radius: 4px;">${data.content || ''}</span>
                    <div class="card mt-sm" style="overflow: hidden; display: flex; flex-direction: row; align-items: center;">
                        ${data.imageUrl ? `<img src="${data.imageUrl}" alt="${title}" style="width: 100px; height: 100px; object-fit: cover;">` : '<div style="width: 100px; height: 100px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 1.5rem; border-right: 1px solid var(--bubble-bot-border);">📦</div>'}
                        <div class="card-body" style="flex:1;">
                            ${badge}
                            <h4 style="margin:0 0 4px 0; color:var(--ds-text-primary);">${title}</h4>
                            <div style="display:flex; align-items:baseline; gap:8px;">
                                <span style="font-size:1.2rem; font-weight:bold; color:var(--ds-text-primary);">${data.price || ''}</span>
                                ${data.oldPrice ? `<span style="font-size:0.85rem; color:var(--text-muted); text-decoration:line-through;">${data.oldPrice}</span>` : ''}
                            </div>
                            ${buttonHtml}
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'AlertCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot">${data.content || ''}</span>
                    <div class="card mt-sm" style="border: 1px solid #fca5a5; background: #fef2f2;">
                        <div class="card-body">
                            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
                                <span style="font-size:1.5rem;">⚠️</span>
                                <h3 style="margin:0; color:#991b1b; font-size: 1.1rem;">${title}</h3>
                            </div>
                            <p style="margin:0; font-size: 0.9rem; color: #7f1d1d;">${subtitle}</p>
                            ${buttonHtml}
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'ProfileCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot">${data.content || ''}</span>
                    <div class="card mt-sm" style="text-align: center;">
                        <div class="card-body">
                            ${data.imageUrl ? `<img src="${data.imageUrl}" alt="${title}" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px auto; border: 2px solid var(--ds-primary);">` : `<div style="width: 80px; height: 80px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 12px auto; border: 2px solid var(--ds-primary);">👤</div>`}
                            <h3 style="margin:0 0 4px 0; color:var(--ds-text-primary); font-size: 1.1rem;">${title}</h3>
                            <p style="margin:0 0 12px 0; font-size: 0.85rem; color: #64748b;">${subtitle}</p>
                            <div style="display:flex; justify-content:center; gap:12px;">
                                ${data.phoneNumber ? `<button class="btn btn-secondary" style="font-size: 0.8rem; padding: 6px;">📞 Contactar</button>` : ''}
                            </div>
                            ${buttonHtml}
                        </div>
                    </div>
                </div>`;
            }

            if (data.cardType === 'ArticleCard') {
                return `
                <div class="flex-col gap-sm" style="width: 100%; max-width: 100%; align-self: flex-start; margin-bottom: 0.5rem;">
                    <span class="bubble bubble-bot">${data.content || ''}</span>
                    <div class="card mt-sm">
                        <div class="card-body">
