        async function executeDeleteMateria() {
            showMessage(`Borrando materia ${currentMateria}... Puede tardar unos segundos.`, false);
            try {
                let filesToDelete = [];
                const resA = await fetch(`/api/admin/brains?action=list&path=${currentMateria}/A_oficial`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                if(resA.ok) { const files = await resA.json(); files.forEach(f => filesToDelete.push({path: `${currentMateria}/A_oficial/${f.name.replace('.md', '')}`, sha: f.sha})); }
                
                const resB = await fetch(`/api/admin/brains?action=list&path=${currentMateria}/B_comercial`, { headers: { 'Authorization': 'Bearer ' + sessionPwd } });
                if(resB.ok) { const files = await resB.json(); files.forEach(f => filesToDelete.push({path: `${currentMateria}/B_comercial/${f.name.replace('.md', '')}`, sha: f.sha})); }

                for(let file of filesToDelete) {
                    await fetch('/api/admin/brains', {
                        method: 'DELETE',
                        headers: { 'Authorization': 'Bearer ' + sessionPwd, 'Content-Type': 'application/json' },
                        body: JSON.stringify({ path: file.path, sha: file.sha })
                    });
                }
                
                showMessage("Materia borrada por completo.");
