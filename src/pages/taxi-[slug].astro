---
import fs from 'fs';
import path from 'path';
import ChatLayout from '../layouts/ChatLayout.astro';

export async function getStaticPaths() {
  const jsonPath = path.resolve('./src/data/landing-pages.json');
  const data = JSON.parse(fs.readFileSync(jsonPath, 'utf-8'));

  return data.map((page: any) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<ChatLayout title={page.title}>
    <meta name="description" content={page.description} slot="head" />
    <meta name="keywords" content={page.keywords} slot="head" />
    
    <!-- Contenido SEO oculto para los motores de búsqueda, pero la UI principal será el chat -->
    <div style="display: none;">
        <h1>{page.h1}</h1>
        <p>{page.description}</p>
    </div>

    <!-- El contenedor de mensajes está vacío inicialmente, se llena con JS -->
    <div id="chat-messages-container" style="display: contents;">
        <!-- Los mensajes se inyectarán aquí -->
    </div>
    
    <!-- Script para inicializar el chat con el contexto de la Landing Page -->
    <script define:vars={{ relatedStop: page.relatedStop, h1Title: page.h1 }}>
        // Esperamos a que chat-ui.js se cargue o interceptamos la carga inicial
        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                // Sobrescribir el saludo inicial si window.sendToAI está listo
                if (window.sendToAI) {
                    const messagesContainer = document.getElementById('chat-messages-container');
                    if (messagesContainer) {
                        // Limpiar el mensaje inicial por defecto si lo hay
                        const defaultMessages = messagesContainer.querySelectorAll('.message');
                        defaultMessages.forEach(el => el.remove());
                    }
                    
                    // Enviar un mensaje de inicialización invisible o simular una petición
                    const prePrompt = `Hola, vengo buscando información sobre: ${h1Title}. Muestra la información oficial.`;
                    
                    // Solo para iniciar la conversación con contexto (simulado)
                    window.sendToAI(prePrompt);
                }
            }, 1000); // Dar tiempo a la inicialización del ChatLayout
        });
    </script>
</ChatLayout>
